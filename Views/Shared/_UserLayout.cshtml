    <style>
        /* ===================================================================
               1. BASE / GLOBAL
            =================================================================== */
        body {
            padding-top: 118px;
            font-family: 'Poppins', sans-serif;
        }

        /* ===================================================================
               2. HEADER SHELL (fixed, glass overlay)
            =================================================================== */
        .site-header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 1000;
            background: rgba(18, 28, 8, 0.45);
            backdrop-filter: blur(14px) saturate(160%);
            -webkit-backdrop-filter: blur(14px) saturate(160%);
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            transition: background 0.4s ease, box-shadow 0.4s ease;
        }

            .site-header.scrolled {
                background: rgba(10, 18, 4, 0.96);
                box-shadow: 0 4px 24px rgba(0, 0, 0, 0.35);
            }

                .site-header.scrolled .main-nav-row {
                    padding: 8px 0;
                }

            .site-header .container {
                max-width: 100%;
                padding-left: 24px;
                padding-right: 24px;
            }

        /* ===================================================================
               3. MARQUEE ANNOUNCEMENT BAR
            =================================================================== */
        .marquee-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: linear-gradient(90deg, #365400, #567f00);
            color: #fff;
            height: 36px;
            overflow: hidden;
            font-size: 12.5px;
            letter-spacing: 0.3px;
        }

        .marquee-track {
            display: flex;
            gap: 70px;
            white-space: nowrap;
            animation: marquee-scroll 70s linear infinite;
            padding-left: 100%;
            will-change: transform;
        }

        .marquee-bar:hover .marquee-track {
            animation-play-state: paused;
        }

        .marquee-track span {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-weight: 500;
            color: #ffffff;
            text-shadow: 0 1px 3px rgba(0, 0, 0, 0.3);
        }

            .marquee-track span i {
                color: #d4f09b;
            }

        @@keyframes marquee-scroll {
            0%

        {
            transform: translateX(0);
        }

        100% {
            transform: translateX(-100%);
        }

        }

        .marquee-social {
            display: flex;
            gap: 16px;
            padding: 0 22px;
            flex-shrink: 0;
            background: rgba(0, 0, 0, 0.2);
            height: 100%;
            align-items: center;
        }

            .marquee-social a {
                color: #fff;
                opacity: 0.85;
                font-size: 13px;
                transition: opacity 0.2s, transform 0.2s;
            }

                .marquee-social a:hover {
                    opacity: 1;
                    transform: translateY(-1px);
                }

        /* ===================================================================
               4. MAIN NAV ROW (locked to one straight line on desktop)
            =================================================================== */
        .main-nav-row {
            padding: 16px 0;
            transition: padding 0.3s ease;
            flex-wrap: nowrap !important;
        }

        #logo {
            flex-shrink: 0;
        }

            #logo img {
                height: 40px;
                width: auto;
            }

        #nav-menu-container {
            flex: 1;
            min-width: 0;
            display: flex;
            justify-content: flex-end;
            overflow: visible;
        }

        .nav-menu {
            display: flex;
            flex-wrap: nowrap;
            align-items: center;
            gap: 4px;
            margin: 0;
            padding: 0;
            list-style: none;
            white-space: nowrap;
        }

            .nav-menu li {
                position: relative;
                margin-right: 2px;
            }

            /* ===================================================================
               5. TOP-LEVEL NAV LINKS
            =================================================================== */
            .nav-menu > li > a {
                color: #fff !important;
                font-size: 14px;
                font-weight: 500;
                padding: 8px 14px;
                border-radius: 6px;
                display: inline-flex;
                align-items: center;
                gap: 7px;
                white-space: nowrap;
                transition: background 0.2s ease, color 0.2s ease;
            }

                .nav-menu > li > a i:first-child {
                    font-size: 13px;
                    color: #d4f09b;
                }

                .nav-menu > li > a .caret {
                    font-size: 10px;
                    margin-left: 4px;
                    color: rgba(255, 255, 255, 0.6);
                    transition: transform 0.25s ease;
                }

            .nav-menu > li:hover > a .caret {
                transform: rotate(180deg);
            }

            .nav-menu > li:not(.user-menu):not(.auth-buttons) > a:hover,
            .nav-menu > li.menu-active > a {
                background: rgba(136, 210, 0, 0.22);
                color: #d4f09b !important;
            }

                .nav-menu > li.menu-active > a i:first-child {
                    color: #d4f09b;
                }

            /* ===================================================================
               6. DROPDOWN MENUS (Shop / My Account / Selling / More)
            =================================================================== */
            .nav-menu .sub-menu {
                position: absolute;
                top: calc(100% + 12px);
                left: 0;
                min-width: 230px;
                background: #fff;
                box-shadow: 0 18px 44px rgba(0, 0, 0, 0.2);
                border-radius: 12px;
                border-top: 3px solid #88d200;
                padding: 10px 0;
                margin: 0;
                list-style: none;
                opacity: 0;
                visibility: hidden;
                transform: translateY(10px);
                transition: all 0.25s cubic-bezier(.4, 0, .2, 1);
                z-index: 1001;
                white-space: normal;
            }

            .nav-menu li:hover .sub-menu {
                opacity: 1;
                visibility: visible;
                transform: translateY(0);
            }

            .nav-menu .sub-menu li a {
                display: flex;
                align-items: center;
                gap: 11px;
                padding: 9px 20px;
                color: #333 !important;
                font-size: 13.5px;
                font-weight: 400;
                white-space: nowrap;
                transition: background 0.2s ease, color 0.2s ease, padding-left 0.2s ease;
            }

                .nav-menu .sub-menu li a i {
                    width: 15px;
                    color: #6fa800;
                    font-size: 13px;
                }

                .nav-menu .sub-menu li a:hover {
                    background: #f0fae6;
                    color: #4d7a00 !important;
                    padding-left: 24px;
                }

        .dropdown-divider {
            height: 1px;
            background: #eee;
            margin: 6px 0;
        }

        /* ===================================================================
               7. AUTH BUTTONS (logged out state)
            =================================================================== */
        .auth-buttons {
            display: flex;
            gap: 10px;
            margin-left: 10px;
            flex-shrink: 0;
        }

        .btn-nav {
            padding: 9px 20px;
            border-radius: 24px;
            font-size: 14px;
            font-weight: 500;
            white-space: nowrap;
            transition: all 0.25s ease;
        }

        .btn-nav-outline {
            color: #fff !important;
            border: 1.5px solid rgba(255, 255, 255, 0.5);
        }

            .btn-nav-outline:hover {
                border-color: #d4f09b;
                background: rgba(255, 255, 255, 0.1);
                color: #d4f09b !important;
            }

        .btn-nav-solid {
            background: linear-gradient(90deg, #6fa800, #88d200);
            color: #fff !important;
            box-shadow: 0 4px 14px rgba(136, 210, 0, 0.4);
        }

            .btn-nav-solid:hover {
                box-shadow: 0 6px 20px rgba(136, 210, 0, 0.55);
                transform: translateY(-1px);
            }

        /* ===================================================================
               8. USER AVATAR + ACCOUNT DROPDOWN (logged in state)
            =================================================================== */
        .nav-menu > li.user-menu {
            margin-left: 10px;
            margin-right: 4px;
            flex-shrink: 0;
        }

        .user-menu-trigger {
            display: flex !important;
            align-items: center;
            gap: 9px;
            padding: 6px 14px 6px 6px !important;
            border-radius: 30px !important;
            background: rgba(255, 255, 255, 0.12);
            border: 1px solid rgba(255, 255, 255, 0.18);
            max-width: 220px;
        }

            .user-menu-trigger:hover {
                background: rgba(255, 255, 255, 0.2) !important;
            }

        .user-avatar {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: linear-gradient(135deg, #d4f09b, #6fa800);
            color: #1c2e00;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: 700;
            flex-shrink: 0;
            border: 2px solid rgba(255, 255, 255, 0.4);
        }

        .user-name {
            font-size: 14px;
            font-weight: 500;
            color: #fff;
            max-width: 150px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            display: inline-block;
        }

        .user-caret {
            font-size: 11px;
            color: rgba(255, 255, 255, 0.75);
            transition: transform 0.25s ease;
            flex-shrink: 0;
        }

        .user-menu:hover .user-caret {
            transform: rotate(180deg);
        }

        /* --- Dropdown card --- */
        .user-dropdown {
            right: -50px !important;
            left: auto;
            width: 270px;
            min-width: 270px;
            max-width: 270px;
            box-sizing: border-box;
            border-top: 3px solid #6fa800;
        }

        .user-dropdown-header {
            display: flex !important;
            align-items: flex-start;
            gap: 12px;
            padding: 8px 18px 14px 18px !important;
            box-sizing: border-box;
            width: 100%;
        }

        .user-avatar-lg {
            width: 44px;
            height: 44px;
            font-size: 18px;
            flex-shrink: 0;
        }

        .user-dropdown-header > div {
            min-width: 0;
            flex: 1;
        }

        .user-dropdown-header strong {
            display: block;
            font-size: 14px;
            color: #222;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .user-dropdown-header small {
            display: block;
            color: #888;
            font-size: 12px;
            line-height: 1.4;
            word-break: break-all;
            overflow-wrap: break-word;
            white-space: normal;
            margin-top: 2px;
        }

        .logout-btn {
            display: flex;
            align-items: center;
            gap: 11px;
            width: 100%;
            text-align: left;
            background: none;
            border: none;
            padding: 9px 20px;
            font-size: 13.5px;
            color: #b9394f;
            cursor: pointer;
        }

            .logout-btn:hover {
                background: #fdf0f2;
            }

            .logout-btn i {
                width: 15px;
            }

        /* ===================================================================
               9. MOBILE HAMBURGER TOGGLE
            =================================================================== */
        .nav-toggle {
            display: none;
            flex-direction: column;
            justify-content: center;
            gap: 5px;
            width: 38px;
            height: 38px;
            background: rgba(255, 255, 255, 0.12);
            border: 1px solid rgba(255, 255, 255, 0.18);
            border-radius: 8px;
            cursor: pointer;
            flex-shrink: 0;
        }

            .nav-toggle span {
                width: 18px;
                height: 2px;
                background: #fff;
                margin: 0 auto;
                transition: all 0.3s ease;
            }

            .nav-toggle.active span:nth-child(1) {
                transform: translateY(7px) rotate(45deg);
            }

            .nav-toggle.active span:nth-child(2) {
                opacity: 0;
            }

            .nav-toggle.active span:nth-child(3) {
                transform: translateY(-7px) rotate(-45deg);
            }

        /* ===================================================================
               10. RESPONSIVE (≤991px)
            =================================================================== */
        @@media (max-width: 991px) {
            .marquee-social

        {
            display: none;
        }

        body {
            padding-top: 90px;
        }

        .nav-toggle {
            display: flex;
        }

        #nav-menu-container {
            position: fixed;
            top: 90px;
            left: 0;
            width: 100%;
            max-height: calc(100vh - 90px);
            overflow-y: auto;
            background: rgba(10, 18, 4, 0.98);
            justify-content: flex-start;
            transform: translateY(-12px);
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
        }

            #nav-menu-container.open {
                transform: translateY(0);
                opacity: 1;
                visibility: visible;
            }

        .nav-menu {
            flex-direction: column;
            align-items: stretch;
            white-space: normal;
            padding: 10px 20px 24px;
            gap: 4px;
        }

            .nav-menu > li > a {
                padding: 12px 10px;
            }

            .nav-menu .sub-menu {
                position: static;
                opacity: 1;
                visibility: visible;
                transform: none;
                box-shadow: none;
                border-radius: 8px;
                border-top: none;
                background: rgba(255, 255, 255, 0.06);
                margin-top: 4px;
                display: none;
            }

                .nav-menu .sub-menu li a {
                    color: #eee !important;
                }

                    .nav-menu .sub-menu li a:hover {
                        background: rgba(136, 210, 0, 0.15);
                        color: #d4f09b !important;
                        padding-left: 20px;
                    }

            .nav-menu li.mobile-open > .sub-menu {
                display: block;
            }

        .user-dropdown {
            right: 0 !important;
            width: 100%;
            min-width: 0;
            max-width: none;
            position: static;
            box-shadow: none;
            margin-top: 6px;
        }

        .auth-buttons {
            flex-direction: column;
            width: 100%;
        }

        .btn-nav {
            text-align: center;
        }

        }
    </style>
