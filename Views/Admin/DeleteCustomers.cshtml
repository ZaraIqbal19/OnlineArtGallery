@model Art_Gallery.Areas.Identity.Data.Art_GalleryUser

@{
    ViewData["Title"] = "Delete User";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-success" role="alert">
        @TempData["Message"]
    </div>
}

<h1>Delete User</h1>

<h3>Are you sure you want to delete this user?</h3>

<div>
    <hr />

    <dl class="row">
        <dt class="col-sm-2">
            User Name
        </dt>
        <dd class="col-sm-10">
            @Model.UserName
        </dd>
    </dl>

    <dl class="row">
        <dt class="col-sm-2">
            Full Name
        </dt>
        
    </dl>

    <dl class="row">
        <dt class="col-sm-2">
            Email
        </dt>
        <dd class="col-sm-10">
            @Model.Email
        </dd>
    </dl>

    <dl class="row">
        <dt class="col-sm-2">
            Phone Number
        </dt>
        <dd class="col-sm-10">
            @Model.PhoneNumber
        </dd>
    </dl>

    <form asp-action="DeleteLogic">
        <input type="hidden" asp-for="Id" />

        <input type="submit" value="Delete User" class="btn btn-danger" />
        |
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>

