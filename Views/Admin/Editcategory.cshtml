@model Art_Gallery.Models.Category

@{
    ViewData["Title"] = "Edit Category";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
<style>
    /* ---------- GREEN & WHITE THEME · ENHANCED ---------- */
    :root {
        --primary-green: #88d200;
        --dark-green: #6fa800;
        --light-green: #d4f09b;
        --ultra-light-green: #f0fae6;
        --shadow-color: rgba(136, 210, 0, 0.2);
        --card-shadow: 0 20px 60px rgba(136, 210, 0, 0.12);
        --border-radius-lg: 32px;
        --border-radius-md: 24px;
        --border-radius-sm: 20px;
        --error-color: #dc3545;
        --error-bg: #fff5f5;
        --success-color: #28a745;
        --success-bg: #e6f4ea;
    }

    ::-webkit-scrollbar {
        width: 0px;
        background: transparent;
    }

    * {
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

    .create-page-wrapper {
        padding: 20px 0;
        animation: fadeInUp 0.6s ease;
        overflow: hidden;
    }

    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* ===== CARD ===== */
    .card-green-white {
        background: #ffffff;
        border: none;
        border-radius: var(--border-radius-lg);
        box-shadow: var(--card-shadow);
        transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
        position: relative;
        overflow: hidden;
        backdrop-filter: blur(2px);
    }

        .card-green-white::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 6px;
            background: linear-gradient(90deg, var(--primary-green), var(--dark-green), var(--primary-green));
            background-size: 200% 100%;
            animation: shimmerGreen 4s infinite;
            z-index: 2;
        }

    @@keyframes shimmerGreen {
        0% { background-position: -200% 0; }
        100% { background-position: 200% 0; }
    }

    .card-green-white:hover {
        transform: translateY(-6px) scale(1.003);
        box-shadow: 0 28px 70px rgba(136, 210, 0, 0.20);
    }

    .text-green-accent { color: var(--primary-green); }
    .bg-green-soft { background: var(--ultra-light-green); }
    .border-green-light { border-color: var(--light-green) !important; }

    /* ===== BUTTONS ===== */
    .btn-green {
        background: linear-gradient(135deg, var(--primary-green), var(--dark-green));
        border: none;
        color: white;
        padding: 14px 36px;
        border-radius: 60px;
        font-weight: 700;
        letter-spacing: 0.5px;
        transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        box-shadow: 0 8px 30px rgba(136, 210, 0, 0.35);
        position: relative;
        overflow: hidden;
    }

        .btn-green::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%);
            opacity: 0;
            transition: opacity 0.5s;
            transform: scale(0.8);
        }

        .btn-green:hover::after { opacity: 1; transform: scale(1); }

        .btn-green:hover {
            background: linear-gradient(135deg, #7abe00, #5a8f00);
            transform: scale(1.04) translateY(-3px);
            box-shadow: 0 14px 40px rgba(136, 210, 0, 0.50);
            color: #fff;
        }

        .btn-green:active { transform: scale(0.96); }
        .btn-green i { transition: transform 0.3s ease; }
        .btn-green:hover i { transform: rotate(6deg) scale(1.1); }

    .btn-outline-green {
        background: transparent;
        border: 2px solid var(--primary-green);
        color: var(--dark-green);
        padding: 14px 36px;
        border-radius: 60px;
        font-weight: 700;
        letter-spacing: 0.5px;
        transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

        .btn-outline-green:hover {
            background: var(--ultra-light-green);
            transform: scale(1.04) translateY(-3px);
            box-shadow: 0 14px 40px rgba(136, 210, 0, 0.15);
            color: var(--dark-green);
            border-color: var(--dark-green);
        }

        .btn-outline-green i { transition: transform 0.3s ease; }
        .btn-outline-green:hover i { transform: translateX(-4px) scale(1.1); }

    /* ===== FORM INPUTS ===== */
    .form-control-green {
        border: 2px solid #e2e8e0;
        border-radius: var(--border-radius-sm);
        padding: 14px 20px;
        transition: all 0.3s ease;
        background: #fefcfc;
        font-weight: 450;
        font-size: 1rem;
        box-shadow: inset 0 2px 6px rgba(0,0,0,0.02);
    }

        .form-control-green:focus {
            border-color: var(--primary-green);
            box-shadow: 0 0 0 6px rgba(136, 210, 0, 0.12), inset 0 2px 8px rgba(0,0,0,0.02);
            background: #ffffff;
            transform: scale(1.01);
        }

        .form-control-green:not(.is-valid):not(.is-invalid) { border-color: #e2e8e0; }

    .form-label {
        font-weight: 700;
        color: #2d3d24;
        margin-bottom: 8px;
        font-size: 0.95rem;
        letter-spacing: -0.2px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .form-label i {
            color: var(--primary-green);
            width: 20px;
            text-align: center;
            transition: transform 0.3s ease;
        }

        .form-label:hover i { transform: scale(1.2) rotate(-10deg); }

        .form-label .validation-rules {
            font-size: 0.65rem;
            font-weight: 400;
            color: #7a8a7a;
            background: #f0f4f0;
            padding: 2px 10px;
            border-radius: 50px;
        }

    /* ===== VALIDATION STATES ===== */
    .form-control-green.is-valid {
        border-color: var(--success-color);
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' width='22' height='22' viewBox='0 0 24 24' fill='none' stroke='%2328a745' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='20 6 9 17 4 12'%3e%3c/polyline%3e%3c/svg%3e");
        background-repeat: no-repeat;
        background-position: right 16px center;
        background-size: 22px;
        padding-right: 50px;
        animation: validPop 0.3s ease;
    }

    @@keyframes validPop {
        0% { transform: scale(0.98); }
        50% { transform: scale(1.02); }
        100% { transform: scale(1); }
    }

    .form-control-green.is-invalid {
        border-color: var(--error-color);
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' width='22' height='22' viewBox='0 0 24 24' fill='none' stroke='%23dc3545' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'%3e%3ccircle cx='12' cy='12' r='10'%3e%3c/circle%3e%3cline x1='15' y1='9' x2='9' y2='15'%3e%3c/line%3e%3cline x1='9' y1='9' x2='15' y2='15'%3e%3c/line%3e%3c/svg%3e");
        background-repeat: no-repeat;
        background-position: right 16px center;
        background-size: 22px;
        padding-right: 50px;
        animation: invalidShake 0.5s ease;
    }

    @@keyframes invalidShake {
        0%, 100% { transform: translateX(0); }
        10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }
        20%, 40%, 60%, 80% { transform: translateX(5px); }
    }

    .invalid-feedback, .valid-feedback {
        font-weight: 600;
        font-size: 0.85rem;
        margin-top: 8px;
        display: flex;
        align-items: center;
        gap: 8px;
        animation: slideIn 0.3s ease;
    }

    @@keyframes slideIn {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .invalid-feedback { color: var(--error-color); }
    .valid-feedback { color: var(--success-color); }

    /* ===== CHARACTER COUNTER ===== */
    .char-counter {
        font-size: 0.8rem;
        color: #7a5a5a;
        transition: 0.3s ease;
        font-weight: 500;
        padding: 4px 12px;
        border-radius: 20px;
        background: #f8faf8;
    }

        .char-counter.limit-reached {
            color: var(--error-color);
            font-weight: 700;
            background: var(--error-bg);
            animation: counterWiggle 0.5s ease;
        }

    @@keyframes counterWiggle {
        0%, 100% { transform: rotate(0deg); }
        25% { transform: rotate(-3deg); }
        75% { transform: rotate(3deg); }
    }

    /* ===== RIBBON ===== */
    .card-badge-ribbon {
        position: absolute;
        top: 20px;
        right: -2px;
        background: linear-gradient(135deg, var(--primary-green), var(--dark-green));
        color: white;
        padding: 8px 24px 8px 28px;
        border-radius: 40px 0 0 40px;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.5px;
        opacity: 0.9;
        box-shadow: -6px 6px 25px rgba(136, 210, 0, 0.3);
        z-index: 3;
        animation: ribbonPulse 3s ease-in-out infinite;
    }

    @@keyframes ribbonPulse {
        0%, 100% { opacity: 0.9; }
        50% { opacity: 1; transform: scale(1.02); }
    }

    @@keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-12px); }
    }

    .float-animation { animation: float 4s ease-in-out infinite; }

    /* ===== TIPS GRID ===== */
    .tips-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.5rem 1.5rem;
    }

        .tips-grid li {
            transition: all 0.3s ease;
            padding: 4px 0;
            cursor: default;
        }

            .tips-grid li:hover {
                transform: translateX(8px);
                color: var(--dark-green) !important;
            }

            .tips-grid li i { transition: all 0.3s ease; }
            .tips-grid li:hover i { transform: scale(1.3); opacity: 1 !important; }

    /* ===== INPUT GROUP ICON ===== */
    .input-group-icon { position: relative; }

        .input-group-icon .form-control-green { padding-left: 48px; }

        .input-group-icon .input-icon-left {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #a0aec0;
            transition: all 0.3s ease;
            z-index: 3;
            font-size: 1rem;
        }

        .input-group-icon:focus-within .input-icon-left {
            color: var(--primary-green);
            transform: translateY(-50%) scale(1.1);
        }

        .input-group-icon .form-control-green.is-valid ~ .input-icon-left { color: var(--success-color); }
        .input-group-icon .form-control-green.is-invalid ~ .input-icon-left { color: var(--error-color); }

    /* ===== BREADCRUMB ===== */
    .breadcrumb-custom {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.85rem;
        color: #7a8a7a;
        margin-bottom: 20px;
        padding: 8px 16px;
        background: var(--ultra-light-green);
        border-radius: 50px;
        border: 1px solid var(--light-green);
    }

        .breadcrumb-custom i { color: var(--primary-green); }
        .breadcrumb-custom .separator { color: #c0d0c0; }
        .breadcrumb-custom .current { color: var(--dark-green); font-weight: 600; }

    /* ===== STATS BADGE ===== */
    .stats-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 14px;
        background: var(--ultra-light-green);
        border-radius: 50px;
        font-size: 0.75rem;
        color: var(--dark-green);
        border: 1px solid var(--light-green);
    }

        .stats-badge i { font-size: 0.7rem; }

    /* ===== IMAGE UPLOAD ===== */
    .image-drop-zone {
        border: 2px dashed var(--light-green);
        border-radius: var(--border-radius-sm);
        background: var(--ultra-light-green);
        padding: 24px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s ease;
        position: relative;
    }

        .image-drop-zone:hover, .image-drop-zone.dragover {
            border-color: var(--primary-green);
            background: #e8f5e0;
            transform: scale(1.005);
        }

        .image-drop-zone.is-invalid {
            border-color: var(--error-color);
            background: var(--error-bg);
            animation: invalidShake 0.5s ease;
        }

        .image-drop-zone.is-valid {
            border-color: var(--success-color);
            background: var(--success-bg);
        }

        .image-drop-zone .drop-icon {
            font-size: 2.5rem;
            color: var(--primary-green);
            margin-bottom: 10px;
            transition: transform 0.3s ease;
        }

        .image-drop-zone:hover .drop-icon { transform: translateY(-4px) scale(1.1); }

        .image-drop-zone .drop-text { font-weight: 600; color: #2d3d24; margin-bottom: 4px; }
        .image-drop-zone .drop-subtext { font-size: 0.8rem; color: #7a8a7a; }

    #categoryImageInput {
        position: absolute;
        inset: 0;
        opacity: 0;
        cursor: pointer;
        width: 100%;
        height: 100%;
    }

    .image-preview-wrapper {
        display: none;
        position: relative;
        margin-top: 14px;
        animation: fadeInUp 0.4s ease;
    }

        .image-preview-wrapper.show { display: inline-block; }

    .image-preview-box {
        position: relative;
        width: 160px;
        height: 160px;
        border-radius: var(--border-radius-sm);
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(136, 210, 0, 0.2);
        border: 3px solid var(--primary-green);
    }

        .image-preview-box img { width: 100%; height: 100%; object-fit: cover; }

    .image-preview-remove {
        position: absolute;
        top: -10px;
        right: -10px;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: var(--error-color);
        color: white;
        border: 3px solid white;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 0.85rem;
        box-shadow: 0 4px 12px rgba(220, 53, 69, 0.4);
        transition: transform 0.2s ease;
    }

        .image-preview-remove:hover { transform: scale(1.15) rotate(90deg); }

    .image-preview-filename {
        font-size: 0.8rem;
        color: #4a6a5a;
        margin-top: 8px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    /* ===== CURRENT IMAGE BOX (edit only) ===== */
    .current-image-box {
        display: flex;
        align-items: center;
        gap: 16px;
        background: var(--ultra-light-green);
        border: 1px solid var(--light-green);
        border-radius: var(--border-radius-sm);
        padding: 14px 18px;
        margin-bottom: 14px;
    }

        .current-image-box img {
            width: 70px;
            height: 70px;
            border-radius: 16px;
            object-fit: cover;
            border: 3px solid var(--primary-green);
            box-shadow: 0 6px 16px rgba(136, 210, 0, 0.25);
        }

        .current-image-box .current-image-label {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #7a9a8a;
            margin-bottom: 2px;
        }

        .current-image-box .current-image-text { font-weight: 600; color: #2d3d24; font-size: 0.9rem; }

    /* ===== RESPONSIVE ===== */
    @@media (max-width: 576px) {
        .card-green-white { padding: 1.8rem !important; }
        .btn-green { width: 100%; justify-content: center; }
        .btn-outline-green { width: 100%; justify-content: center; }
        .tips-grid { grid-template-columns: 1fr !important; }
        .card-badge-ribbon { font-size: 0.6rem; padding: 6px 16px 6px 20px; top: 15px; }
        .current-image-box { flex-direction: column; text-align: center; }
    }

    @@media (max-width: 768px) {
        .card-green-white { padding: 1.5rem !important; }
        .card-badge-ribbon { font-size: 0.6rem; padding: 6px 16px 6px 20px; }
    }
</style>

<div class="create-page-wrapper">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">

            <!-- CARD -->
            <div class="card card-green-white p-4 p-md-5 position-relative">

                <div class="card-badge-ribbon">
                    <i class="fa-regular fa-pen-to-square me-1"></i> EDITING
                </div>

                <!-- BREADCRUMB -->
                <div class="breadcrumb-custom">
                    <i class="fas fa-home"></i>
                    <span>Dashboard</span>
                    <span class="separator">/</span>
                    <i class="fas fa-folder-open"></i>
                    <span>Categories</span>
                    <span class="separator">/</span>
                    <span class="current"><i class="fas fa-pen me-1"></i>Edit</span>
                </div>

                <!-- HEADER -->
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="bg-green-soft p-3 rounded-4 shadow-sm float-animation">
                        <i class="fa fa-layer-group fa-2x text-green-accent"></i>
                    </div>
                    <div>
                        <h3 class="fw-bold mb-0" style="color: #1d2d1a;">
                            Edit Category
                            <span class="stats-badge ms-2">
                                <i class="fa-regular fa-pen-to-square"></i> Updating
                            </span>
                        </h3>
                        <p class="text-muted small" style="letter-spacing: 0.2px;">
                            <i class="fa-regular fa-circle-check text-green-accent me-1"></i> Update the details of this category
                        </p>
                    </div>
                </div>

                <!-- ========== FORM ========== -->
                <form asp-controller="Admin" asp-action="EditCategorylogic" method="post" id="categoryForm" enctype="multipart/form-data" novalidate>
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <!-- Validation Summary -->
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:none;" id="validationSummary">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        <span></span>
                    </div>

                    <!-- ===== CATEGORY NAME ===== -->
                    <div class="mb-4">
                        <label asp-for="Name" class="form-label">
                            <i class="fa-regular fa-tag"></i> Category Name <span class="text-danger">*</span>
                            <span class="validation-rules">
                                <i class="fa-regular fa-circle-check me-1"></i> 3-50 chars · Letters & spaces only
                            </span>
                        </label>
                        <div class="input-group-icon">
                            <span class="input-icon-left">
                                <i class="fa-regular fa-folder-open"></i>
                            </span>
                            <input asp-for="Name"
                                   type="text"
                                   class="form-control form-control-green"
                                   id="nameInput"
                                   placeholder="Enter category name (e.g., Abstract Art, Modern, Contemporary...)"
                                   maxlength="50"
                                   required
                                   autofocus>
                        </div>
                        <div class="invalid-feedback" id="nameInvalid" style="display: none;">
                            <i class="fa-regular fa-circle-exclamation"></i> <span id="nameInvalidText">Category name is required.</span>
                        </div>
                        <div class="valid-feedback" id="nameValid" style="display: none;">
                            <i class="fa-regular fa-check-circle"></i> Perfect!
                        </div>
                        <span asp-validation-for="Name" class="text-danger small" id="serverError"></span>

                        <!-- Character Counter -->
                        <div class="d-flex justify-content-end mt-2">
                            <span class="char-counter" id="charCounter">
                                <i class="fa-regular fa-keyboard me-1"></i> <span id="charCount">0</span> / 50 characters
                            </span>
                        </div>
                    </div>

                    <!-- ===== CATEGORY IMAGE ===== -->
                    <div class="mb-4">
                        <label class="form-label">
                            <i class="fa-regular fa-image"></i> Category Image
                            <span class="validation-rules">
                                <i class="fa-regular fa-circle-check me-1"></i> JPG, PNG or WEBP · Max 2MB · Optional
                            </span>
                        </label>

                        @if (!string.IsNullOrEmpty(Model.Categoryimage))
                        {
                            <div class="current-image-box">
                                <img src="@Model.Categoryimage" alt="@Model.Name" onerror="this.style.display='none';" />
                                <div>
                                    <div class="current-image-label">Current Image</div>
                                    <div class="current-image-text">Upload a new image below to replace it</div>
                                </div>
                            </div>
                        }

                        <div class="image-drop-zone" id="imageDropZone">
                            <input type="file" name="CategoryImageFile" id="categoryImageInput" accept=".jpg,.jpeg,.png,.webp" />
                            <div class="drop-icon"><i class="fa-regular fa-cloud-arrow-up"></i></div>
                            <div class="drop-text">Click or drag a new image here</div>
                            <div class="drop-subtext">Leave empty to keep the current image · JPG, PNG, WEBP (max 2MB)</div>
                        </div>

                        <div class="invalid-feedback" id="imageInvalid" style="display: none;">
                            <i class="fa-regular fa-circle-exclamation"></i> <span id="imageInvalidText">Please select a valid image.</span>
                        </div>
                        <span asp-validation-for="Categoryimage" class="text-danger small"></span>

                        <div class="image-preview-wrapper" id="imagePreviewWrapper">
                            <div class="image-preview-box">
                                <img id="imagePreviewImg" src="" alt="Preview">
                                <div class="image-preview-remove" id="imageRemoveBtn" title="Remove selected image">
                                    <i class="fa-solid fa-xmark"></i>
                                </div>
                            </div>
                            <div class="image-preview-filename">
                                <i class="fa-regular fa-file-image text-green-accent"></i>
                                <span id="imageFileName"></span>
                            </div>
                        </div>
                    </div>

                    <!-- ===== TIPS SECTION ===== -->
                    <div class="bg-green-soft p-3 rounded-4 mb-4" style="border: 1px solid var(--light-green);">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <i class="fas fa-lightbulb text-green-accent" style="font-size: 1.1rem;"></i>
                            <h5 class="fw-bold mb-0" style="color: var(--dark-green); font-size: 0.95rem;">Pro Tips for Editing Categories</h5>
                            <span class="ms-auto stats-badge">
                                <i class="fa-regular fa-lightbulb"></i> 4 Tips
                            </span>
                        </div>
                        <ul class="list-unstyled mb-0 tips-grid">
                            <li class="d-flex align-items-center gap-2" style="font-size: 0.85rem; color: #4a5568;">
                                <i class="fas fa-circle text-green-accent" style="font-size: 0.5rem;"></i>
                                Use clear, descriptive names for easy navigation
                            </li>
                            <li class="d-flex align-items-center gap-2" style="font-size: 0.85rem; color: #4a5568;">
                                <i class="fas fa-circle text-green-accent" style="font-size: 0.5rem;"></i>
                                Keep names between 3-50 characters
                            </li>
                            <li class="d-flex align-items-center gap-2" style="font-size: 0.85rem; color: #4a5568;">
                                <i class="fas fa-circle text-green-accent" style="font-size: 0.5rem;"></i>
                                Use only letters and spaces (no numbers or symbols)
                            </li>
                            <li class="d-flex align-items-center gap-2" style="font-size: 0.85rem; color: #4a5568;">
                                <i class="fas fa-circle text-green-accent" style="font-size: 0.5rem;"></i>
                                Only upload a new image if you want to replace the current one
                            </li>
                        </ul>
                    </div>

                    <!-- SUBMIT -->
                    <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                        <button class="btn btn-green btn-animate px-5 py-3" type="submit" id="submitBtn">
                            <i class="fa fa-check me-2"></i> <span id="submitText">Update Category</span>
                        </button>
                        <a asp-action="Index" class="btn btn-outline-green px-5 py-3">
                            <i class="fa fa-arrow-left me-2"></i> Back to List
                        </a>
                    </div>

                </form>
                <!-- ========== END FORM ========== -->

            </div>
            <!-- end card -->

        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

<script>
    (function() {
        'use strict';

        const form = document.getElementById('categoryForm');
        const nameInput = document.getElementById('nameInput');
        const charCounter = document.getElementById('charCounter');
        const charCount = document.getElementById('charCount');
        const nameInvalid = document.getElementById('nameInvalid');
        const nameInvalidText = document.getElementById('nameInvalidText');
        const nameValid = document.getElementById('nameValid');
        const serverError = document.getElementById('serverError');
        const submitBtn = document.getElementById('submitBtn');
        const maxLength = 50;
        const minLength = 3;

        // ===== IMAGE UPLOAD ELEMENTS =====
        const imageDropZone = document.getElementById('imageDropZone');
        const categoryImageInput = document.getElementById('categoryImageInput');
        const imageInvalid = document.getElementById('imageInvalid');
        const imageInvalidText = document.getElementById('imageInvalidText');
        const imagePreviewWrapper = document.getElementById('imagePreviewWrapper');
        const imagePreviewImg = document.getElementById('imagePreviewImg');
        const imageFileName = document.getElementById('imageFileName');
        const imageRemoveBtn = document.getElementById('imageRemoveBtn');

        const allowedImageTypes = ['image/jpeg', 'image/png', 'image/webp'];
        const maxImageSize = 2 * 1024 * 1024; // 2MB

        // ===== INITIALIZE CHAR COUNT FOR PRE-FILLED NAME =====
        if (nameInput.value && nameInput.value.length > 0) {
            charCount.textContent = nameInput.value.length;
        }

        // ===== NAME VALIDATION =====
        function validateCategoryName(value) {
            if (!value || value.trim().length === 0) {
                return { valid: false, message: 'Category name is required.' };
            }
            if (value.trim().length < minLength) {
                return { valid: false, message: 'Category name must be at least ' + minLength + ' characters.' };
            }
            if (value.trim().length > maxLength) {
                return { valid: false, message: 'Maximum ' + maxLength + ' characters allowed.' };
            }
            const regex = /^[a-zA-Z\s]+$/;
            if (!regex.test(value.trim())) {
                return { valid: false, message: 'Only letters and spaces are allowed. No numbers or special characters.' };
            }
            return { valid: true, message: '' };
        }

        // ===== IMAGE VALIDATION (optional on edit) =====
        function validateImageFile(file) {
            if (!file) {
                return { valid: true, message: '' };
            }
            if (!allowedImageTypes.includes(file.type)) {
                return { valid: false, message: 'Only JPG, PNG, or WEBP images are allowed.' };
            }
            if (file.size > maxImageSize) {
                return { valid: false, message: 'Image size must not exceed 2MB.' };
            }
            return { valid: true, message: '' };
        }

        function showImagePreview(file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                imagePreviewImg.src = e.target.result;
                imagePreviewWrapper.classList.add('show');
            };
            reader.readAsDataURL(file);
            imageFileName.textContent = file.name;
        }

        function clearImagePreview() {
            imagePreviewImg.src = '';
            imagePreviewWrapper.classList.remove('show');
            imageFileName.textContent = '';
            categoryImageInput.value = '';
            imageDropZone.classList.remove('is-valid', 'is-invalid');
        }

        // ===== FILE SELECTED =====
        categoryImageInput.addEventListener('change', function() {
            const file = this.files[0];
            const result = validateImageFile(file);

            if (!file) {
                imageDropZone.classList.remove('is-valid', 'is-invalid');
                imageInvalid.style.display = 'none';
                imagePreviewWrapper.classList.remove('show');
                return;
            }

            if (!result.valid) {
                imageDropZone.classList.add('is-invalid');
                imageDropZone.classList.remove('is-valid');
                imageInvalid.style.display = 'flex';
                imageInvalidText.textContent = result.message;
                imagePreviewWrapper.classList.remove('show');
                return;
            }

            imageDropZone.classList.remove('is-invalid');
            imageDropZone.classList.add('is-valid');
            imageInvalid.style.display = 'none';
            showImagePreview(file);
        });

        // ===== REMOVE IMAGE =====
        imageRemoveBtn.addEventListener('click', function(e) {
            e.stopPropagation();
            clearImagePreview();
        });

        // ===== DRAG & DROP =====
        ['dragenter', 'dragover'].forEach(evt => {
            imageDropZone.addEventListener(evt, function(e) {
                e.preventDefault();
                e.stopPropagation();
                imageDropZone.classList.add('dragover');
            });
        });

        ['dragleave', 'drop'].forEach(evt => {
            imageDropZone.addEventListener(evt, function(e) {
                e.preventDefault();
                e.stopPropagation();
                imageDropZone.classList.remove('dragover');
            });
        });

        imageDropZone.addEventListener('drop', function(e) {
            const files = e.dataTransfer.files;
            if (files.length > 0) {
                const dt = new DataTransfer();
                dt.items.add(files[0]);
                categoryImageInput.files = dt.files;
                categoryImageInput.dispatchEvent(new Event('change'));
            }
        });

        // ===== CLEAR VALIDATION STATE =====
        function clearValidation() {
            nameInput.classList.remove('is-valid', 'is-invalid');
            nameInvalid.style.display = 'none';
            nameValid.style.display = 'none';
            if (serverError) serverError.textContent = '';
        }

        // ===== CHARACTER COUNTER =====
        nameInput.addEventListener('input', function() {
            const length = this.value.length;
            charCount.textContent = length;

            const result = validateCategoryName(this.value);

            if (!result.valid) {
                charCounter.classList.add('limit-reached');
                this.classList.add('is-invalid');
                this.classList.remove('is-valid');
                nameInvalid.style.display = 'flex';
                nameValid.style.display = 'none';
                nameInvalidText.textContent = result.message;
            } else if (length > 0) {
                charCounter.classList.remove('limit-reached');
                this.classList.remove('is-invalid');
                this.classList.add('is-valid');
                nameInvalid.style.display = 'none';
                nameValid.style.display = 'flex';
            } else {
                charCounter.classList.remove('limit-reached');
                this.classList.remove('is-valid', 'is-invalid');
                nameInvalid.style.display = 'none';
                nameValid.style.display = 'none';
            }

            if (serverError) serverError.textContent = '';
            const summary = document.getElementById('validationSummary');
            if (summary) summary.style.display = 'none';
        });

        // ===== VALIDATION ON BLUR =====
        nameInput.addEventListener('blur', function() {
            const result = validateCategoryName(this.value);

            if (!result.valid) {
                this.classList.add('is-invalid');
                this.classList.remove('is-valid');
                nameInvalid.style.display = 'flex';
                nameValid.style.display = 'none';
                nameInvalidText.textContent = result.message;
            } else if (this.value.trim().length > 0) {
                this.classList.remove('is-invalid');
                this.classList.add('is-valid');
                nameInvalid.style.display = 'none';
                nameValid.style.display = 'flex';
            }
        });

        // ===== FOCUS EVENT =====
        nameInput.addEventListener('focus', function() {
            if (this.value.trim() === '') {
                this.classList.remove('is-invalid');
                nameInvalid.style.display = 'none';
            }
        });

        // ===== FORM SUBMIT =====
        form.addEventListener('submit', function(event) {
            clearValidation();
            let isValid = true;

            // Name validation
            const nameVal = nameInput.value.trim();
            const nameResult = validateCategoryName(nameVal);

            if (!nameResult.valid) {
                nameInput.classList.add('is-invalid');
                nameInput.classList.remove('is-valid');
                nameInvalid.style.display = 'flex';
                nameValid.style.display = 'none';
                nameInvalidText.textContent = nameResult.message;
                isValid = false;
            } else {
                nameInput.classList.remove('is-invalid');
                nameInput.classList.add('is-valid');
                nameInvalid.style.display = 'none';
                nameValid.style.display = 'flex';
            }

            // Image validation (optional on edit)
            const imageResult = validateImageFile(categoryImageInput.files[0]);
            if (!imageResult.valid) {
                imageDropZone.classList.add('is-invalid');
                imageDropZone.classList.remove('is-valid');
                imageInvalid.style.display = 'flex';
                imageInvalidText.textContent = imageResult.message;
                isValid = false;
            } else if (categoryImageInput.files[0]) {
                imageDropZone.classList.remove('is-invalid');
                imageDropZone.classList.add('is-valid');
                imageInvalid.style.display = 'none';
            }

            if (!isValid) {
                event.preventDefault();
                event.stopPropagation();
                if (!nameResult.valid) {
                    nameInput.focus();
                }
                return;
            }

            submitBtn.innerHTML = '<i class="fa fa-spinner fa-spin me-2"></i> Updating...';
            submitBtn.disabled = true;
        });

        // ===== SHOW SERVER-SIDE ERRORS =====
        @if (!ViewData.ModelState.IsValid)
        {
                    <text>
                        var errors = @Html.Raw(Json.Serialize(ViewData.ModelState.Values.SelectMany(v => v.Errors).Select(e => e.ErrorMessage)));
                        if (errors && errors.length > 0) {
                            var summary = document.getElementById('validationSummary');
                            if (summary) {
                                summary.style.display = 'block';
                                var span = summary.querySelector('span');
                                if (span) {
                                    span.textContent = errors.join(' | ');
                                }
                            }

                            var nameError = '@Html.Raw(ViewData.ModelState["Name"]?.Errors.FirstOrDefault()?.ErrorMessage ?? "")';
                            if (nameError) {
                                nameInput.classList.add('is-invalid');
                                nameInput.classList.remove('is-valid');
                                nameInvalid.style.display = 'flex';
                                nameValid.style.display = 'none';
                                nameInvalidText.textContent = nameError;
                                if (serverError) serverError.textContent = nameError;
                            }

                            var imageError = '@Html.Raw(ViewData.ModelState["Categoryimage"]?.Errors.FirstOrDefault()?.ErrorMessage ?? "")';
                            if (imageError) {
                                imageDropZone.classList.add('is-invalid');
                                imageDropZone.classList.remove('is-valid');
                                imageInvalid.style.display = 'flex';
                                imageInvalidText.textContent = imageError;
                            }
                        }
                    </text>
        }

    })();
</script>