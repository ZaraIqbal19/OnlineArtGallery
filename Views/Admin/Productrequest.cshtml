@model IEnumerable<Art_Gallery.Models.Product>
@{
    ViewData["Title"] = "Product Requests";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />

<style>
    /* ===== everything scoped under .requests-page so it can't leak into the admin shell ===== */
    .requests-page {
        font-family: 'Inter', 'Segoe UI', Roboto, system-ui, sans-serif;
        padding: 1.5rem 0;
    }

        .requests-page *,
        .requests-page *::before,
        .requests-page *::after {
            box-sizing: border-box;
        }

        .requests-page .container-cust {
            max-width: 1400px;
            margin: 0 auto;
        }

        /* ----- alerts ----- */
        .requests-page .alert-cust {
            border: none;
            border-radius: 16px;
            padding: 14px 22px;
            font-weight: 600;
            font-size: 0.9rem;
            margin-bottom: 1.2rem;
            display: flex;
            align-items: center;
            gap: 10px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.06);
            animation: fadeSlideReq 0.4s ease;
        }

        .requests-page .alert-success-cust {
            background: #f0fae6;
            color: #4c7800;
            border-left: 6px solid #88d200;
        }

        .requests-page .alert-danger-cust {
            background: #fff5f5;
            color: #a51b1b;
            border-left: 6px solid #dc3545;
        }

        .requests-page .alert-warning-cust {
            background: #fff8e6;
            color: #a5720b;
            border-left: 6px solid #f0a500;
        }

        /* ----- main card / glass effect ----- */
        .requests-page .admin-card {
            background: rgba(255, 255, 255, 0.97);
            border-radius: 2rem;
            padding: 2rem 1.8rem 1.8rem 1.8rem;
            box-shadow: 0 20px 45px -16px rgba(111, 168, 0, 0.22), 0 4px 18px rgba(136, 210, 0, 0.06);
            border: 1px solid rgba(136, 210, 0, 0.12);
            position: relative;
            overflow: hidden;
        }

            .requests-page .admin-card::before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 6px;
                background: linear-gradient(90deg, #d4f09b, #88d200, #6fa800);
            }

        /* ----- header ----- */
        .requests-page .header-section {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            margin-bottom: 1.8rem;
            padding-bottom: 0.75rem;
            border-bottom: 2px solid rgba(136, 210, 0, 0.18);
        }

        .requests-page .brand-head {
            display: flex;
            align-items: center;
            gap: 0.9rem;
        }

        .requests-page .brand-icon {
            background: #88d200;
            width: 48px;
            height: 48px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.5rem;
            box-shadow: 0 8px 18px rgba(136, 210, 0, 0.35);
            transition: all 0.25s;
            flex-shrink: 0;
        }

            .requests-page .brand-icon:hover {
                transform: rotate(-6deg) scale(1.04);
                background: #6fa800;
            }

        .requests-page .heading-green {
            font-weight: 700;
            font-size: 1.85rem;
            letter-spacing: -0.5px;
            color: #1a1a1a;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            flex-wrap: wrap;
        }

            .requests-page .heading-green span {
                background: #88d200;
                color: white;
                font-size: 0.85rem;
                font-weight: 600;
                padding: 0.2rem 1rem;
                border-radius: 60px;
                letter-spacing: 0.3px;
            }

        /* ----- stat cards ----- */
        .requests-page .stats-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 14px;
            margin-bottom: 1.4rem;
        }

        .requests-page .stat-card {
            background: #f0fae6;
            border: 1px solid #d4f09b;
            border-radius: 16px;
            padding: 14px 18px;
            display: flex;
            align-items: center;
            gap: 14px;
            transition: all 0.25s;
        }

            .requests-page .stat-card:hover {
                background: #d4f09b;
                transform: translateY(-3px);
                box-shadow: 0 10px 22px rgba(136, 210, 0, 0.22);
            }

        .requests-page .stat-icon {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: #88d200;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.05rem;
            flex-shrink: 0;
            box-shadow: 0 6px 14px rgba(136, 210, 0, 0.3);
        }

        .requests-page .stat-card.pending .stat-icon {
            background: #f0a500;
            box-shadow: 0 6px 14px rgba(240, 165, 0, 0.3);
        }

        .requests-page .stat-card.approved .stat-icon {
            background: #4c7800;
        }

        .requests-page .stat-card.rejected .stat-icon {
            background: #dc3545;
            box-shadow: 0 6px 14px rgba(220, 53, 69, 0.3);
        }

        .requests-page .stat-value {
            font-weight: 700;
            font-size: 1.25rem;
            color: #1a1a1a;
            line-height: 1.1;
        }

        .requests-page .stat-label {
            font-size: 0.76rem;
            color: #5c7a2e;
            font-weight: 600;
            margin-top: 2px;
        }

        /* ----- toolbar / search ----- */
        .requests-page .toolbar-row {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 1.1rem;
        }

        .requests-page .search-box {
            display: flex;
            align-items: center;
            gap: 10px;
            background: #f0fae6;
            border: 1.5px solid #d4f09b;
            border-radius: 60px;
            padding: 9px 20px;
            flex: 1;
            max-width: 340px;
            transition: all 0.2s;
        }

            .requests-page .search-box:focus-within {
                border-color: #88d200;
                background: white;
                box-shadow: 0 6px 16px rgba(136, 210, 0, 0.18);
            }

            .requests-page .search-box i {
                color: #6fa800;
            }

            .requests-page .search-box input {
                border: none;
                outline: none;
                background: transparent;
                font-size: 0.88rem;
                width: 100%;
                color: #1a1a1a;
            }

        .requests-page .result-count {
            font-size: 0.8rem;
            color: #5c7a2e;
            font-weight: 600;
            white-space: nowrap;
        }

        /* ----- table ----- */
        .requests-page .table-responsive-cust {
            border-radius: 1.6rem;
            overflow-x: auto;
            overflow-y: auto;
            max-height: 560px;
            padding-bottom: 6px;
            scrollbar-width: thin;
            scrollbar-color: #88d200 #eef6de;
        }

            .requests-page .table-responsive-cust::-webkit-scrollbar {
                height: 10px;
                width: 10px;
            }

            .requests-page .table-responsive-cust::-webkit-scrollbar-track {
                background: #eef6de;
                border-radius: 20px;
            }

            .requests-page .table-responsive-cust::-webkit-scrollbar-thumb {
                background: linear-gradient(90deg, #88d200, #6fa800);
                border-radius: 20px;
                border: 2px solid #eef6de;
            }

        .requests-page .table-green-white {
            border-collapse: separate;
            border-spacing: 0 10px;
            width: 100%;
            min-width: 900px;
            margin-bottom: 0;
        }

            .requests-page .table-green-white thead th {
                background: #88d200;
                color: white;
                font-weight: 600;
                font-size: 0.76rem;
                text-transform: uppercase;
                letter-spacing: 0.6px;
                padding: 15px 18px;
                border: none;
                position: sticky;
                top: 0;
                z-index: 2;
                text-align: center;
                white-space: nowrap;
            }

                .requests-page .table-green-white thead th:first-child {
                    border-radius: 20px 0 0 20px;
                    padding-left: 26px;
                }

                .requests-page .table-green-white thead th:last-child {
                    border-radius: 0 20px 20px 0;
                    padding-right: 26px;
                }

        .requests-page .empty-state-row td {
            text-align: center;
            padding: 40px 20px !important;
            color: #8a9a6e;
            font-weight: 500;
            font-size: 0.95rem;
            border-radius: 20px !important;
        }

        .requests-page .empty-state-row i {
            display: block;
            font-size: 2rem;
            color: #d4f09b;
            margin-bottom: 10px;
        }

        .requests-page .table-green-white tbody tr {
            background: white;
            border-radius: 18px;
            box-shadow: 0 4px 14px rgba(111, 168, 0, 0.05);
            transition: all 0.25s cubic-bezier(0.2, 0, 0, 1);
            border: 1px solid rgba(136, 210, 0, 0.06);
            opacity: 0;
            animation: fadeSlideReq 0.45s forwards;
            animation-delay: calc(0.05s * var(--i, 1));
        }

    @@keyframes fadeSlideReq {
        0% {
            opacity: 0;
            transform: translateY(16px) scale(0.98);
        }

        100% {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .requests-page .table-green-white tbody tr:hover {
        background: #fbffef;
        border-color: #d4f09b;
        transform: scale(1.012) translateY(-3px);
        box-shadow: 0 16px 32px rgba(111, 168, 0, 0.18);
        z-index: 1;
        position: relative;
    }

    .requests-page .table-green-white tbody td {
        padding: 16px 18px;
        vertical-align: middle;
        border: none;
        background: transparent;
        font-size: 0.9rem;
        text-align: center;
    }

        .requests-page .table-green-white tbody td:first-child {
            padding-left: 24px;
            border-radius: 18px 0 0 18px;
            border-left: 4px solid transparent;
            transition: border-color 0.25s ease;
        }

    .requests-page .table-green-white tbody tr:hover td:first-child {
        border-left-color: #88d200;
    }

    .requests-page .table-green-white tbody td:last-child {
        padding-right: 26px;
        border-radius: 0 18px 18px 0;
    }

    .requests-page .name-cell {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    .requests-page .prod-thumb {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        object-fit: cover;
        flex-shrink: 0;
        box-shadow: 0 4px 10px rgba(136, 210, 0, 0.25);
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .requests-page .table-green-white tbody tr:hover .prod-thumb {
        transform: scale(1.12) rotate(-2deg);
        box-shadow: 0 8px 20px rgba(136, 210, 0, 0.4);
    }

    .requests-page .prod-thumb-placeholder {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        background: linear-gradient(135deg, #88d200, #6fa800);
        color: white;
        font-weight: 700;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        box-shadow: 0 4px 10px rgba(136, 210, 0, 0.3);
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .requests-page .table-green-white tbody tr:hover .prod-thumb-placeholder {
        transform: scale(1.12) rotate(-2deg);
        box-shadow: 0 8px 20px rgba(136, 210, 0, 0.4);
    }

    .requests-page .prod-name {
        font-weight: 700;
        color: #1a1a1a;
        white-space: nowrap;
        transition: color 0.2s ease;
    }

    .requests-page .table-green-white tbody tr:hover .prod-name {
        color: #6fa800;
    }

    .requests-page .prod-desc {
        font-size: 0.8rem;
        color: #8a9a6e;
        max-width: 220px;
        white-space: normal;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-align: left;
        margin: 0 auto;
    }

    /* ----- status badges ----- */
    .requests-page .badge-status {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border-radius: 60px;
        font-size: 0.74rem;
        font-weight: 700;
        letter-spacing: 0.3px;
        text-transform: capitalize;
        white-space: nowrap;
    }

        .requests-page .badge-status i {
            font-size: 0.5rem;
        }

        .requests-page .badge-status.status-active {
            background: #f0fae6;
            color: #4c7800;
            border: 1px solid #88d200;
        }

        .requests-page .badge-status.status-inactive {
            background: #fff5f5;
            color: #a51b1b;
            border: 1px solid #f0c8c8;
        }

        .requests-page .badge-status.status-pending {
            background: #fff8e6;
            color: #a5720b;
            border: 1px solid #f0dca8;
        }

    .requests-page .badge-status {
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .requests-page .table-green-white tbody tr:hover .badge-status {
        transform: translateY(-2px);
        box-shadow: 0 6px 14px rgba(0, 0, 0, 0.08);
    }

    .requests-page .prod-desc {
        transition: color 0.2s ease;
    }

    .requests-page .table-green-white tbody tr:hover .prod-desc {
        color: #6c8a4a;
    }

    /* action buttons */
    .requests-page .actions-wrap {
        display: flex;
        flex-wrap: nowrap;
        align-items: center;
        gap: 8px;
        justify-content: center;
    }

    .requests-page .btn-action {
        border-radius: 60px;
        padding: 8px 15px;
        font-weight: 600;
        font-size: 0.72rem;
        letter-spacing: 0.25px;
        transition: all 0.25s cubic-bezier(0.2, 0, 0, 1);
        border: 1px solid transparent;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        text-decoration: none;
        line-height: 1;
        cursor: pointer;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .requests-page .btn-view {
        background: white;
        color: #495057;
        border: 1.5px solid #dee2e6;
    }

        .requests-page .btn-view:hover {
            background: #495057;
            color: white;
            border-color: #495057;
            transform: translateY(-3px) scale(1.04);
            box-shadow: 0 12px 20px rgba(73, 80, 87, 0.2);
        }

    .requests-page .btn-accept {
        background: white;
        color: #6fa800;
        border: 1.5px solid #88d200;
    }

        .requests-page .btn-accept:hover {
            background: #88d200;
            color: white;
            transform: translateY(-3px) scale(1.04);
            box-shadow: 0 12px 20px rgba(136, 210, 0, 0.22);
        }

    .requests-page .btn-reject {
        background: transparent;
        color: #a5720b;
        border: 1.5px solid #f0dca8;
    }

        .requests-page .btn-reject:hover {
            background: #f0a500;
            color: white;
            border-color: #f0a500;
            transform: translateY(-3px) scale(1.04);
            box-shadow: 0 12px 24px rgba(240, 165, 0, 0.25);
        }

    .requests-page .btn-delete {
        background: transparent;
        color: #a51b1b;
        border: 1.5px solid #f0c8c8;
    }

        .requests-page .btn-delete:hover {
            background: #dc3545;
            color: white;
            border-color: #dc3545;
            transform: translateY(-3px) scale(1.04);
            box-shadow: 0 12px 24px rgba(220, 53, 69, 0.25);
        }

    /* footer */
    .requests-page .table-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 1.6rem;
        padding-top: 1rem;
        border-top: 1px solid rgba(136, 210, 0, 0.12);
        color: #6c757d;
        font-size: 0.84rem;
        flex-wrap: wrap;
        gap: 10px;
    }

        .requests-page .table-footer i {
            color: #88d200;
            margin: 0 4px;
        }

        .requests-page .table-footer .pill {
            background: #f0fae6;
            padding: 0.2rem 1.2rem;
            border-radius: 60px;
            color: #2d2d2d;
            font-weight: 500;
            transition: 0.15s;
        }

            .requests-page .table-footer .pill:hover {
                background: #88d200;
                color: white;
            }

    /* ===== ACTION CONFIRM MODAL (shared by accept / reject / delete) ===== */
    .requests-page .action-modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(8px);
        z-index: 10000;
        display: none;
        align-items: center;
        justify-content: center;
        animation: fadeInOverlayReq 0.3s ease;
    }

    @@keyframes fadeInOverlayReq {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    .requests-page .action-modal {
        background: #ffffff;
        border-radius: 24px;
        padding: 2.5rem;
        max-width: 440px;
        width: 90%;
        position: relative;
        animation: modalSlideUpReq 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 30px 80px rgba(0, 0, 0, 0.3);
        text-align: center;
    }

    @@keyframes modalSlideUpReq {
        from {
            transform: scale(0.8) translateY(40px);
            opacity: 0;
        }

        to {
            transform: scale(1) translateY(0);
            opacity: 1;
        }
    }

    .requests-page .action-modal .modal-icon {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        font-size: 2.5rem;
        animation: pulseIconReq 1.5s ease-in-out infinite;
    }

    @@keyframes pulseIconReq {
        0%, 100% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.05);
        }
    }

    .requests-page .action-modal.mode-accept .modal-icon {
        background: linear-gradient(135deg, #f0fae6, #d4f09b);
        color: #6fa800;
    }

    .requests-page .action-modal.mode-reject .modal-icon {
        background: linear-gradient(135deg, #fff8e6, #ffe8b8);
        color: #f0a500;
    }

    .requests-page .action-modal.mode-delete .modal-icon {
        background: linear-gradient(135deg, #fff5f5, #ffe8e8);
        color: #dc3545;
    }

    .requests-page .action-modal h3 {
        color: #1a1a2e;
        font-weight: 700;
        margin-bottom: 0.5rem;
        font-size: 1.5rem;
    }

    .requests-page .action-modal p {
        color: #6c757d;
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: 1.5rem;
    }

    .requests-page .action-modal .name-highlight {
        font-weight: 700;
        padding: 2px 12px;
        border-radius: 8px;
        display: inline-block;
    }

    .requests-page .action-modal.mode-accept .name-highlight {
        color: #4c7800;
        background: #f0fae6;
    }

    .requests-page .action-modal.mode-reject .name-highlight {
        color: #a5720b;
        background: #fff8e6;
    }

    .requests-page .action-modal.mode-delete .name-highlight {
        color: #dc3545;
        background: #fff5f5;
    }

    .requests-page .action-modal .modal-actions {
        display: flex;
        gap: 12px;
        justify-content: center;
    }

    .requests-page .action-modal .btn-cancel {
        background: #f1f3f5;
        color: #495057;
        border: none;
        border-radius: 50px;
        padding: 0.7rem 2rem;
        font-weight: 600;
        transition: all 0.3s ease;
        cursor: pointer;
        flex: 1;
    }

        .requests-page .action-modal .btn-cancel:hover {
            background: #e9ecef;
            transform: scale(1.02);
        }

    .requests-page .action-modal .btn-confirm {
        color: #fff;
        border: none;
        border-radius: 50px;
        padding: 0.7rem 2rem;
        font-weight: 600;
        transition: all 0.3s cubic-bezier(0.2, 0.9, 0.4, 1);
        cursor: pointer;
        flex: 1;
    }

    .requests-page .action-modal.mode-accept .btn-confirm {
        background: linear-gradient(135deg, #88d200, #6fa800);
        box-shadow: 0 4px 15px rgba(136, 210, 0, 0.3);
    }

        .requests-page .action-modal.mode-accept .btn-confirm:hover {
            transform: scale(1.02) translateY(-2px);
            box-shadow: 0 8px 25px rgba(136, 210, 0, 0.4);
        }

    .requests-page .action-modal.mode-reject .btn-confirm {
        background: linear-gradient(135deg, #f0a500, #cf8c00);
        box-shadow: 0 4px 15px rgba(240, 165, 0, 0.3);
    }

        .requests-page .action-modal.mode-reject .btn-confirm:hover {
            transform: scale(1.02) translateY(-2px);
            box-shadow: 0 8px 25px rgba(240, 165, 0, 0.4);
        }

    .requests-page .action-modal.mode-delete .btn-confirm {
        background: linear-gradient(135deg, #dc3545, #b02a37);
        box-shadow: 0 4px 15px rgba(220, 53, 69, 0.3);
    }

        .requests-page .action-modal.mode-delete .btn-confirm:hover {
            transform: scale(1.02) translateY(-2px);
            box-shadow: 0 8px 25px rgba(220, 53, 69, 0.4);
        }

    /* ===== SUCCESS TOAST ===== */
    .requests-page .toast-container-custom {
        position: fixed;
        top: 30px;
        right: 30px;
        z-index: 9999;
        min-width: 320px;
        max-width: 450px;
        pointer-events: none;
    }

    .requests-page .toast-success {
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(10px);
        border-left: 8px solid #88d200;
        border-radius: 20px;
        box-shadow: 0 20px 60px -12px rgba(0, 0, 0, 0.25), 0 4px 20px rgba(136, 210, 0, 0.12);
        padding: 20px 28px;
        color: #1a1a2e;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 16px;
        opacity: 1;
        pointer-events: none;
        animation: slideInRightReq 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

        .requests-page .toast-success.tone-reject {
            border-left-color: #f0a500;
        }

        .requests-page .toast-success.tone-delete {
            border-left-color: #dc3545;
        }

    @@keyframes slideInRightReq {
        from {
            transform: translateX(120%) scale(0.9);
            opacity: 0;
        }

        to {
            transform: translateX(0) scale(1);
            opacity: 1;
        }
    }

    .requests-page .toast-success i {
        font-size: 2rem;
        color: #88d200;
        background: linear-gradient(135deg, #f0fae6, #d4f09b);
        padding: 12px;
        border-radius: 50%;
        box-shadow: 0 2px 10px rgba(136, 210, 0, 0.15);
        animation: checkBounceReq 0.6s ease;
    }

    .requests-page .toast-success.tone-reject i {
        color: #f0a500;
        background: linear-gradient(135deg, #fff8e6, #ffe8b8);
    }

    .requests-page .toast-success.tone-delete i {
        color: #dc3545;
        background: linear-gradient(135deg, #fff5f5, #ffe0e0);
    }

    @@keyframes checkBounceReq {
        0% {
            transform: scale(0);
        }

        50% {
            transform: scale(1.2);
        }

        70% {
            transform: scale(0.9);
        }

        100% {
            transform: scale(1);
        }
    }

    .requests-page .toast-success .toast-content {
        flex: 1;
    }

    .requests-page .toast-success .toast-title {
        font-weight: 700;
        color: #1a1a2e;
        font-size: 1rem;
    }

    .requests-page .toast-success .toast-message {
        color: #6c757d;
        font-size: 0.9rem;
        margin-top: 2px;
    }

    .requests-page .toast-success.hide {
        animation: slideOutRightReq 0.5s cubic-bezier(0.2, 0.9, 0.4, 1) forwards;
    }

    @@keyframes slideOutRightReq {
        from {
            transform: translateX(0) scale(1);
            opacity: 1;
        }

        to {
            transform: translateX(120%) scale(0.9);
            opacity: 0;
        }
    }

    .requests-page .fade-out {
        animation: fadeOutReq 0.5s cubic-bezier(0.2, 0.9, 0.4, 1) forwards;
    }

    @@keyframes fadeOutReq {
        0% {
            opacity: 1;
            transform: scale(1) translateY(0);
        }

        100% {
            opacity: 0;
            transform: scale(0.8) translateY(-20px);
        }
    }

    /* responsive */
    @@media (max-width: 768px) {
        .requests-page .admin-card {
            padding: 1.2rem;
        }

        .requests-page .heading-green {
            font-size: 1.45rem;
        }

        .requests-page .brand-icon {
            width: 40px;
            height: 40px;
            font-size: 1.25rem;
        }

        .requests-page .table-green-white thead th,
        .requests-page .table-green-white tbody td {
            padding: 12px 10px;
            font-size: 0.82rem;
        }

        .requests-page .btn-action {
            padding: 6px 12px;
            font-size: 0.68rem;
        }

        .requests-page .actions-wrap {
            gap: 4px;
        }

        .requests-page .toast-container-custom {
            top: 20px;
            right: 20px;
            left: 20px;
            min-width: unset;
            max-width: unset;
        }

        .requests-page .action-modal {
            padding: 2rem 1.5rem;
        }

            .requests-page .action-modal .modal-actions {
                flex-direction: column;
            }

        .requests-page .toolbar-row {
            flex-direction: column;
            align-items: stretch;
        }

        .requests-page .search-box {
            max-width: unset;
        }
    }
</style>

<div class="requests-page">
    <div class="container-cust">

        @if (TempData["Message"] != null)
        {
            <div class="alert-cust alert-success-cust">
                <i class="fas fa-check-circle"></i> @TempData["Message"]
            </div>
        }
        @if (TempData["Warningmessage"] != null)
        {
            <div class="alert-cust alert-warning-cust">
                <i class="fas fa-exclamation-triangle"></i> @TempData["Warningmessage"]
            </div>
        }
        @if (TempData["Errormessage"] != null)
        {
            <div class="alert-cust alert-danger-cust">
                <i class="fas fa-exclamation-circle"></i> @TempData["Errormessage"]
            </div>
        }

        <div class="admin-card">

            <!-- header -->
            <div class="header-section">
                <div class="brand-head">
                    <div class="brand-icon">
                        <i class="fas fa-clipboard-list"></i>
                    </div>
                    <h1 class="heading-green">
                        Product Requests
                        <span>@Model.Count()</span>
                    </h1>
                </div>
            </div>

            <!-- stat cards -->
            <div class="stats-row">
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-inbox"></i></div>
                    <div>
                        <div class="stat-value">@Model.Count()</div>
                        <div class="stat-label">Total Requests</div>
                    </div>
                </div>
                <div class="stat-card pending">
                    <div class="stat-icon"><i class="fas fa-hourglass-half"></i></div>
                    <div>
                        <div class="stat-value">@Model.Count(p => p.Status != "Available" && p.Status != "Rejected")</div>
                        <div class="stat-label">Pending</div>
                    </div>
                </div>
                <div class="stat-card approved">
                    <div class="stat-icon"><i class="fas fa-check"></i></div>
                    <div>
                        <div class="stat-value">@Model.Count(p => p.Status == "Available")</div>
                        <div class="stat-label">Approved</div>
                    </div>
                </div>
                <div class="stat-card rejected">
                    <div class="stat-icon"><i class="fas fa-xmark"></i></div>
                    <div>
                        <div class="stat-value">@Model.Count(p => p.Status == "Rejected")</div>
                        <div class="stat-label">Rejected</div>
                    </div>
                </div>
            </div>

            <!-- search / toolbar -->
            <div class="toolbar-row">
                <div class="search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" id="reqSearch" placeholder="Search by name..." onkeyup="filterRequests()" />
                </div>
                <span class="result-count" id="resultCount">@Model.Count() of @Model.Count() shown</span>
            </div>

            <!-- table -->
            <div class="table-responsive-cust">
                <table class="table table-green-white">
                    <thead>
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.Name)</th>
                            <th>@Html.DisplayNameFor(model => model.Description)</th>
                            <th>@Html.DisplayNameFor(model => model.price)</th>
                            <th>@Html.DisplayNameFor(model => model.quantity)</th>
                            <th>Category</th>
                            <th>Submitted By</th>
                            <th>@Html.DisplayNameFor(model => model.Status)</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int rowIndex = 0;
                        }
                        @foreach (var item in Model)
                        {
                            rowIndex++;
                            var statusText = item.Status ?? "Unknown";
                            var statusClass = statusText.ToLower() switch
                            {
                                "available" => "status-active",
                                "rejected" => "status-inactive",
                                _ => "status-pending"
                            };
                            var safeName = System.Web.HttpUtility.JavaScriptStringEncode(item.Name);
                            <tr style="--i: @rowIndex;" data-req-name="@item.Name">
                                <td>
                                    <div class="name-cell">
                                        @if (!string.IsNullOrEmpty(item.Image1))
                                        {
                                            <img src="@item.Image1" alt="@item.Name" class="prod-thumb" onerror="this.onerror=null;this.src='@Url.Content("~/images/products/" + item.Image1)';" />
                                        }
                                        else
                                        {
                                            <div class="prod-thumb-placeholder">@(string.IsNullOrEmpty(item.Name) ? "?" : item.Name.Substring(0, 1).ToUpper())</div>
                                        }
                                        <div class="prod-name">@Html.DisplayFor(modelItem => item.Name)</div>
                                    </div>
                                </td>
                                <td><div class="prod-desc">@Html.DisplayFor(modelItem => item.Description)</div></td>
                                <td>@item.price.ToString("C")</td>
                                <td>@Html.DisplayFor(modelItem => item.quantity)</td>
                                <td>@Html.DisplayFor(modelItem => item.SubCategory.Name)</td>
                                <td>@Html.DisplayFor(modelItem => item.User.UserName)</td>
                                <td>
                                    <span class="badge-status @statusClass">
                                        <i class="fas fa-circle"></i> @statusText
                                    </span>
                                </td>
                                <td>
                                    <div class="actions-wrap">
                                        <form id="form-view-@item.Id" asp-action="Viewproductdetails" asp-route-id="@item.Id" method="post" class="m-0" style="display:contents;">
                                            <button type="submit" class="btn btn-action btn-view">
                                                <i class="fas fa-eye"></i> View
                                            </button>
                                        </form>
                                        <form id="form-accept-@item.Id" asp-action="Acceptrequestlogic" asp-route-id="@item.Id" method="post" class="m-0" style="display:contents;"></form>
                                        <button type="button" class="btn btn-action btn-accept"
                                                onclick="openActionModal('accept', 'form-accept-@item.Id', '@safeName')">
                                            <i class="fas fa-check"></i> Accept
                                        </button>

                                        <form id="form-reject-@item.Id" asp-action="Rejectrequestlogic" asp-route-id="@item.Id" method="post" class="m-0" style="display:contents;"></form>
                                        <button type="button" class="btn btn-action btn-reject"
                                                onclick="openActionModal('reject', 'form-reject-@item.Id', '@safeName')">
                                            <i class="fas fa-ban"></i> Reject
                                        </button>

                                        <form id="form-delete-@item.Id" asp-action="Deleterequestlogic" asp-route-id="@item.Id" method="post" class="m-0" style="display:contents;"></form>
                                        <button type="button" class="btn btn-action btn-delete"
                                                onclick="openActionModal('delete', 'form-delete-@item.Id', '@safeName')">
                                            <i class="fas fa-trash-alt"></i> Delete
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                        <tr class="empty-state-row" id="noResultsRow" style="display: none;">
                            <td colspan="8">
                                <i class="fas fa-folder-open"></i>
                                No matching requests found.
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- footer -->
            <div class="table-footer">
                <span><i class="fas fa-arrow-right"></i> review each submission before it goes live</span>
                <span class="pill"><i class="fas fa-clipboard-list"></i> @Model.Count() requests</span>
            </div>

        </div> <!-- end admin-card -->
    </div> <!-- end container-cust -->
    <!-- ===== SHARED ACTION CONFIRM MODAL ===== -->
    <div id="actionModalOverlay" class="action-modal-overlay">
        <div class="action-modal" id="actionModalBox">
            <div class="modal-icon" id="actionModalIcon"><i class="fas fa-question"></i></div>
            <h3 id="actionModalTitle">Are you sure?</h3>
            <p>
                <span id="actionModalMessage">Confirm this action for</span>
                <span class="name-highlight" id="actionModalName">"Name"</span>?
            </p>
            <div class="modal-actions">
                <button class="btn-cancel" onclick="closeActionModal()">
                    <i class="fas fa-times"></i> Cancel
                </button>
                <button class="btn-confirm" id="actionConfirmBtn">
                    <i class="fas fa-check"></i> Yes, Continue
                </button>
            </div>
        </div>
    </div>

    <!-- ===== SUCCESS TOAST ===== -->
    <div id="successToast" class="toast-container-custom">
        <div id="toastMessage" class="toast-success" style="display: none;">
            <i class="fas fa-check-circle"></i>
            <div class="toast-content">
                <div class="toast-title">Working...</div>
                <div class="toast-message" id="toastText">Processing your request</div>
            </div>
        </div>
    </div>
</div> <!-- end requests-page -->

<script>
    let pendingFormId = null;

    const modalConfig = {
        accept: {
            icon: 'fas fa-check',
            title: 'Approve Product?',
            message: 'Are you sure you want to approve',
            confirmIcon: 'fas fa-check',
            confirmText: 'Yes, Approve',
            toastTitle: 'Approved!',
            toastMessage: 'The product is now live in the gallery.',
            tone: ''
        },
        reject: {
            icon: 'fas fa-ban',
            title: 'Reject Product?',
            message: 'Are you sure you want to reject',
            confirmIcon: 'fas fa-ban',
            confirmText: 'Yes, Reject',
            toastTitle: 'Rejected',
            toastMessage: 'The product request has been rejected.',
            tone: 'tone-reject'
        },
        delete: {
            icon: 'fas fa-trash-alt',
            title: 'Delete Request?',
            message: 'Are you sure you want to permanently delete',
            confirmIcon: 'fas fa-trash-alt',
            confirmText: 'Yes, Delete',
            toastTitle: 'Deleted!',
            toastMessage: 'The request was removed successfully.',
            tone: 'tone-delete'
        }
    };

    function openActionModal(mode, formId, name) {
        pendingFormId = formId;
        const cfg = modalConfig[mode];
        const box = document.getElementById('actionModalBox');
        box.className = 'action-modal mode-' + mode;

        document.getElementById('actionModalIcon').innerHTML = `<i class="${cfg.icon}"></i>`;
        document.getElementById('actionModalTitle').innerText = cfg.title;
        document.getElementById('actionModalMessage').innerText = cfg.message;
        document.getElementById('actionModalName').textContent = `"${name}"`;

        const confirmBtn = document.getElementById('actionConfirmBtn');
        confirmBtn.innerHTML = `<i class="${cfg.confirmIcon}"></i> ${cfg.confirmText}`;
        confirmBtn.dataset.mode = mode;

        const overlay = document.getElementById('actionModalOverlay');
        overlay.style.display = 'flex';

        box.style.animation = 'none';
        setTimeout(() => { box.style.animation = 'modalSlideUpReq 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275)'; }, 10);
    }

    function closeActionModal() {
        document.getElementById('actionModalOverlay').style.display = 'none';
        pendingFormId = null;
    }

    document.getElementById('actionConfirmBtn').addEventListener('click', function () {
        if (!pendingFormId) return;
        const mode = this.dataset.mode;
        const cfg = modalConfig[mode];
        const form = document.getElementById(pendingFormId);
        const row = form ? form.closest('tr') : null;

        closeActionModal();
        showSuccessToast(cfg.toastTitle, cfg.toastMessage, cfg.tone);

        if (row && mode === 'delete') {
            row.classList.add('fade-out');
        }

        setTimeout(() => {
            if (form) form.submit();
        }, mode === 'delete' ? 700 : 300);
    });

    document.getElementById('actionModalOverlay').addEventListener('click', function (e) {
        if (e.target === this) closeActionModal();
    });

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeActionModal();
    });

    function showSuccessToast(title, message, tone) {
        const toast = document.getElementById('toastMessage');
        toast.className = 'toast-success ' + (tone || '');

        toast.querySelector('.toast-title').innerText = title;
        toast.querySelector('.toast-message').innerText = message;

        toast.style.display = 'flex';
        toast.style.animation = 'none';
        setTimeout(() => { toast.style.animation = 'slideInRightReq 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275)'; }, 10);

        clearTimeout(window.toastTimeoutReq);
        window.toastTimeoutReq = setTimeout(() => {
            toast.classList.add('hide');
            setTimeout(() => { toast.style.display = 'none'; }, 500);
        }, 4000);
    }

    // Live search filter across the name column
    function filterRequests() {
        const query = document.getElementById('reqSearch').value.trim().toLowerCase();
        const rows = document.querySelectorAll('.requests-page .table-green-white tbody tr:not(#noResultsRow)');
        let visibleCount = 0;

        rows.forEach(row => {
            const name = (row.getAttribute('data-req-name') || '').toLowerCase();
            const matches = name.includes(query);
            row.style.display = matches ? '' : 'none';
            if (matches) visibleCount++;
        });

        document.getElementById('noResultsRow').style.display = visibleCount === 0 ? '' : 'none';
        const countEl = document.getElementById('resultCount');
        if (countEl) countEl.textContent = `${visibleCount} of ${rows.length} shown`;
    }
</script>
