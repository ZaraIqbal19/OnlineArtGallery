@model Art_Gallery.Models.AuctionDetails
@using Art_Gallery.Models
@using Microsoft.EntityFrameworkCore
@using System.Text.Json
@using System.Linq
@{
    ViewData["Title"] = "Auction Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
@functions {
    string GetImgFileName(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return string.Empty;
        var normalized = raw.Replace('\\', '/');
        return normalized.Substring(normalized.LastIndexOf('/') + 1);
    }

    // AvailableForBid is stored as a string, not a bool, so it can't be
    // compared/coalesced as one. This treats common truthy values as "available".
    bool IsAvailableForBid(string? val)
    {
        if (string.IsNullOrWhiteSpace(val)) return false;
        var v = val.Trim();
        return v.Equals("yes", StringComparison.OrdinalIgnoreCase)
            || v.Equals("true", StringComparison.OrdinalIgnoreCase)
            || v.Equals("available", StringComparison.OrdinalIgnoreCase)
            || v.Equals("1", StringComparison.OrdinalIgnoreCase);
    }

    // Safely JSON-escapes a string for embedding inside an inline <script> block.
    string JsStr(string? val) => JsonSerializer.Serialize(val ?? "");

    // Builds a small list of candidate app-relative URLs for an image.
    // The DB value (raw) is normally already a full relative path from
    // wwwroot, e.g. "/uploads/categories/xyz.png" — that's the real,
    // correct location, so it's tried FIRST, exactly as stored. The
    // "~/images/<folder>/" guesses are kept only as a last-resort fallback
    // in case some rows were seeded with a bare filename instead of a path.
    string[] ImgCandidates(string? raw, string folder)
    {
        if (string.IsNullOrWhiteSpace(raw)) return Array.Empty<string>();
        var name = GetImgFileName(raw);
        if (string.IsNullOrEmpty(name)) return Array.Empty<string>();

        var normalized = raw.Replace('\\', '/').TrimStart('~');
        if (!normalized.StartsWith("/")) normalized = "/" + normalized;

        var singular = folder.EndsWith("s") ? folder.Substring(0, folder.Length - 1) : folder;
        var paths = new List<string>
        {
            Url.Content("~" + normalized),                 // exact stored path, e.g. /uploads/categories/xyz.png
            Url.Content("~/uploads/" + folder + "/" + name),
            Url.Content("~/images/" + folder + "/" + name),
            Url.Content("~/images/" + singular + "/" + name),
            Url.Content("~/images/" + name)
        };
        return paths.Distinct().ToArray();
    }
}

@{
    // ---- Bid history for this product, supplied by the controller via ViewBag ----
    // Controller sorts DESCENDING by amount; re-sorted ascending here so the
    // timeline still reads "lowest → leading bid" left-to-right.
    var bidHistory = (ViewBag.PreviousBids as List<AuctionDetails> ?? new List<AuctionDetails>())
        .OrderBy(b => b.bidamount)
        .ToList();
}

