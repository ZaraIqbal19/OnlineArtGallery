@{
}
@model IEnumerable<Art_Gallery.Models.SubCategory>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Sub Category</th>
            <th>Category</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.category.Name</td>
            </tr>
        }
    </tbody>
</table>

