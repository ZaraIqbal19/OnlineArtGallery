@model Art_Gallery.Models.Category

@{
    ViewData["Title"] = "Create Category";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
<style>
    /* ---------- GREEN & WHITE THEME · ENHANCED ---------- */
    :root {
        --primary-green: #88d200;
        --dark-green: #6fa800;
        --light-green: #d4f09b;
        --ultra-light-green: #f0fae6;
        --gradient-start: #88d200;
        --gradient-end: #6fa800;
        --shadow-color: rgba(136, 210, 0, 0.2);
        --card-shadow: 0 20px 60px rgba(136, 210, 0, 0.12);
        --border-radius-lg: 32px;
        --border-radius-md: 24px;
        --border-radius-sm: 20px;
        --transition-smooth: cubic-bezier(0.23, 1, 0.32, 1);
        --error-color: #dc3545;
        --error-bg: #fff5f5;
        --success-color: #28a745;
        --success-bg: #e6f4ea;
    }

    /* Hide scrollbar */
    ::-webkit-scrollbar {
        width: 0px;
        background: transparent;
    }

    * {
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

    .create-page-wrapper {
        padding: 20px 0;
        animation: fadeInUp 0.6s ease;
        overflow: hidden;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ===== CARD ===== */
    .card-green-white {
        background: #ffffff;
        border: none;
        border-radius: var(--border-radius-lg);
        box-shadow: var(--card-shadow);
        transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
        position: relative;
        overflow: hidden;
        backdrop-filter: blur(2px);
    }

        .card-green-white::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 6px;
            background: linear-gradient(90deg, var(--primary-green), var(--dark-green), var(--primary-green));
            background-size: 200% 100%;
            animation: shimmerGreen 4s infinite;
            z-index: 2;
        }

    @@keyframes shimmerGreen {
        0% {
            background-position: -200% 0;
        }

        100% {
            background-position: 200% 0;
        }
    }

    .card-green-white:hover {
        transform: translateY(-6px) scale(1.003);
        box-shadow: 0 28px 70px rgba(136, 210, 0, 0.20);
    }

    /* ===== TYPOGRAPHY & ACCENTS ===== */
    .text-green-accent {
        color: var(--primary-green);
    }

    .bg-green-soft {
        background: var(--ultra-light-green);
    }

    .border-green-light {
        border-color: var(--light-green) !important;
    }

    /* ===== BUTTONS ===== */
    .btn-green {
        background: linear-gradient(135deg, var(--primary-green), var(--dark-green));
        border: none;
        color: white;
        padding: 14px 36px;
        border-radius: 60px;
        font-weight: 700;
        letter-spacing: 0.5px;
        transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        box-shadow: 0 8px 30px rgba(136, 210, 0, 0.35);
        position: relative;
        overflow: hidden;
    }

        .btn-green::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%);
            opacity: 0;
            transition: opacity 0.5s;
            transform: scale(0.8);
        }

        .btn-green:hover::after {
            opacity: 1;
            transform: scale(1);
        }

        .btn-green:hover {
            background: linear-gradient(135deg, #7abe00, #5a8f00);
            transform: scale(1.04) translateY(-3px);
            box-shadow: 0 14px 40px rgba(136, 210, 0, 0.50);
            color: #fff;
        }

        .btn-green:active {
            transform: scale(0.96);
        }

        .btn-green i {
            transition: transform 0.3s ease;
        }

        .btn-green:hover i {
            transform: rotate(6deg) scale(1.1);
        }

    .btn-outline-green {
        background: transparent;
        border: 2px solid var(--primary-green);
        color: var(--dark-green);
        padding: 14px 36px;
        border-radius: 60px;
        font-weight: 700;
        letter-spacing: 0.5px;
        transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

        .btn-outline-green:hover {
            background: var(--ultra-light-green);
            transform: scale(1.04) translateY(-3px);
            box-shadow: 0 14px 40px rgba(136, 210, 0, 0.15);
            color: var(--dark-green);
            border-color: var(--dark-green);
        }

        .btn-outline-green i {
            transition: transform 0.3s ease;
        }

        .btn-outline-green:hover i {
            transform: translateX(-4px) scale(1.1);
        }

    /* ===== FORM INPUTS ===== */
    .form-control-green {
        border: 2px solid #e2e8e0;
        border-radius: var(--border-radius-sm);
        padding: 14px 20px;
        transition: all 0.3s ease;
        background: #fefcfc;
        font-weight: 450;
        font-size: 1rem;
        box-shadow: inset 0 2px 6px rgba(0,0,0,0.02);
    }

        .form-control-green:focus {
            border-color: var(--primary-green);
            box-shadow: 0 0 0 6px rgba(136, 210, 0, 0.12), inset 0 2px 8px rgba(0,0,0,0.02);
            background: #ffffff;
            transform: scale(1.01);
        }

        .form-control-green:not(.is-valid):not(.is-invalid) {
            border-color: #e2e8e0;
        }

    .form-label {
        font-weight: 700;
        color: #2d3d24;
        margin-bottom: 8px;
        font-size: 0.95rem;
        letter-spacing: -0.2px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .form-label i {
            color: var(--primary-green);
            width: 20px;
            text-align: center;
            transition: transform 0.3s ease;
        }

        .form-label:hover i {
            transform: scale(1.2) rotate(-10deg);
        }

        .form-label .validation-rules {
            font-size: 0.65rem;
            font-weight: 400;
            color: #7a8a7a;
            background: #f0f4f0;
            padding: 2px 10px;
            border-radius: 50px;
        }

    /* ===== VALIDATION STATES ===== */
    .form-control-green.is-valid {
        border-color: var(--success-color);
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' width='22' height='22' viewBox='0 0 24 24' fill='none' stroke='%2328a745' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='20 6 9 17 4 12'%3e%3c/polyline%3e%3c/svg%3e");
        background-repeat: no-repeat;
        background-position: right 16px center;
        background-size: 22px;
        padding-right: 50px;
        animation: validPop 0.3s ease;
    }

    @@keyframes validPop {
        0% {
            transform: scale(0.98);
        }

        50% {
            transform: scale(1.02);
        }

        100% {
            transform: scale(1);
        }
    }

    .form-control-green.is-invalid {
        border-color: var(--error-color);
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' width='22' height='22' viewBox='0 0 24 24' fill='none' stroke='%23dc3545' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'%3e%3ccircle cx='12' cy='12' r='10'%3e%3c/circle%3e%3cline x1='15' y1='9' x2='9' y2='15'%3e%3c/line%3e%3cline x1='9' y1='9' x2='15' y2='15'%3e%3c/line%3e%3c/svg%3e");
        background-repeat: no-repeat;
        background-position: right 16px center;
        background-size: 22px;
        padding-right: 50px;
        animation: invalidShake 0.5s ease;
    }

    @@keyframes invalidShake {
        0%, 100% {
            transform: translateX(0);
        }

        10%, 30%, 50%, 70%, 90% {
            transform: translateX(-5px);
        }

        20%, 40%, 60%, 80% {
            transform: translateX(5px);
        }
    }

    .invalid-feedback, .valid-feedback {
        font-weight: 600;
        font-size: 0.85rem;
        margin-top: 8px;
        display: flex;
        align-items: center;
        gap: 8px;
        animation: slideIn 0.3s ease;
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .invalid-feedback {
        color: var(--error-color);
    }

    .valid-feedback {
        color: var(--success-color);
    }

    /* ===== ENHANCED SUCCESS POPUP ===== */
    .success-popup-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        z-index: 9999;
        animation: overlayFadeIn 0.4s ease;
        justify-content: center;
        align-items: center;
        padding: 20px;
    }

        .success-popup-overlay.show {
            display: flex;
        }

    @@keyframes overlayFadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    .success-popup {
        background: linear-gradient(145deg, #ffffff, #f8fbf8);
        border-radius: var(--border-radius-lg);
        padding: 50px 45px 40px;
        max-width: 520px;
        width: 100%;
        position: relative;
        animation: popupBounce 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 50px 100px rgba(0, 0, 0, 0.3), 0 0 0 1px rgba(136, 210, 0, 0.1);
        text-align: center;
        overflow: hidden;
    }

        .success-popup::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -30%;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(136, 210, 0, 0.05) 0%, transparent 70%);
            border-radius: 50%;
            animation: popupGlow 4s ease-in-out infinite;
        }

        .success-popup::after {
            content: '';
            position: absolute;
            bottom: -30%;
            left: -20%;
            width: 250px;
            height: 250px;
            background: radial-gradient(circle, rgba(40, 167, 69, 0.04) 0%, transparent 70%);
            border-radius: 50%;
            animation: popupGlow 5s ease-in-out infinite reverse;
        }

    @@keyframes popupGlow {
        0%, 100% {
            transform: translate(0, 0) scale(1);
        }

        50% {
            transform: translate(-20px, -20px) scale(1.2);
        }
    }

    @@keyframes popupBounce {
        0% {
            opacity: 0;
            transform: scale(0.3) translateY(-80px) rotate(-10deg);
        }

        50% {
            transform: scale(1.05) translateY(10px) rotate(2deg);
        }

        70% {
            transform: scale(0.95) translateY(-5px) rotate(-1deg);
        }

        85% {
            transform: scale(1.01) translateY(2px);
        }

        100% {
            opacity: 1;
            transform: scale(1) translateY(0) rotate(0deg);
        }
    }

    .success-popup .popup-icon-container {
        position: relative;
        z-index: 1;
        margin-bottom: 20px;
    }

    .success-popup .popup-icon {
        width: 120px;
        height: 120px;
        background: linear-gradient(135deg, #e6f4ea, #d4edda);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
        position: relative;
        animation: popupIconPulse 3s ease-in-out infinite;
        box-shadow: 0 0 0 0 rgba(40, 167, 69, 0.2);
    }

    @@keyframes popupIconPulse {
        0%, 100% {
            transform: scale(1);
            box-shadow: 0 0 0 0 rgba(40, 167, 69, 0.2);
        }

        50% {
            transform: scale(1.05);
            box-shadow: 0 0 0 30px rgba(40, 167, 69, 0);
        }
    }

    .success-popup .popup-icon .icon-ring {
        position: absolute;
        inset: -8px;
        border-radius: 50%;
        border: 3px solid rgba(40, 167, 69, 0.15);
        animation: ringPulse 2s ease-in-out infinite;
    }

        .success-popup .popup-icon .icon-ring:nth-child(2) {
            inset: -16px;
            border-color: rgba(40, 167, 69, 0.08);
            animation-delay: 0.5s;
        }

    @@keyframes ringPulse {
        0%, 100% {
            transform: scale(1);
            opacity: 1;
        }

        50% {
            transform: scale(1.1);
            opacity: 0.3;
        }
    }

    .success-popup .popup-icon i {
        font-size: 4.5rem;
        color: var(--success-color);
        animation: popupCheck 1s ease;
        position: relative;
        z-index: 2;
    }

    @@keyframes popupCheck {
        0% {
            transform: scale(0) rotate(-180deg);
            opacity: 0;
        }

        50% {
            transform: scale(1.3) rotate(10deg);
            opacity: 1;
        }

        70% {
            transform: scale(0.9) rotate(-5deg);
        }

        100% {
            transform: scale(1) rotate(0deg);
            opacity: 1;
        }
    }

    .success-popup .popup-title {
        font-size: 2rem;
        font-weight: 800;
        color: #1a3324;
        margin-bottom: 6px;
        position: relative;
        z-index: 1;
    }

        .success-popup .popup-title .highlight {
            background: linear-gradient(135deg, var(--primary-green), var(--success-color));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

    .success-popup .popup-subtitle {
        color: #4a6a5a;
        font-size: 1.05rem;
        margin-bottom: 6px;
        position: relative;
        z-index: 1;
    }

    .success-popup .popup-message {
        color: #6a8a7a;
        font-size: 0.95rem;
        margin-bottom: 20px;
        position: relative;
        z-index: 1;
        line-height: 1.6;
    }

    .success-popup .popup-category-box {
        background: linear-gradient(135deg, var(--ultra-light-green), #e8f5e0);
        border-radius: var(--border-radius-sm);
        padding: 14px 20px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        border: 1px solid var(--light-green);
        position: relative;
        z-index: 1;
        animation: categoryBoxPop 0.6s ease 0.3s both;
    }

    @@keyframes categoryBoxPop {
        from {
            opacity: 0;
            transform: scale(0.9) translateY(10px);
        }

        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }

    .success-popup .popup-category-box i {
        color: var(--primary-green);
        font-size: 1.2rem;
    }

    .success-popup .popup-category-box .category-name {
        font-weight: 700;
        color: var(--dark-green);
        font-size: 1.05rem;
        letter-spacing: 0.5px;
    }

    .success-popup .popup-category-box .category-label {
        color: #7a9a8a;
        font-size: 0.8rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .success-popup .popup-stats {
        display: flex;
        justify-content: center;
        gap: 30px;
        margin-bottom: 24px;
        position: relative;
        z-index: 1;
    }

        .success-popup .popup-stats .stat-item {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.85rem;
            color: #6a8a7a;
        }

            .success-popup .popup-stats .stat-item i {
                color: var(--primary-green);
                font-size: 0.9rem;
            }

        .success-popup .popup-stats .stat-divider {
            width: 1px;
            background: #e0ece0;
        }

    .success-popup .popup-actions {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
        position: relative;
        z-index: 1;
    }

        .success-popup .popup-actions .btn-popup-primary {
            background: linear-gradient(135deg, var(--primary-green), var(--dark-green));
            border: none;
            color: white;
            padding: 14px 40px;
            border-radius: 60px;
            font-weight: 700;
            transition: all 0.3s ease;
            box-shadow: 0 8px 30px rgba(136, 210, 0, 0.35);
            position: relative;
            overflow: hidden;
        }

            .success-popup .popup-actions .btn-popup-primary::after {
                content: '';
                position: absolute;
                top: -50%;
                left: -50%;
                width: 200%;
                height: 200%;
                background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%);
                opacity: 0;
                transition: opacity 0.4s;
            }

            .success-popup .popup-actions .btn-popup-primary:hover::after {
                opacity: 1;
            }

            .success-popup .popup-actions .btn-popup-primary:hover {
                transform: translateY(-3px) scale(1.05);
                box-shadow: 0 12px 40px rgba(136, 210, 0, 0.45);
            }

            .success-popup .popup-actions .btn-popup-primary:active {
                transform: scale(0.96);
            }

        .success-popup .popup-actions .btn-popup-secondary {
            background: transparent;
            border: 2px solid #e2e8e0;
            color: #4a6a5a;
            padding: 14px 32px;
            border-radius: 60px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

            .success-popup .popup-actions .btn-popup-secondary:hover {
                background: #f7faf7;
                border-color: var(--primary-green);
                transform: translateY(-3px);
                box-shadow: 0 8px 25px rgba(0, 0, 0, 0.05);
            }

    .success-popup .popup-close {
        position: absolute;
        top: 16px;
        right: 16px;
        background: rgba(0, 0, 0, 0.04);
        border: none;
        color: #a0b0a0;
        font-size: 1.2rem;
        cursor: pointer;
        transition: all 0.3s ease;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 2;
    }

        .success-popup .popup-close:hover {
            background: rgba(0, 0, 0, 0.08);
            color: #4a6a5a;
            transform: rotate(90deg) scale(1.1);
        }

    /* ===== CONFETTI ===== */
    .confetti-container {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 10000;
        overflow: hidden;
    }

    .confetti-piece {
        position: absolute;
        top: -20px;
        width: 10px;
        height: 10px;
        border-radius: 2px;
        animation: confettiFall linear forwards;
    }

    @@keyframes confettiFall {
        0% {
            transform: translateY(0) rotate(0deg) scale(0);
            opacity: 1;
        }

        100% {
            transform: translateY(110vh) rotate(720deg) scale(1);
            opacity: 0;
        }
    }

    /* ===== CHARACTER COUNTER ===== */
    .char-counter {
        font-size: 0.8rem;
        color: #7a5a5a;
        transition: 0.3s ease;
        font-weight: 500;
        padding: 4px 12px;
        border-radius: 20px;
        background: #f8faf8;
    }

        .char-counter.limit-reached {
            color: var(--error-color);
            font-weight: 700;
            background: var(--error-bg);
            animation: counterWiggle 0.5s ease;
        }

    @@keyframes counterWiggle {
        0%, 100% {
            transform: rotate(0deg);
        }

        25% {
            transform: rotate(-3deg);
        }

        75% {
            transform: rotate(3deg);
        }
    }

    /* ===== RIBBON DECORATION ===== */
    .card-badge-ribbon {
        position: absolute;
        top: 20px;
        right: -2px;
        background: linear-gradient(135deg, var(--primary-green), var(--dark-green));
        color: white;
        padding: 8px 24px 8px 28px;
        border-radius: 40px 0 0 40px;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.5px;
        opacity: 0.9;
        box-shadow: -6px 6px 25px rgba(136, 210, 0, 0.3);
        z-index: 3;
        animation: ribbonPulse 3s ease-in-out infinite;
    }

    @@keyframes ribbonPulse {
        0%, 100% {
            opacity: 0.9;
        }

        50% {
            opacity: 1;
            transform: scale(1.02);
        }
    }

    /* ===== ANIMATIONS ===== */
    @@keyframes float {
        0%, 100% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-12px);
        }
    }

    .float-animation {
        animation: float 4s ease-in-out infinite;
    }

    /* ===== TIPS GRID ===== */
    .tips-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.5rem 1.5rem;
    }

        .tips-grid li {
            transition: all 0.3s ease;
            padding: 4px 0;
            cursor: default;
        }

            .tips-grid li:hover {
                transform: translateX(8px);
                color: var(--dark-green) !important;
            }

            .tips-grid li i {
                transition: all 0.3s ease;
            }

            .tips-grid li:hover i {
                transform: scale(1.3);
                opacity: 1 !important;
            }

    /* ===== INPUT GROUP ICON ===== */
    .input-group-icon {
        position: relative;
    }

        .input-group-icon .form-control-green {
            padding-left: 48px;
        }

        .input-group-icon .input-icon-left {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #a0aec0;
            transition: all 0.3s ease;
            z-index: 3;
            font-size: 1rem;
        }

        .input-group-icon:focus-within .input-icon-left {
            color: var(--primary-green);
            transform: translateY(-50%) scale(1.1);
        }

        .input-group-icon .form-control-green.is-valid ~ .input-icon-left {
            color: var(--success-color);
        }

        .input-group-icon .form-control-green.is-invalid ~ .input-icon-left {
            color: var(--error-color);
        }

    /* ===== BREADCRUMB ===== */
    .breadcrumb-custom {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.85rem;
        color: #7a8a7a;
        margin-bottom: 20px;
        padding: 8px 16px;
        background: var(--ultra-light-green);
        border-radius: 50px;
        border: 1px solid var(--light-green);
    }

        .breadcrumb-custom i {
            color: var(--primary-green);
        }

