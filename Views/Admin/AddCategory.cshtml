                            <h5 class="fw-bold mb-0" style="color: var(--dark-green); font-size: 0.95rem;">Pro Tips for Creating Categories</h5>
                            <span class="ms-auto stats-badge">
                                <i class="fa-regular fa-lightbulb"></i> 4 Tips
                            </span>
                        </div>
