@model IEnumerable<Art_Gallery.Models.Category>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
@if (TempData["Message"] != null)
{
    <div class="alert alert-success" role="alert">
        @TempData["Message"]
    </div>
}



<h1>Index</h1>

<p>
    <a asp-action="Create" class="btn btn-success">Create New Category</a>
</p>

<h1>Add Subcategory</h1>
<div class="row">
    <div class="col-md-4">
        <form asp-controller="Admin" asp-action="Addsubcategorylogic" method="post">

            <div class="form-group mb-3">
                <label for="Name" class="control-label">Subcategory Name</label>
                <input type="text" name="Name" class="form-control" required />
            </div>

            <div class="form-group mb-3">
                <label for="CategoryId">Category</label>
                <select name="CategoryId" class="form-control" required>
                    <option value="">-- Select a Category --</option>
                    @foreach (var item in Model)
                    {
                        <option value="@item.Id">@item.Name</option>
                    }
                </select>
            </div>

            <div class="form-group mt-2">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>

        </form>
    </div>
</div>

