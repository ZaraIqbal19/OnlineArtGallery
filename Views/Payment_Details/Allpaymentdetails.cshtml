@model IEnumerable<Art_Gallery.Models.Payment_Details>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.CardNumber)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CardTitle)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CVVCode)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DateofExpiry)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.UserId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.User)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.CardNumber)
            </td>
            <td>
                @Html.DisplayFor(model => item.CardTitle)
            </td>
            <td>
                @Html.DisplayFor(model => item.CVVCode)
            </td>
            <td>
                @Html.DisplayFor(model => item.DateofExpiry)
            </td>
            <td>
                @Html.DisplayFor(model => item.UserId)
            </td>
            <td>
                @Html.DisplayFor(model => item.User)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
