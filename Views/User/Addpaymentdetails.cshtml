    /* Confetti */
    .confetti-wrap {
        position: absolute;
        inset: 0;
        pointer-events: none;
        overflow: hidden;
        z-index: 5;
    }

    .confetti-piece {
        position: absolute;
        top: -12px;
        width: 8px;
        height: 14px;
        opacity: 0;
        border-radius: 2px;
    }

        .confetti-piece:nth-child(1) {
