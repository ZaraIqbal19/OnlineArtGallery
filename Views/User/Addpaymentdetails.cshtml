<div class="payment-page-wrapper">
    <!-- Floating particles -->
    <div class="particle"><i class="fas fa-credit-card"></i></div>
    <div class="particle"><i class="fas fa-lock"></i></div>
    <div class="particle"><i class="fas fa-shield-alt"></i></div>

    <div class="payment-page">

        <div class="trust-ribbon">
            <i class="fas fa-lock"></i> All payment data is encrypted end-to-end and never stored in plain text
        </div>

        <div class="payment-wrapper">
            <!-- Left Side - Credit Card Preview -->
            <div class="card-preview-section">
                <div class="card-preview-label">
                    <i class="fas fa-credit-card"></i> Card Preview
                    <span class="live-badge">
                        <span class="pulse-dot"></span> Live
                    </span>
                </div>

                <div class="credit-card-container" id="cardFlipTrigger">
                    <div class="credit-card" id="creditCard">
                        <!-- Front -->
                        <div class="card-face card-front">
                            <div class="card-bg-pattern"></div>
                            <div class="card-texture"></div>
                            <div class="card-bg-shine"></div>
                            <div class="card-chip-container">
                                <div class="card-chip"></div>
                                <div class="card-type placeholder" id="cardBrandIcon">✦</div>
                            </div>
                            <div class="card-number" id="cardDisplayNumber">
                                <span class="num-group">••••</span>
                                <span class="num-group">••••</span>
                                <span class="num-group">••••</span>
                                <span class="num-group">••••</span>
                            </div>
                            <div class="card-details">
                                <div class="card-holder">
                                    Card Holder
                                    <span id="cardDisplayName">YOUR NAME</span>
                                </div>
                                <div class="card-expiry">
                                    Expires
                                    <span id="cardDisplayExpiry">MM/YY</span>
                                </div>
                            </div>
                        </div>

                        <!-- Back -->
                        <div class="card-face card-back">
                            <div class="card-stripe"></div>
                            <div class="card-cvv-section">
                                <span class="card-cvv-label">CVV</span>
                                <span class="card-cvv" id="cardDisplayCVV">•••</span>
                            </div>
                            <div class="card-back-text">Secure Payment System</div>
                        </div>
                    </div>
                </div>

                <div class="flip-hint"><i class="fas fa-sync-alt"></i> Tap the card to flip it</div>

                <!-- Card Security Features -->
                <div class="card-security-features">
                    <span class="feature-item"><i class="fas fa-shield-alt"></i> 256-bit SSL</span>
                    <span class="feature-item"><i class="fas fa-lock"></i> PCI Compliant</span>
                    <span class="feature-item"><i class="fas fa-user-shield"></i> Fraud Protection</span>
                </div>
            </div>

            <!-- Right Side - Form -->
            <div class="form-section">
                <div class="form-header">
                    <div class="header-icon"><i class="fas fa-lock"></i></div>
                    <h2>
                        Payment Details
                        <small>Enter your card information securely</small>
                    </h2>
                    <div class="secure-badge"><i class="fas fa-shield-alt"></i> Secure</div>
                </div>

                <div class="form-progress">
                    <div class="form-progress-track">
                        <div class="form-progress-fill" id="formProgressFill"></div>
                    </div>
                    <div class="form-progress-label" id="formProgressLabel">0%</div>
                </div>

                <form method="post" asp-controller="user" asp-action="addpaymentdetailslogic" id="paymentForm" novalidate>
                    <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:0.5rem;"></div>

                    <!-- Card Number: displayed with auto-inserted spaces (1234 5678 9012 3456),
                         the real 16-digit value is submitted via the hidden input below. -->
                    <div class="input-group-modern floating">
                        <i class="fas fa-credit-card input-icon"></i>
                        <input type="text" class="form-control" id="CardNumberDisplay"
                               maxlength="19" inputmode="numeric" autocomplete="cc-number"
                               placeholder=" " />
                        <label for="CardNumberDisplay" class="floating-label">Card Number</label>
                        <i class="fas fa-check-circle valid-check"></i>
                        <span class="text-danger" id="cardNumberError">
                            <i class="fas fa-exclamation-circle"></i>
                        </span>
                        <input asp-for="CardNumber" type="hidden" id="CardNumber" />
                    </div>

                    <!-- Card Holder Name -->
                    <div class="input-group-modern floating">
                        <i class="fas fa-user input-icon"></i>
                        <input asp-for="CardTitle" class="form-control" id="CardTitle"
                               maxlength="50" placeholder=" " />
                        <label asp-for="CardTitle" class="floating-label">Card Holder Name</label>
                        <i class="fas fa-check-circle valid-check"></i>
                        <span asp-validation-for="CardTitle" class="text-danger" id="cardTitleError">
                            <i class="fas fa-exclamation-circle"></i>
                        </span>
                    </div>

                    <!-- CVV & Expiry -->
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="input-group-modern floating">
                                <i class="fas fa-key input-icon"></i>
                                <input asp-for="CVVCode" class="form-control" id="CVVCode"
                                       maxlength="3" inputmode="numeric" placeholder=" " />
                                <label asp-for="CVVCode" class="floating-label">CVV</label>
                                <i class="fas fa-check-circle valid-check"></i>
                                <span asp-validation-for="CVVCode" class="text-danger" id="cvvError">
                                    <i class="fas fa-exclamation-circle"></i>
                                </span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="input-group-modern floating">
                                <i class="fas fa-calendar-alt input-icon"></i>
                                <input type="date" asp-for="DateofExpiry" class="form-control" id="DateofExpiry" placeholder=" " />
                                <i class="fas fa-check-circle valid-check"></i>
                                <span asp-validation-for="DateofExpiry" class="text-danger" id="expiryError">
                                    <i class="fas fa-exclamation-circle"></i>
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- Submit -->
                    <div class="mt-4">
                        <button type="submit" class="btn-submit" id="submitBtn" disabled>
                            <i class="fas fa-save"></i>
                            <span>Secure Payment</span>
                            <i class="fas fa-arrow-right"></i>
                            <span class="spinner" id="submitSpinner"></span>
                        </button>
                    </div>
                </form>

                <!-- Back link -->
                <div>
                    <a asp-action="Index" class="back-link">
                        <i class="fas fa-chevron-left"></i> Back to List
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(function () {
        // Show success modal
        @if (TempData["Message"] != null)
        {
                        <text>
                            var successModal = new bootstrap.Modal(document.getElementById('successModal'), {
                                backdrop: 'static',
                                keyboard: true
                            });
                            successModal.show();
                        </text>
        }

        // ----- Helper: toggle the "has-value" class that drives the floating label -----
        // This is the key fix for "placeholder text not going away when typing":
        // instead of relying only on the CSS :placeholder-shown trick (which some
        // browsers/input types like <input type="date"> don't handle well, and which
        // can lag when we rewrite .val() from JS), we explicitly flag every field
        // with .has-value the moment it has content, on every input/blur/change.
        function syncFloatingLabel($input) {
            const val = $input.val();
            if (val && val.length > 0) {
                $input.addClass('has-value');
            } else {
                $input.removeClass('has-value');
            }
        }

        // ----- Card brand detection (Visa / Mastercard / Amex / Discover) -----
        function detectCardBrand(digits) {
            if (/^4/.test(digits)) return { icon: 'fa-cc-visa', label: 'Visa' };
            if (/^(5[1-5]|2[2-7])/.test(digits)) return { icon: 'fa-cc-mastercard', label: 'Mastercard' };
            if (/^3[47]/.test(digits)) return { icon: 'fa-cc-amex', label: 'Amex' };
            if (/^6(011|5)/.test(digits)) return { icon: 'fa-cc-discover', label: 'Discover' };
            return null;
        }

        function updateCardBrand(digits) {
            const brand = detectCardBrand(digits);
            const $el = $('#cardBrandIcon');
            if (brand) {
                $el.removeClass('placeholder').html('<i class="fab ' + brand.icon + '"></i>');
            } else {
                $el.addClass('placeholder').text('✦');
            }
        }

        // Groups raw digits into "1234 5678 9012 3456" style spacing
        function formatCardNumber(digits) {
            const groups = digits.match(/.{1,4}/g) || [];
            return groups.join(' ');
        }

        // ----- Live card preview with grouped display -----
        function updateCardPreview() {
            let clean = ($('#CardNumber').val() || '');
            let groups = clean.match(/.{1,4}/g) || ['••••', '••••', '••••', '••••'];
            while (groups.length < 4) groups.push('••••');
            $('.card-number .num-group').each(function (i) {
                $(this).text(groups[i] || '••••');
            });

            updateCardBrand(clean);

            let name = $('#CardTitle').val() || 'YOUR NAME';
            $('#cardDisplayName').text(name.toUpperCase() || 'YOUR NAME');

            let cvv = $('#CVVCode').val() || '•••';
            $('#cardDisplayCVV').text(cvv.padEnd(3, '•'));

            let expiry = $('#DateofExpiry').val() || '';
            if (expiry) {
                let parts = expiry.split('-');
                let month = parts[1] || 'MM';
                let year = parts[0] ? parts[0].slice(2) : 'YY';
                $('#cardDisplayExpiry').text(month + '/' + year);
            } else {
                $('#cardDisplayExpiry').text('MM/YY');
            }
        }

        // ----- Card flip on click/tap -----
        $('#cardFlipTrigger').on('click', function () {
            $('#creditCard').toggleClass('flipped');
        });
        // Auto-flip to show CVV while typing it, then flip back
        $('#CVVCode').on('focus', function () { $('#creditCard').addClass('flipped'); });
        $('#CVVCode').on('blur', function () { $('#creditCard').removeClass('flipped'); });

        // ----- Validation functions -----
        function validateCardNumber(value) {
            const cleaned = (value || '').replace(/\s/g, '');
            if (cleaned.length === 0) return { valid: false, msg: 'Card number is required.' };
            if (!/^\d+$/.test(cleaned)) return { valid: false, msg: 'Only digits allowed.' };
            if (cleaned.length !== 16) return { valid: false, msg: 'Must be exactly 16 digits.' };
            return { valid: true, msg: '' };
        }

        function validateCardTitle(value) {
            if (!value || value.trim().length === 0) return { valid: false, msg: 'Card holder name is required.' };
            if (!/^[A-Za-z\s]+$/.test(value)) return { valid: false, msg: 'Only letters and spaces allowed.' };
            if (value.length < 3 || value.length > 50) return { valid: false, msg: 'Must be 3 to 50 characters.' };
            return { valid: true, msg: '' };
        }

        function validateCVV(value) {
            if (!value || value.length === 0) return { valid: false, msg: 'CVV is required.' };
            if (!/^\d+$/.test(value)) return { valid: false, msg: 'Only digits allowed.' };
            if (value.length !== 3) return { valid: false, msg: 'Must be exactly 3 digits.' };
            return { valid: true, msg: '' };
        }

        function validateExpiry(value) {
            if (!value) return { valid: false, msg: 'Expiry date is required.' };
            const selected = new Date(value);
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            if (selected < today) return { valid: false, msg: 'Date must be today or a future date.' };
            return { valid: true, msg: '' };
        }

        function updateProgress() {
            const cardNum = $('#CardNumber').val() || '';
            const cardTitle = $('#CardTitle').val() || '';
            const cvv = $('#CVVCode').val() || '';
            const expiry = $('#DateofExpiry').val() || '';

            let done = 0;
            if (validateCardNumber(cardNum).valid) done++;
            if (validateCardTitle(cardTitle).valid) done++;
            if (validateCVV(cvv).valid) done++;
            if (validateExpiry(expiry).valid) done++;

            const pct = Math.round((done / 4) * 100);
            $('#formProgressFill').css('width', pct + '%');
            $('#formProgressLabel').text(pct + '%');
        }

        function updateSubmitButton() {
            const cardNum = $('#CardNumber').val() || '';
            const cardTitle = $('#CardTitle').val() || '';
            const cvv = $('#CVVCode').val() || '';
            const expiry = $('#DateofExpiry').val() || '';

            const allValid = validateCardNumber(cardNum).valid &&
                             validateCardTitle(cardTitle).valid &&
                             validateCVV(cvv).valid &&
                             validateExpiry(expiry).valid;
            $('#submitBtn').prop('disabled', !allValid);
            updateProgress();
        }

        function showError(errorSpan, message) {
            if (message) {
                errorSpan.html('<i class="fas fa-exclamation-circle"></i> ' + message).addClass('show-error');
            } else {
                errorSpan.html('<i class="fas fa-exclamation-circle"></i>').removeClass('show-error');
            }
        }

        function setFieldValidity(input, isValid, errorSpan, message) {
            const $input = $(input);
            if (isValid) {
                $input.removeClass('input-invalid').addClass('input-valid');
                showError(errorSpan, null);
            } else {
                $input.removeClass('input-valid').addClass('input-invalid');
                showError(errorSpan, message);
            }
        }

        // ----- Card Number: type in #CardNumberDisplay (spaced), keep raw digits in
        // hidden #CardNumber (the one actually submitted to the server) -----
        $('#CardNumberDisplay').on('input', function () {
            const caretWasAtEnd = this.selectionStart === this.value.length;
            let raw = ($(this).val() || '').replace(/\D/g, '').slice(0, 16);
            const formatted = formatCardNumber(raw);

            $(this).val(formatted);
            $('#CardNumber').val(raw);
            syncFloatingLabel($(this));

            if (caretWasAtEnd) {
                this.setSelectionRange(this.value.length, this.value.length);
            }

            const result = validateCardNumber(raw);
            const errorSpan = $('#cardNumberError');
            if ($(this).is(':focus')) {
                if (!result.valid && raw.length > 0) { setFieldValidity(this, false, errorSpan, result.msg); }
                else if (result.valid) { setFieldValidity(this, true, errorSpan, null); }
                else { $(this).removeClass('input-valid input-invalid'); showError(errorSpan, null); }
            } else {
                if (!result.valid) { setFieldValidity(this, false, errorSpan, result.msg); }
                else { setFieldValidity(this, true, errorSpan, null); }
            }
            updateSubmitButton();
            updateCardPreview();
        });

        $('#CardNumberDisplay').on('blur', function () {
            const raw = $('#CardNumber').val() || '';
            const result = validateCardNumber(raw);
            const errorSpan = $('#cardNumberError');
            if (!result.valid) { setFieldValidity(this, false, errorSpan, result.msg); }
            else { setFieldValidity(this, true, errorSpan, null); }
        });

        $('#CardTitle').on('blur input', function () {
            let value = $(this).val() || '';
            const filtered = value.replace(/[^A-Za-z\s]/g, '');
            if (filtered !== value) { $(this).val(filtered); value = filtered; }
            if (value.length > 50) { $(this).val(value.slice(0, 50)); value = value.slice(0, 50); }
            syncFloatingLabel($(this));
            const result = validateCardTitle(value);
            const errorSpan = $('#cardTitleError');
            if ($(this).is(':focus')) {
                if (!result.valid && value.length > 0) { setFieldValidity(this, false, errorSpan, result.msg); }
                else if (result.valid) { setFieldValidity(this, true, errorSpan, null); }
            } else {
                if (!result.valid) { setFieldValidity(this, false, errorSpan, result.msg); }
                else { setFieldValidity(this, true, errorSpan, null); }
            }
            updateSubmitButton();
            updateCardPreview();
        });

        $('#CVVCode').on('blur input', function () {
            let value = $(this).val() || '';
            const digitsOnly = value.replace(/\D/g, '');
            if (digitsOnly !== value) { $(this).val(digitsOnly); value = digitsOnly; }
            if (value.length > 3) { $(this).val(value.slice(0, 3)); value = value.slice(0, 3); }
            syncFloatingLabel($(this));
            const result = validateCVV(value);
            const errorSpan = $('#cvvError');
            if ($(this).is(':focus')) {
                if (!result.valid && value.length > 0) { setFieldValidity(this, false, errorSpan, result.msg); }
                else if (result.valid) { setFieldValidity(this, true, errorSpan, null); }
            } else {
                if (!result.valid) { setFieldValidity(this, false, errorSpan, result.msg); }
                else { setFieldValidity(this, true, errorSpan, null); }
            }
            updateSubmitButton();
            updateCardPreview();
        });

        $('#DateofExpiry').on('blur input change', function () {
            const value = $(this).val() || '';
            syncFloatingLabel($(this));
            const result = validateExpiry(value);
            const errorSpan = $('#expiryError');
            if ($(this).is(':focus')) {
                if (!result.valid && value.length > 0) { setFieldValidity(this, false, errorSpan, result.msg); }
                else if (result.valid) { setFieldValidity(this, true, errorSpan, null); }
            } else {
                if (!result.valid) { setFieldValidity(this, false, errorSpan, result.msg); }
                else { setFieldValidity(this, true, errorSpan, null); }
            }
            updateSubmitButton();
            updateCardPreview();
        });

        // Initial state
        $('#submitBtn').prop('disabled', true);
        updateProgress();
        updateCardPreview();

        // Form submit
        $('#paymentForm').on('submit', function (e) {
            $('#CardNumberDisplay').trigger('blur');
            $('#CardTitle').trigger('blur');
            $('#CVVCode').trigger('blur');
            $('#DateofExpiry').trigger('blur');
            updateSubmitButton();

            if ($('#submitBtn').prop('disabled')) {
                e.preventDefault();
                $('.input-invalid').first().focus();
                return false;
            }

            // Show spinner
            const $btn = $('#submitBtn');
            $btn.find('i.fa-save, i.fa-arrow-right, span:not(.spinner)').hide();
            $btn.find('.spinner').show();
            $btn.prop('disabled', true);
            return true;
        });
    });
</script>
