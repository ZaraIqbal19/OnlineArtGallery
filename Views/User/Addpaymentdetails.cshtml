@model Art_Gallery.Models.Payment_Details

@{
    ViewData["Title"] = "Payment Details";
    Layout = "~/Views/Shared/_UserLayout.cshtml";

    // ----- Success message content -----
    // Falls back to a friendly default if the controller didn't set one,
    // so the modal always has something meaningful to say.
    var successMessage = TempData["Message"] as string
        ?? "Your card has been added successfully and is ready to use for purchases.";
}

<!-- Font Awesome 6 (free) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />

@if (TempData["Orderpaymentmessage"] != null)
{
    <div class="alert alert-warning">
        @TempData["Message"]
    </div>
}


@if (TempData["Message"] != null || true)
{
    <!-- Success Popup Modal -->
    <div class="modal fade" id="successModal" tabindex="-1" aria-labelledby="successModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content success-modal-content">
                <!-- Confetti burst -->
                <div class="confetti-wrap" aria-hidden="true">
                    <span class="confetti-piece"></span>
                    <span class="confetti-piece"></span>
                    <span class="confetti-piece"></span>
                    <span class="confetti-piece"></span>
                    <span class="confetti-piece"></span>
                    <span class="confetti-piece"></span>
                    <span class="confetti-piece"></span>
                    <span class="confetti-piece"></span>
                    <span class="confetti-piece"></span>
                    <span class="confetti-piece"></span>
                    <span class="confetti-piece"></span>
                    <span class="confetti-piece"></span>
                </div>

                <div class="success-banner"></div>

                <div class="modal-body text-center p-5 pt-4">
                    <div class="success-icon">
                        <svg viewBox="0 0 90 90" class="success-check-svg">
                            <circle class="success-check-circle" cx="45" cy="45" r="40" />
                            <path class="success-check-path" d="M27 46l12 12 24-24" />
                        </svg>
                    </div>

                    <h3 class="mt-4 mb-2 success-title">Payment Method Added!</h3>
                    <p class="success-subtitle">@successMessage</p>

                    <div class="success-detail-chip">
                        <i class="fas fa-shield-alt"></i> Encrypted &amp; PCI DSS compliant
                    </div>

                    <!-- Fixed: was a plain <button type="button"> which only closed the modal and
                         never navigated anywhere. Tag helpers like asp-controller/asp-action don't
                         wire up navigation on a <button type="button">, so it looked "broken".
                         Using an <a> styled as a button makes the click actually navigate. -->
                    <a asp-controller="user" asp-action="Addpaymentdetails" class="btn-success-modal">
                        <i class="fas fa-thumbs-up"></i> Got it
                    </a>
                </div>
            </div>
        </div>
    </div>
}

<style>
    /* ----- Color Theme Variables ----- */
    :root {
        --primary-green: #88d200;
        --dark-green: #6fa800;
        --light-green: #d4f09b;
        --ultra-light-green: #f0fae6;
        --deep-forest: #1a2e0e;
        --accent-gold: #ffd700;
        --shadow-sm: 0 2px 10px rgba(0,0,0,0.04);
        --shadow-md: 0 8px 30px rgba(0,0,0,0.06);
        --shadow-lg: 0 20px 60px rgba(0,0,0,0.08);
        --shadow-xl: 0 30px 80px rgba(111, 168, 0, 0.12);
        --radius-sm: 12px;
        --radius-md: 18px;
        --radius-lg: 28px;
        --radius-xl: 36px;
    }

    /* ----- Override Layout Styles ----- */
    .payment-page-wrapper {
        padding-top: 120px !important;
        padding-bottom: 80px !important;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        margin-top: 0;
        background: radial-gradient(circle at 15% 20%, rgba(136,210,0,0.05) 0%, transparent 45%), radial-gradient(circle at 85% 80%, rgba(111,168,0,0.05) 0%, transparent 45%);
    }

    /* ----- Page Layout ----- */
    .payment-page {
        width: 100%;
        position: relative;
        z-index: 1;
        padding: 1rem 2rem;
        margin-top: 20px;
    }

    /* Floating particles */
    .particle {
        position: absolute;
        font-size: 2.5rem;
        color: rgba(136, 210, 0, 0.05);
        animation: particleFloat 30s linear infinite;
        pointer-events: none;
    }

        .particle:nth-child(1) {
            top: 8%;
            left: 3%;
            animation-delay: 0s;
            font-size: 5rem;
        }

        .particle:nth-child(2) {
            top: 55%;
            right: 2%;
            animation-delay: 6s;
            font-size: 3.5rem;
        }

        .particle:nth-child(3) {
            bottom: 15%;
            left: 5%;
            animation-delay: 12s;
            font-size: 6rem;
        }

    @@keyframes particleFloat {
        0% {
            transform: translate(0, 0) rotate(0deg) scale(1);
        }

        33% {
            transform: translate(40px, -30px) rotate(120deg) scale(1.1);
        }

        66% {
            transform: translate(-30px, 40px) rotate(240deg) scale(0.9);
        }

        100% {
            transform: translate(0, 0) rotate(360deg) scale(1);
        }
    }

    /* ----- Trust ribbon above the whole page ----- */
    .trust-ribbon {
        max-width: 1050px;
        margin: 0 auto 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.6rem;
        color: var(--dark-green);
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.3px;
    }

        .trust-ribbon i {
            color: var(--primary-green);
        }

    /* ----- Main Container ----- */
    .payment-wrapper {
        display: grid;
        grid-template-columns: 1fr 1.1fr;
        gap: 3rem;
        max-width: 1050px;
        width: 100%;
        margin: 0 auto;
        position: relative;
        z-index: 1;
        align-items: start;
    }

    /* ----- Left Side - Credit Card Preview ----- */
    .card-preview-section {
        position: sticky;
        top: 2rem;
    }

    .card-preview-label {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 2.5px;
        color: #8a9f7a;
        font-weight: 600;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.8rem;
    }

        .card-preview-label i {
            color: var(--primary-green);
            font-size: 0.9rem;
        }

        .card-preview-label .live-badge {
            margin-left: auto;
            background: var(--ultra-light-green);
            padding: 0.2rem 0.8rem;
            border-radius: 50px;
            font-size: 0.6rem;
            color: var(--dark-green);
            font-weight: 700;
            letter-spacing: 0.5px;
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
        }

            .card-preview-label .live-badge .pulse-dot {
                width: 6px;
                height: 6px;
                border-radius: 50%;
                background: var(--primary-green);
                animation: pulseDot 1.6s ease-in-out infinite;
            }

    @@keyframes pulseDot {
        0%, 100% {
            box-shadow: 0 0 0 0 rgba(136,210,0,0.5);
        }

        50% {
            box-shadow: 0 0 0 5px rgba(136,210,0,0);
        }
    }

    /* Card Security Features */
    .card-security-features {
        display: flex;
        gap: 0.8rem;
        margin-top: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

        .card-security-features .feature-item {
            display: flex;
            align-items: center;
            gap: 0.4rem;
            font-size: 0.65rem;
            color: #7a8f6a;
            background: rgba(255,255,255,0.7);
            padding: 0.3rem 0.8rem;
            border-radius: 50px;
            backdrop-filter: blur(4px);
            border: 1px solid rgba(136,210,0,0.1);
            transition: all 0.3s ease;
        }

            .card-security-features .feature-item:hover {
                background: white;
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(136,210,0,0.1);
            }

            .card-security-features .feature-item i {
                color: var(--primary-green);
                font-size: 0.7rem;
            }

    .credit-card-container {
        perspective: 1300px;
        width: 100%;
        max-width: 420px;
        margin: 0 auto;
        cursor: pointer;
    }

    .credit-card {
        width: 100%;
        aspect-ratio: 1.586/1;
        position: relative;
        transform-style: preserve-3d;
        transition: transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        animation: cardHover 4s ease-in-out infinite;
    }

    @@keyframes cardHover {
        0%, 100% {
            transform: translateY(0) rotateY(0deg);
        }

        50% {
            transform: translateY(-8px) rotateY(2deg);
        }
    }

    .credit-card-container:hover .credit-card {
        transform: rotateY(10deg) rotateX(5deg) scale(1.02);
        transition: transform 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .credit-card.flipped {
        transform: rotateY(180deg) !important;
        animation: none;
    }

    .card-face {
        position: absolute;
        width: 100%;
        height: 100%;
        backface-visibility: hidden;
        border-radius: var(--radius-md);
        padding: 1.8rem 2rem;
        box-shadow: 0 20px 60px rgba(0,0,0,0.18), inset 0 1px 0 rgba(255,255,255,0.08);
        overflow: hidden;
    }

    /* Card Front - richer, more premium gradient + subtle animated sheen */
    .card-front {
        background: linear-gradient(150deg, #16280c 0%, #1f3a12 30%, #345c1e 65%, #4a7a2a 100%);
        transform: rotateY(0deg);
        border: 1px solid rgba(255,255,255,0.08);
    }

        .card-front .card-bg-pattern {
            position: absolute;
            top: -50%;
            right: -30%;
            width: 80%;
            height: 200%;
            background: radial-gradient(circle at 70% 50%, rgba(255,255,255,0.05) 0%, transparent 60%);
            pointer-events: none;
        }

            .card-front .card-bg-pattern::after {
                content: '';
                position: absolute;
                bottom: -30%;
                left: -20%;
                width: 60%;
                height: 60%;
                background: radial-gradient(circle, rgba(136,210,0,0.08) 0%, transparent 70%);
                border-radius: 50%;
            }

        /* Faint geometric texture for a more "premium card" feel */
        .card-front .card-texture {
            position: absolute;
            inset: 0;
            opacity: 0.5;
            background-image: repeating-linear-gradient(115deg, rgba(255,255,255,0.025) 0px, rgba(255,255,255,0.025) 1px, transparent 1px, transparent 14px);
            pointer-events: none;
        }

        .card-front .card-bg-shine {
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle at 30% 40%, rgba(255,255,255,0.04) 0%, transparent 60%);
            pointer-events: none;
            animation: shineMove 8s ease-in-out infinite;
        }

    @@keyframes shineMove {
        0%, 100% {
            transform: translate(0, 0);
        }

        50% {
            transform: translate(10%, 10%);
        }
    }

    .card-front .card-chip-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.2rem;
        position: relative;
        z-index: 2;
    }

    .card-front .card-chip {
        width: 48px;
        height: 34px;
        background: linear-gradient(135deg, #ffe9a0, var(--accent-gold), #d4a800);
        border-radius: 6px;
        box-shadow: 0 2px 16px rgba(255, 215, 0, 0.3);
        position: relative;
    }

        .card-front .card-chip::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 4px;
            right: 4px;
            height: 1px;
            background: rgba(0,0,0,0.15);
        }

        .card-front .card-chip::after {
            content: '';
            position: absolute;
            top: 4px;
            left: 4px;
            right: 4px;
            bottom: 4px;
            background: linear-gradient(135deg, rgba(255,255,255,0.2), transparent);
            border-radius: 4px;
        }

    .card-front .card-type {
        color: rgba(255,255,255,0.75);
        font-size: 1.6rem;
        font-weight: 900;
        letter-spacing: 1px;
        transition: all 0.3s ease;
    }

        .card-front .card-type i {
            font-size: 1.7rem;
        }

        .card-front .card-type.placeholder {
            color: rgba(255,255,255,0.15);
            font-size: 2rem;
            letter-spacing: 4px;
        }

    .card-front .card-number {
        color: white;
        font-size: 1.35rem;
        font-weight: 600;
        letter-spacing: 4px;
        font-family: 'Courier New', monospace;
        margin: 0.5rem 0 1rem;
        text-shadow: 0 2px 16px rgba(0,0,0,0.3);
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        position: relative;
        z-index: 2;
    }

        .card-front .card-number .num-group {
            flex: 1;
            min-width: 45px;
            text-align: center;
            background: rgba(255,255,255,0.04);
            padding: 0.2rem 0;
            border-radius: 4px;
            transition: all 0.3s ease;
        }

            .card-front .card-number .num-group.active {
                background: rgba(136,210,0,0.18);
                box-shadow: 0 0 20px rgba(136,210,0,0.12);
            }

    .card-front .card-details {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-top: auto;
        position: relative;
        z-index: 2;
    }

    .card-front .card-holder {
        color: rgba(255,255,255,0.4);
        font-size: 0.55rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
    }

        .card-front .card-holder span {
            display: block;
            color: white;
            font-size: 0.85rem;
            font-weight: 500;
            margin-top: 3px;
            letter-spacing: 1.5px;
            text-shadow: 0 1px 8px rgba(0,0,0,0.2);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 220px;
        }

    .card-front .card-expiry {
        color: rgba(255,255,255,0.4);
        font-size: 0.55rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        text-align: right;
    }

        .card-front .card-expiry span {
            display: block;
            color: white;
            font-size: 0.85rem;
            font-weight: 500;
            letter-spacing: 1.5px;
            text-shadow: 0 1px 8px rgba(0,0,0,0.2);
        }

    /* Card Back */
    .card-back {
        background: linear-gradient(150deg, #16240c 0%, #24371a 100%);
        transform: rotateY(180deg);
        border: 1px solid rgba(255,255,255,0.08);
        padding: 1.5rem 2rem;
    }

        .card-back .card-stripe {
            background: #0a0a0a;
            height: 38px;
            margin: 0.5rem -2rem 1rem;
            box-shadow: inset 0 2px 6px rgba(0,0,0,0.4);
        }

        .card-back .card-cvv-section {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 0.8rem;
            margin-top: 0.5rem;
        }

        .card-back .card-cvv-label {
            color: rgba(255,255,255,0.25);
            font-size: 0.55rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
        }

        .card-back .card-cvv {
            background: rgba(255,255,255,0.95);
            padding: 0.3rem 0.8rem;
            border-radius: 4px;
            font-family: 'Courier New', monospace;
            font-weight: 700;
            font-size: 0.9rem;
            color: #1a1a1a;
            min-width: 60px;
            text-align: right;
            letter-spacing: 3px;
            box-shadow: inset 0 2px 6px rgba(0,0,0,0.05);
        }

        .card-back .card-back-text {
            color: rgba(255,255,255,0.08);
            font-size: 0.45rem;
            text-transform: uppercase;
            letter-spacing: 3px;
            margin-top: 1.8rem;
            text-align: center;
        }

    .flip-hint {
        text-align: center;
        font-size: 0.65rem;
        color: #a3b895;
        margin-top: 0.9rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
    }

        .flip-hint i {
            color: var(--primary-green);
            font-size: 0.6rem;
            animation: rotateHint 3s linear infinite;
        }

    @@keyframes rotateHint {
        0%, 100% {
            transform: rotateY(0deg);
        }

        50% {
            transform: rotateY(180deg);
        }
    }

    /* ----- Right Side - Form ----- */
    .form-section {
        background: rgba(255, 255, 255, 0.92);
        backdrop-filter: blur(24px);
        border-radius: var(--radius-lg);
        padding: 2.8rem;
        box-shadow: var(--shadow-xl), var(--shadow-md);
        border: 1px solid rgba(255,255,255,0.6);
        transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

        .form-section:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-xl), 0 16px 50px rgba(136,210,0,0.06);
        }

    .form-header {
        display: flex;
        align-items: center;
        gap: 1.2rem;
        margin-bottom: 2.2rem;
        padding-bottom: 1.2rem;
        border-bottom: 2px solid rgba(136,210,0,0.08);
    }

        .form-header .header-icon {
            width: 52px;
            height: 52px;
            background: linear-gradient(135deg, var(--ultra-light-green), var(--light-green));
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary-green);
            font-size: 1.5rem;
            transition: all 0.4s ease;
            box-shadow: 0 4px 16px rgba(136,210,0,0.12);
        }

        .form-header:hover .header-icon {
            transform: scale(1.06) rotate(-6deg);
            box-shadow: 0 6px 24px rgba(136,210,0,0.2);
        }

        .form-header h2 {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--dark-green);
            margin: 0;
            letter-spacing: -0.5px;
        }

            .form-header h2 small {
                display: block;
                font-size: 0.75rem;
                font-weight: 400;
                color: #8a9f7a;
                letter-spacing: 0.5px;
                margin-top: 2px;
            }

        .form-header .secure-badge {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            color: var(--dark-green);
            font-size: 0.65rem;
            font-weight: 600;
            background: var(--ultra-light-green);
            padding: 0.4rem 1rem;
            border-radius: 50px;
            border: 1px solid rgba(136,210,0,0.1);
            transition: all 0.3s ease;
        }

            .form-header .secure-badge i {
                color: var(--primary-green);
                font-size: 0.7rem;
            }

            .form-header .secure-badge:hover {
                background: var(--light-green);
                transform: scale(1.02);
            }

    /* Progress indicator - shows how much of the form is complete */
    .form-progress {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-bottom: 1.6rem;
    }

    .form-progress-track {
        flex: 1;
        height: 6px;
        border-radius: 50px;
        background: var(--ultra-light-green);
        overflow: hidden;
    }

    .form-progress-fill {
        height: 100%;
        width: 0%;
        border-radius: 50px;
        background: linear-gradient(90deg, var(--primary-green), var(--dark-green));
        transition: width 0.4s cubic-bezier(0.25,0.46,0.45,0.94);
    }

    .form-progress-label {
        font-size: 0.7rem;
        font-weight: 700;
        color: var(--dark-green);
        min-width: 34px;
        text-align: right;
    }

    /* ----- Premium Input Fields ----- */
    .input-group-modern {
        position: relative;
        margin-bottom: 1.8rem;
    }

        .input-group-modern .input-icon {
            position: absolute;
            left: 18px;
            top: 50%;
            transform: translateY(-50%);
            color: #b0c0a0;
            font-size: 1rem;
            transition: all 0.3s ease;
            z-index: 2;
            pointer-events: none;
            width: 20px;
            text-align: center;
        }

        .input-group-modern:focus-within .input-icon {
            color: var(--primary-green);
            transform: translateY(-50%) scale(1.15);
        }

        .input-group-modern .form-control {
            border: 2px solid #eaf0e2;
            border-radius: var(--radius-sm);
            padding: 0.75rem 1rem 0.75rem 3.2rem;
            background: #fafff8;
            transition: all 0.35s ease;
            font-size: 0.95rem;
            width: 100%;
            height: 56px;
            color: #1a2a0e;
            box-shadow: 0 2px 8px rgba(0,0,0,0.02);
            font-weight: 500;
        }

            .input-group-modern .form-control::placeholder {
                color: #b8c8a8;
                font-size: 0.9rem;
                font-weight: 400;
            }

            .input-group-modern .form-control:focus {
                border-color: var(--primary-green);
                box-shadow: 0 0 0 6px rgba(136,210,0,0.06), 0 4px 16px rgba(0,0,0,0.02);
                outline: none;
                background: white;
                transform: translateY(-1px);
            }

            .input-group-modern .form-control:hover {
                border-color: var(--light-green);
                background: #fcfff8;
            }

        /* Check mark shown once a field is validated */
        .input-group-modern .valid-check {
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%) scale(0.5);
            color: var(--primary-green);
            font-size: 1rem;
            opacity: 0;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            pointer-events: none;
        }

        .input-group-modern .form-control.input-valid ~ .valid-check {
            opacity: 1;
            transform: translateY(-50%) scale(1);
        }

        /* Floating label for modern input */
        .input-group-modern.floating .form-control {
            padding-top: 1.3rem;
            padding-bottom: 0.2rem;
            height: 64px;
        }

        .input-group-modern.floating .floating-label {
            position: absolute;
            left: 3.2rem;
            top: 50%;
            transform: translateY(-50%);
            color: #a0b898;
            font-size: 0.9rem;
            transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            pointer-events: none;
            background: transparent;
            padding: 0 4px;
            z-index: 1;
            font-weight: 500;
        }

        /*
               FIX: the label used to only float up based on the CSS-only
               `:not(:placeholder-shown)` trick. That breaks for the date input
               (browsers don't treat its native placeholder consistently) and can
               lag when JavaScript rewrites .val() programmatically (e.g. while
               auto-inserting spaces in the card number). We now also toggle a
               `.has-value` class from JS on every input/blur, and float the label
               whenever EITHER condition is true - so the placeholder text always
               gets out of the way the moment something is typed.
            */
        .input-group-modern.floating .form-control:focus + .floating-label,
        .input-group-modern.floating .form-control:not(:placeholder-shown) + .floating-label,
        .input-group-modern.floating .form-control.has-value + .floating-label {
            top: 4px;
            transform: translateY(0) scale(0.7);
            color: var(--primary-green);
            background: white;
            padding: 0 8px;
            left: 2.8rem;
            font-weight: 600;
            letter-spacing: 0.3px;
        }

        .input-group-modern.floating .form-control::placeholder {
            color: transparent;
        }

        /* Validation states */
        .input-group-modern .form-control.input-valid {
            border-color: var(--primary-green);
            background: #f7ffe8;
            box-shadow: 0 0 0 4px rgba(136,210,0,0.04);
        }

        .input-group-modern .form-control.input-invalid {
            border-color: #dc3545;
            background: #fff6f6;
            box-shadow: 0 0 0 4px rgba(220,53,69,0.04);
            animation: shakeError 0.4s ease;
        }

    @@keyframes shakeError {
        0%, 100% {
            transform: translateX(0);
        }

        20% {
            transform: translateX(-8px);
        }

        40% {
            transform: translateX(8px);
        }

        60% {
            transform: translateX(-4px);
        }

        80% {
            transform: translateX(4px);
        }
    }

    /* Error messages */
    .text-danger, .field-validation-error {
        color: #dc3545;
        font-size: 0.75rem;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 6px;
        margin-top: 0.4rem;
        padding: 0.2rem 1rem;
        border-radius: 50px;
        background: #fff5f5;
        border-left: 3px solid #dc3545;
        transition: all 0.35s ease;
        max-height: 0;
        opacity: 0;
        overflow: hidden;
    }

        .text-danger.show-error, .field-validation-error.show-error {
            max-height: 60px;
            opacity: 1;
            padding: 0.3rem 1rem;
            animation: slideDown 0.35s ease;
        }

    @@keyframes slideDown {
        0% {
            max-height: 0;
            opacity: 0;
            transform: translateY(-8px);
        }

        100% {
            max-height: 60px;
            opacity: 1;
            transform: translateY(0);
        }
    }

    .text-danger i, .field-validation-error i {
        font-size: 0.7rem;
        color: #dc3545;
    }

    .text-danger:empty, .field-validation-error:empty {
        display: none;
    }

    /* Validation summary */
    .validation-summary-errors {
        color: #dc3545;
        background: #fff5f5;
        border-radius: var(--radius-sm);
        padding: 0.5rem 1rem;
        margin-bottom: 1rem;
        border-left: 4px solid #dc3545;
        font-size: 0.85rem;
    }

    /* Submit Button */
    .btn-submit {
        background: linear-gradient(135deg, var(--primary-green), var(--dark-green));
        border: none;
        border-radius: var(--radius-sm);
        padding: 0.9rem 2.5rem;
        font-weight: 700;
        font-size: 1rem;
        color: white;
        box-shadow: 0 8px 28px rgba(136,210,0,0.3);
        transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 14px;
        height: 56px;
        position: relative;
        overflow: hidden;
        letter-spacing: 0.5px;
    }

        .btn-submit::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 60%);
            animation: shimmerBtn 4s ease-in-out infinite;
            pointer-events: none;
        }

    @@keyframes shimmerBtn {
        0% {
            transform: translateX(-100%) rotate(45deg);
        }

        100% {
            transform: translateX(100%) rotate(45deg);
        }
    }

    .btn-submit:hover:not(:disabled) {
        background: linear-gradient(135deg, #7ac000, #5f9600);
        transform: translateY(-3px);
        box-shadow: 0 12px 40px rgba(136,210,0,0.4);
    }

    .btn-submit:active:not(:disabled) {
        transform: scale(0.97);
    }

    .btn-submit:disabled {
        background: #c0d8a8;
        box-shadow: none;
        opacity: 0.6;
        cursor: not-allowed;
        transform: none;
    }

        .btn-submit:disabled::after {
            display: none;
        }

    .btn-submit i {
        font-size: 1rem;
        transition: transform 0.3s ease;
    }

    .btn-submit:hover:not(:disabled) i {
        transform: translateX(4px);
    }

    .btn-submit .spinner {
