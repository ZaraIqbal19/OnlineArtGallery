        }

    .modal.show .confetti-piece {
        animation: confettiFall 1.6s ease-in forwards;
    }

        .modal.show .confetti-piece:nth-child(1) {
            animation-delay: 0.05s;
        }

        .modal.show .confetti-piece:nth-child(2) {
            animation-delay: 0.15s;
        }

        .modal.show .confetti-piece:nth-child(3) {
            animation-delay: 0.02s;
        }

        .modal.show .confetti-piece:nth-child(4) {
            animation-delay: 0.22s;
        }

        .modal.show .confetti-piece:nth-child(5) {
            animation-delay: 0.10s;
        }

        .modal.show .confetti-piece:nth-child(6) {
            animation-delay: 0.30s;
        }

        .modal.show .confetti-piece:nth-child(7) {
