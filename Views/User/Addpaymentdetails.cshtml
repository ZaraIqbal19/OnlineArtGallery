        }

    /* ===================== Success Modal (enhanced) ===================== */
    .success-modal-content {
        border-radius: var(--radius-xl);
        border: none;
        box-shadow: 0 40px 100px rgba(0,0,0,0.16);
        background: white;
        overflow: hidden;
