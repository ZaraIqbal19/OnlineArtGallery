    /* insight cards */
    .seller-page .insight-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
    }

    .seller-page .insight-item {
        background: #f9fdf2;
        border: 1px solid rgba(136,210,0,0.14);
        border-radius: 16px;
        padding: 16px;
        display: flex;
        align-items: flex-start;
        gap: 12px;
        transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
    }

        .seller-page .insight-item:nth-child(1) {
            animation-delay: 0.05s;
        }

        .seller-page .insight-item:nth-child(2) {
            animation-delay: 0.12s;
        }

        .seller-page .insight-item:nth-child(3) {
            animation-delay: 0.19s;
        }

        .seller-page .insight-item:nth-child(4) {
            animation-delay: 0.26s;
        }

        .seller-page .insight-item:nth-child(5) {
            animation-delay: 0.33s;
        }

        .seller-page .insight-item:nth-child(6) {
            animation-delay: 0.40s;
        }

        .seller-page .insight-item:hover {
            transform: translateY(-5px);
            background: #fff;
            box-shadow: 0 18px 32px -16px rgba(136,210,0,0.35);
        }

    .seller-page .insight-icon {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: linear-gradient(135deg, #88d200, #6fa800);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.05rem;
        flex-shrink: 0;
        box-shadow: 0 8px 16px rgba(136,210,0,0.3);
        transition: transform 0.3s ease;
    }

    .seller-page .insight-item:hover .insight-icon {
        transform: scale(1.1) rotate(6deg);
    }

    .seller-page .insight-label {
        font-size: 0.68rem;
        font-weight: 700;
        color: #5c7a2e;
        text-transform: uppercase;
        letter-spacing: 0.4px;
    }

    .seller-page .insight-value {
        font-size: 0.95rem;
        font-weight: 800;
        color: #1a1a1a;
        margin-top: 2px;
        line-height: 1.3;
        word-break: break-word;
    }

    .seller-page .insight-sub {
        font-size: 0.72rem;
        color: #9ab569;
        font-weight: 600;
        margin-top: 2px;
    }

    /* charts */
    .seller-page .chart-wrap {
        position: relative;
        height: 240px;
    }

        .seller-page .chart-wrap.small {
            height: 210px;
        }

    .seller-page .chart-legend-row {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
        margin-top: 14px;
        justify-content: center;
    }

    .seller-page .chart-legend-item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.74rem;
        font-weight: 700;
        color: #5c7a2e;
        transition: transform 0.2s ease;
    }

        .seller-page .chart-legend-item:hover {
            transform: translateY(-2px);
        }

    .seller-page .chart-legend-dot {
        width: 9px;
        height: 9px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    /* tables */
    .seller-page .table-wrap {
        overflow-x: auto;
        width: 100%;
    }

    .seller-page table.seller-table {
        width: 100%;
        min-width: 480px;
        border-collapse: collapse;
        font-size: 0.85rem;
    }

        .seller-page table.seller-table thead th {
            text-align: left;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            color: #5c7a2e;
            background: #f0fae6;
            padding: 10px 12px;
            white-space: nowrap;
            position: sticky;
            top: 0;
        }

            .seller-page table.seller-table thead th:first-child {
                border-radius: 10px 0 0 10px;
            }

            .seller-page table.seller-table thead th:last-child {
                border-radius: 0 10px 10px 0;
            }

        .seller-page table.seller-table tbody td {
            padding: 11px 12px;
            border-bottom: 1px solid rgba(136,210,0,0.1);
            color: #1a1a1a;
            font-weight: 600;
            white-space: nowrap;
            max-width: 260px;
            overflow: hidden;
            text-overflow: ellipsis;
            transition: color 0.2s ease;
        }

        .seller-page table.seller-table tbody tr {
            transition: background 0.25s ease, transform 0.2s ease, box-shadow 0.25s ease;
            animation: fadeInUp 0.4s ease both;
        }

            .seller-page table.seller-table tbody tr:nth-child(1) {
                animation-delay: 0.03s;
            }

            .seller-page table.seller-table tbody tr:nth-child(2) {
                animation-delay: 0.06s;
            }

            .seller-page table.seller-table tbody tr:nth-child(3) {
                animation-delay: 0.09s;
            }

            .seller-page table.seller-table tbody tr:nth-child(4) {
                animation-delay: 0.12s;
            }

            .seller-page table.seller-table tbody tr:nth-child(5) {
                animation-delay: 0.15s;
            }

            .seller-page table.seller-table tbody tr:nth-child(n+6) {
                animation-delay: 0.18s;
            }

            .seller-page table.seller-table tbody tr:hover {
                background: #f9fdf2;
                box-shadow: inset 3px 0 0 #88d200;
                transform: translateX(2px);
            }

    .seller-page .badge-status {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.72rem;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: 40px;
        transition: transform 0.2s ease;
    }

    .seller-page table.seller-table tbody tr:hover .badge-status {
        transform: scale(1.06);
    }

    .seller-page .badge-status.pending {
        background: #fdf3d9;
        color: #b8860b;
        animation: pulseSoft 1.8s ease-in-out infinite;
    }

    .seller-page .badge-status.processing {
        background: #e3edfb;
        color: #1a5fa5;
    }

    .seller-page .badge-status.dispatched {
        background: #f0e9fe;
        color: #8a5cf6;
    }

    .seller-page .badge-status.delivered {
        background: #eaf7d6;
        color: #4c7800;
    }

    .seller-page .badge-status.cancelled {
        background: #fdeaea;
        color: #a51b1b;
    }

    .seller-page .empty-note {
        font-size: 0.85rem;
        color: #9ab569;
        font-weight: 600;
        padding: 20px 0;
        text-align: center;
    }

    @@media (max-width: 900px) {
        .seller-page .cards-row-2, .seller-page .quick-stats {
            grid-template-columns: 1fr 1fr;
        }

        .seller-page .acct-grid, .seller-page .insight-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media (max-width: 576px) {
        .seller-page .user-card {
            padding: 1.2rem;
        }

        .seller-page .cards-row-2, .seller-page .quick-stats, .seller-page .info-grid, .seller-page .acct-grid, .seller-page .insight-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="seller-page">
    <div class="container-cust">

        <!-- identity -->
        <div class="user-card fade-in">
            <div class="identity-row">
                <div class="avatar-circle">
                    @(string.IsNullOrEmpty(seller?.UserName) ? "?" : seller.UserName.Substring(0, 1).ToUpper())
                    <span class="status-ring" title="Active"></span>
                </div>
                <div>
                    <h1 class="identity-name">@seller?.UserName</h1>
                    <div class="identity-email">@seller?.Email</div>
                    <div class="identity-badges">
                        <span class="id-badge"><i class="fas fa-box"></i> @ViewBag.TotalProducts products</span>
                        <span class="id-badge"><i class="fas fa-shopping-bag"></i> @ViewBag.TotalOrders orders</span>
                        <span class="id-badge"><i class="fas fa-gavel"></i> @ViewBag.TotalBids bids</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- quick stats -->
        <div class="quick-stats">
            <div class="qs-item fade-in">
                <div class="qs-icon"><i class="fas fa-coins"></i></div>
                <div>
                    <div class="qs-label">Total Revenue</div>
                    <div class="qs-value">Rs. @ViewBag.TotalRevenue</div>
                </div>
            </div>
            <div class="qs-item fade-in">
                <div class="qs-icon"><i class="fas fa-cubes"></i></div>
                <div>
                    <div class="qs-label">Items Sold</div>
                    <div class="qs-value">@ViewBag.TotalItemsSold</div>
                </div>
            </div>
            <div class="qs-item fade-in">
                <div class="qs-icon"><i class="fas fa-receipt"></i></div>
                <div>
                    <div class="qs-label">Total Orders</div>
                    <div class="qs-value">@ViewBag.TotalOrders</div>
                </div>
            </div>
            <div class="qs-item fade-in">
                <div class="qs-icon"><i class="fas fa-chart-line"></i></div>
                <div>
                    <div class="qs-label">Avg Order Value</div>
                    <div class="qs-value">Rs. @(string.Format("{0:0.##}", ViewBag.AverageOrderValue))</div>
                </div>
            </div>
        </div>

        <!-- revenue trend + order status charts -->
        <div class="cards-row-2">
            <div class="sub-card fade-in">
                <div class="section-title">
                    <i class="fas fa-chart-area"></i> Revenue Trend (6 mo)
                    <span class="trend-badge @(isGrowthPositive ? "up" : "down")">
                        @(isGrowthPositive ? "▲" : "▼") @(string.Format("{0:0.#}", Math.Abs(growthPct)))% vs last mo
                    </span>
                </div>
                @if (revenueLabels.Count > 0)
                {
                    <div class="chart-wrap">
                        <canvas id="revenueTrendChart"></canvas>
                    </div>
                }
                else
                {
                    <div class="empty-note">No sales in the last 6 months yet.</div>
                }
            </div>

            <div class="sub-card fade-in">
                <div class="section-title"><i class="fas fa-tasks"></i> Order Status Breakdown</div>
                @{
                    int total = ViewBag.TotalSales > 0 ? ViewBag.TotalSales : 1;
                    var statuses = new (string label, string css, int count)[]
                    {
                                ("Pending", "pending", pendingSalesCount),
                                ("Processing", "processing", processingSalesCount),
                                ("Dispatched", "dispatched", dispatchedSalesCount),
                                ("Delivered", "delivered", deliveredSalesCount),
                                ("Cancelled", "cancelled", cancelledSalesCount)
                    };
                }
                @if (totalSalesCount > 0)
                {
                    <div class="chart-wrap small">
                        <canvas id="orderStatusChart"></canvas>
                    </div>
                    <div class="chart-legend-row">
                        @foreach (var s in statuses)
                        {
                            <div class="chart-legend-item"><span class="chart-legend-dot dot-@s.css"></span>@s.label (@s.count)</div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-note">No orders received yet.</div>
                }
            </div>
        </div>

        <div class="cards-row-2">
            <!-- product analytics -->
            <div class="sub-card fade-in">
                <div class="section-title"><i class="fas fa-boxes-stacked"></i> Product Analytics</div>
                <div class="info-grid">
                    <div class="info-row"><span class="k">Total Products</span><span class="v">@ViewBag.TotalProducts</span></div>
                    <div class="info-row"><span class="k">Available</span><span class="v">@ViewBag.AvailableProducts</span></div>
                    <div class="info-row"><span class="k">Out of Stock</span><span class="v">@ViewBag.OutOfStock</span></div>
                    <div class="info-row"><span class="k">Total Stock</span><span class="v">@ViewBag.TotalStock</span></div>
                </div>
            </div>

            <!-- sales insights -->
            <div class="sub-card fade-in">
                <div class="section-title"><i class="fas fa-chart-simple"></i> Sales Insights</div>
                <div class="info-grid">
                    <div class="info-row"><span class="k">Highest Sale</span><span class="v">Rs. @ViewBag.HighestSale</span></div>
                    <div class="info-row"><span class="k">Lowest Sale</span><span class="v">Rs. @ViewBag.LowestSale</span></div>
                    <div class="info-row"><span class="k">First Sale</span><span class="v">@(ViewBag.FirstSale != null ? ((DateTime)ViewBag.FirstSale).ToString("dd MMM yyyy") : "—")</span></div>
                    <div class="info-row"><span class="k">Last Sale</span><span class="v">@(ViewBag.LastSale != null ? ((DateTime)ViewBag.LastSale).ToString("dd MMM yyyy") : "—")</span></div>
                </div>
                <div class="split-row" style="margin-top:14px;">
                    <div class="split-box"><div class="sv">@ViewBag.CardPayments</div><div class="sl">Card</div></div>
                    <div class="split-box"><div class="sv">@ViewBag.CODPayments</div><div class="sl">COD</div></div>
                    <div class="split-box"><div class="sv">@ViewBag.TotalCustomers</div><div class="sl">Customers</div></div>
                    <div class="split-box"><div class="sv">@ViewBag.RepeatCustomers</div><div class="sl">Repeat</div></div>
                </div>
            </div>
        </div>

        <!-- top products + payment split charts -->
        <div class="cards-row-2">
            <div class="sub-card fade-in">
                <div class="section-title"><i class="fas fa-trophy"></i> Top 5 Products by Units Sold</div>
                @if (topProductChartLabels.Count > 0)
                {
                    <div class="chart-wrap">
                        <canvas id="topProductsChart"></canvas>
                    </div>
                }
                else
                {
                    <div class="empty-note">No sales yet.</div>
                }
            </div>

            <div class="sub-card fade-in">
                <div class="section-title"><i class="fas fa-credit-card"></i> Payment Method Split</div>
                @if (cardPaymentsCount + codPaymentsCount > 0)
                {
                    <div class="chart-wrap small">
                        <canvas id="paymentSplitChart"></canvas>
                    </div>
                    <div class="chart-legend-row">
                        <div class="chart-legend-item"><span class="chart-legend-dot" style="background:#88d200;"></span>Card (@cardPaymentsCount)</div>
                        <div class="chart-legend-item"><span class="chart-legend-dot" style="background:#1a5fa5;"></span>COD (@codPaymentsCount)</div>
                    </div>
                }
                else
                {
                    <div class="empty-note">No payments recorded yet.</div>
                }
            </div>
        </div>

        <!-- bidding analytics -->
        <div class="sub-card fade-in" style="margin-bottom:1.4rem;">
            <div class="section-title"><i class="fas fa-gavel"></i> Bidding Analytics</div>
            <div class="info-grid">
                <div class="info-row"><span class="k">Total Bids</span><span class="v">@ViewBag.TotalBidsReceived</span></div>
                <div class="info-row"><span class="k">Unique Bidders</span><span class="v">@ViewBag.UniqueBidders</span></div>
                <div class="info-row"><span class="k">Highest Bid</span><span class="v">Rs. @ViewBag.HighestBid</span></div>
                <div class="info-row"><span class="k">Average Bid</span><span class="v">Rs. @(string.Format("{0:0.##}", ViewBag.AverageBid))</span></div>
            </div>
        </div>

        <!-- more insights -->
        <div class="sub-card fade-in" style="margin-bottom:1.4rem;">
            <div class="section-title"><i class="fas fa-lightbulb"></i> More Insights</div>
            <div class="insight-grid">
                <div class="insight-item fade-in">
                    <div class="insight-icon"><i class="fas fa-crown"></i></div>
                    <div>
                        <div class="insight-label">Top Selling Product</div>
                        <div class="insight-value">@topProductName</div>
                        <div class="insight-sub">@topProductQty units sold</div>
                    </div>
                </div>
                <div class="insight-item fade-in">
                    <div class="insight-icon"><i class="fas fa-fire"></i></div>
                    <div>
                        <div class="insight-label">Most Bid-On Product</div>
                        <div class="insight-value">@topBidProductName</div>
                        <div class="insight-sub">@topBidProductCount bids received</div>
                    </div>
                </div>
                <div class="insight-item fade-in">
                    <div class="insight-icon"><i class="fas fa-star"></i></div>
                    <div>
                        <div class="insight-label">Top Bidder</div>
                        <div class="insight-value">@topBidderName</div>
                        <div class="insight-sub">@topBidderCount bids placed</div>
                    </div>
                </div>
                <div class="insight-item fade-in">
                    <div class="insight-icon"><i class="fas fa-layer-group"></i></div>
                    <div>
                        <div class="insight-label">Avg Items / Order</div>
                        <div class="insight-value">@(string.Format("{0:0.##}", avgItemsPerOrder))</div>
                        <div class="insight-sub">items per order on average</div>
                    </div>
                </div>
                <div class="insight-item fade-in">
                    <div class="insight-icon"><i class="fas fa-percent"></i></div>
                    <div>
                        <div class="insight-label">Bid-to-Sale Ratio</div>
                        <div class="insight-value">@(string.Format("{0:0.##}", bidToSaleRatio)) : 1</div>
                        <div class="insight-sub">bids received per sale</div>
                    </div>
                </div>
                <div class="insight-item fade-in">
                    <div class="insight-icon"><i class="fas fa-triangle-exclamation"></i></div>
                    <div>
                        <div class="insight-label">Low Stock Alert</div>
                        <div class="insight-value">@lowStockCount product(s)</div>
                        <div class="insight-sub">5 units or fewer remaining</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- this week / last month -->
        <div class="sub-card fade-in" style="margin-bottom:1.4rem;">
            <div class="section-title"><i class="fas fa-calendar-days"></i> Performance Snapshot</div>
            <div class="acct-grid">
                <div class="acct-item">
                    <div class="ai-icon"><i class="fas fa-cart-shopping"></i></div>
                    <div class="ai-label">This Week Sales</div>
                    <div class="ai-value">@ViewBag.ThisWeekSales</div>
                </div>
                <div class="acct-item">
                    <div class="ai-icon"><i class="fas fa-sack-dollar"></i></div>
                    <div class="ai-label">This Week Revenue</div>
                    <div class="ai-value">Rs. @ViewBag.ThisWeekRevenue</div>
                    <span class="trend-chip @(isGrowthPositive ? "up" : "down")">
                        <i class="fas @(isGrowthPositive ? "fa-arrow-up" : "fa-arrow-down")"></i>
                        @(string.Format("{0:0.#}", Math.Abs(growthPct)))% vs last month
                    </span>
                </div>
                <div class="acct-item">
                    <div class="ai-icon"><i class="fas fa-cart-shopping"></i></div>
                    <div class="ai-label">Last Month Sales</div>
                    <div class="ai-value">@ViewBag.LastMonthSales</div>
                </div>
                <div class="acct-item">
                    <div class="ai-icon"><i class="fas fa-sack-dollar"></i></div>
                    <div class="ai-label">Last Month Revenue</div>
                    <div class="ai-value">Rs. @ViewBag.LastMonthRevenue</div>
                </div>
            </div>
        </div>

        <!-- products table -->
        <div class="sub-card fade-in" style="margin-bottom:1.4rem;">
            <div class="section-title"><i class="fas fa-box-open"></i> My Products <small>@ViewBag.TotalProducts total</small></div>
            <div class="table-wrap">
                @if (productsList.Any())
                {
                    <table class="seller-table">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Category</th>
                                <th>Quantity</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in productsList)
                            {
                                <tr>
                                    <td>@p.Name</td>
                                    <td>@(p.SubCategory != null ? p.SubCategory.Name : "—")</td>
                                    <td>@p.quantity</td>
                                    <td>
                                        @if ((int)p.quantity == 0)
                                        {
                                            <span class="badge-status cancelled">Out of Stock</span>
                                        }
                                        else if ((int)p.quantity <= 5)
                                        {
                                            <span class="badge-status pending">Low Stock</span>
                                        }
                                        else
                                        {
                                            <span class="badge-status delivered">In Stock</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-note">No products uploaded yet.</div>
                }
            </div>
        </div>

        <!-- recent orders -->
        <div class="sub-card fade-in" style="margin-bottom:1.4rem;">
            <div class="section-title"><i class="fas fa-clock-rotate-left"></i> Recent Orders</div>
            <div class="table-wrap">
                @if (ordersList.Any())
                {
                    <table class="seller-table">
                        <thead>
                            <tr>
                                <th>Customer</th>
                                <th>Product</th>
                                <th>Qty</th>
                                <th>Price</th>
                                <th>Status</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var o in ordersList.OrderByDescending(x => x.OrderDate).Take(10))
                            {
                                string statusCss = ((string)o.Status ?? "pending").ToLower();
                                <tr>
                                    <td>@(o.User != null ? o.User.UserName : "—")</td>
                                    <td>@(o.Product != null ? o.Product.Name : "—")</td>
                                    <td>@o.Quantity</td>
                                    <td>Rs. @o.PricePaid</td>
                                    <td><span class="badge-status @statusCss">@o.Status</span></td>
                                    <td>@(((DateTime)o.OrderDate).ToString("dd MMM yyyy"))</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-note">No orders received yet.</div>
                }
            </div>
        </div>

        <!-- recent bids -->
        <div class="sub-card fade-in">
            <div class="section-title"><i class="fas fa-gavel"></i> Recent Bids</div>
            <div class="table-wrap">
                @if (bidsList.Any())
                {
                    <table class="seller-table">
                        <thead>
                            <tr>
                                <th>Bidder</th>
                                <th>Product</th>
                                <th>Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var b in bidsList.Take(10))
                            {
                                <tr>
                                    <td>@(b.User != null ? b.User.UserName : "—")</td>
                                    <td>@(b.Product != null ? b.Product.Name : "—")</td>
                                    <td>Rs. @b.bidamount</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-note">No bids placed yet.</div>
                }
            </div>
        </div>

    </div>
</div>

<script>
    (function () {
        Chart.defaults.font.family = "'Inter','Segoe UI',Roboto,system-ui,sans-serif";

        @if (revenueLabels.Count > 0)
        {
                <text>
                const revenueCtx = document.getElementById('revenueTrendChart');
                if (revenueCtx) {
                    new Chart(revenueCtx, {
                        type: 'line',
                        data: {
                            labels: [@Html.Raw(string.Join(",", revenueLabels.Select(l => $"'{l.Replace("'", "\\'")}'")))],
                            datasets: [{
                                label: 'Revenue (Rs.)',
                                data: [@Html.Raw(string.Join(",", revenueValues.Select(v => v.ToString(System.Globalization.CultureInfo.InvariantCulture))))],
                                borderColor: '#88d200',
                                backgroundColor: 'rgba(136,210,0,0.12)',
                                pointBackgroundColor: '#6fa800',
                                borderWidth: 2.5,
                                tension: 0.35,
                                fill: true
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: { legend: { display: false } },
                            scales: {
                                y: { beginAtZero: true, grid: { color: 'rgba(136,210,0,0.08)' } },
                                x: { grid: { display: false } }
                            }
                        }
                    });
                }
                </text>
        }

        @if (totalSalesCount > 0)
        {
                <text>
                const statusCtx = document.getElementById('orderStatusChart');
                if (statusCtx) {
                    new Chart(statusCtx, {
                        type: 'doughnut',
                        data: {
                            labels: ['Pending', 'Processing', 'Dispatched', 'Delivered', 'Cancelled'],
                            datasets: [{
                                data: [@pendingSalesCount, @processingSalesCount, @dispatchedSalesCount, @deliveredSalesCount, @cancelledSalesCount],
                                backgroundColor: ['#f0a500', '#1a5fa5', '#8a5cf6', '#6fa800', '#dc3545'],
                                borderWidth: 2,
                                borderColor: '#fff'
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            cutout: '68%',
                            plugins: { legend: { display: false } }
                        }
                    });
                }
                </text>
        }

        @if (topProductChartLabels.Count > 0)
        {
                <text>
                const topProductsCtx = document.getElementById('topProductsChart');
                if (topProductsCtx) {
                    new Chart(topProductsCtx, {
                        type: 'bar',
                        data: {
                            labels: [@Html.Raw(string.Join(",", topProductChartLabels.Select(l => $"'{l.Replace("'", "\\'")}'")))],
                            datasets: [{
                                label: 'Units Sold',
                                data: [@Html.Raw(string.Join(",", topProductChartValues))],
                                backgroundColor: '#88d200',
                                borderRadius: 8,
                                maxBarThickness: 42
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: { legend: { display: false } },
                            scales: {
                                y: { beginAtZero: true, ticks: { precision: 0 }, grid: { color: 'rgba(136,210,0,0.08)' } },
                                x: { grid: { display: false } }
                            }
                        }
                    });
                }
                </text>
        }

        @if (cardPaymentsCount + codPaymentsCount > 0)
        {
                <text>
                const paymentCtx = document.getElementById('paymentSplitChart');
                if (paymentCtx) {
                    new Chart(paymentCtx, {
                        type: 'doughnut',
                        data: {
                            labels: ['Card', 'Cash on Delivery'],
                            datasets: [{
                                data: [@cardPaymentsCount, @codPaymentsCount],
                                backgroundColor: ['#88d200', '#1a5fa5'],
                                borderWidth: 2,
                                borderColor: '#fff'
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            cutout: '68%',
                            plugins: { legend: { display: false } }
                        }
                    });
                }
                </text>
        }
    })();
</script>
