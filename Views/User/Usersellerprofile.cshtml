@using System.Linq
@{
    ViewData["Title"] = "Seller Dashboard";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
    var seller = ViewBag.Seller;
    var products = ViewBag.Products;
    var orders = ViewBag.Orders;
    var bids = ViewBag.Bids;

    var productsList = products != null ? ((IEnumerable<dynamic>)products).ToList() : new List<dynamic>();
    var ordersList = orders != null ? ((IEnumerable<dynamic>)orders).ToList() : new List<dynamic>();
    var bidsList = bids != null ? ((IEnumerable<dynamic>)bids).ToList() : new List<dynamic>();

    // --- extra analytics computed on the view side ---
    var productQty = new Dictionary<string, int>();
    var productBidCount = new Dictionary<string, int>();
    var bidderCount = new Dictionary<string, int>();

    foreach (var o in ordersList)
    {
        string pname = (string)(o.Product != null ? o.Product.Name : null) ?? "Unknown";
        int qty = (int)o.Quantity;
        if (!productQty.ContainsKey(pname)) { productQty[pname] = 0; }
        productQty[pname] += qty;
    }

    foreach (var b in bidsList)
    {
        string pname = (string)(b.Product != null ? b.Product.Name : null) ?? "Unknown";
        if (!productBidCount.ContainsKey(pname)) { productBidCount[pname] = 0; }
        productBidCount[pname] += 1;

        string bidder = (string)(b.User != null ? b.User.UserName : null) ?? "Unknown";
        if (!bidderCount.ContainsKey(bidder)) { bidderCount[bidder] = 0; }
        bidderCount[bidder] += 1;
    }

    string topProductName = productQty.Any() ? productQty.OrderByDescending(x => x.Value).First().Key : "—";
    int topProductQty = productQty.Any() ? productQty.OrderByDescending(x => x.Value).First().Value : 0;

    string topBidProductName = productBidCount.Any() ? productBidCount.OrderByDescending(x => x.Value).First().Key : "—";
    int topBidProductCount = productBidCount.Any() ? productBidCount.OrderByDescending(x => x.Value).First().Value : 0;

    string topBidderName = bidderCount.Any() ? bidderCount.OrderByDescending(x => x.Value).First().Key : "—";
    int topBidderCount = bidderCount.Any() ? bidderCount.OrderByDescending(x => x.Value).First().Value : 0;

    int totalOrdersCount = ViewBag.TotalOrders != null ? (int)ViewBag.TotalOrders : 0;
    int totalItemsSoldCount = ViewBag.TotalItemsSold != null ? (int)ViewBag.TotalItemsSold : 0;
    double avgItemsPerOrder = totalOrdersCount > 0 ? (double)totalItemsSoldCount / totalOrdersCount : 0;

    int totalBidsCount = ViewBag.TotalBidsReceived != null ? (int)ViewBag.TotalBidsReceived : 0;
    int totalSalesCount = ViewBag.TotalSales != null ? (int)ViewBag.TotalSales : 0;
    double bidToSaleRatio = totalSalesCount > 0 ? (double)totalBidsCount / totalSalesCount : 0;

    int lowStockCount = productsList.Count(p => (int)p.quantity > 0 && (int)p.quantity <= 5);

    decimal thisWeekRevenue = ViewBag.ThisWeekRevenue != null ? Convert.ToDecimal(ViewBag.ThisWeekRevenue) : 0m;
    decimal lastMonthRevenue = ViewBag.LastMonthRevenue != null ? Convert.ToDecimal(ViewBag.LastMonthRevenue) : 0m;
    decimal weeklyAvgLastMonth = lastMonthRevenue > 0 ? lastMonthRevenue / 4m : 0m;
    decimal growthPct = weeklyAvgLastMonth > 0 ? ((thisWeekRevenue - weeklyAvgLastMonth) / weeklyAvgLastMonth) * 100m : 0m;
    bool isGrowthPositive = growthPct >= 0;

    // ---- chart datasets (computed from the same lists above, no controller changes needed) ----

    // Revenue trend, last 6 months
    var sixMonthsAgo = DateTime.Now.AddMonths(-5).Date;
    var monthlyRevenueGroups = ordersList
        .Select(o => new { Date = (DateTime)o.OrderDate, Price = (decimal)o.PricePaid })
        .Where(x => x.Date >= sixMonthsAgo)
        .GroupBy(x => new { x.Date.Year, x.Date.Month })
        .OrderBy(g => g.Key.Year).ThenBy(g => g.Key.Month)
        .Select(g => new
        {
            Label = new DateTime(g.Key.Year, g.Key.Month, 1).ToString("MMM yyyy"),
            Total = g.Sum(x => x.Price)
        })
        .ToList();
    var revenueLabels = monthlyRevenueGroups.Select(x => x.Label).ToList();
    var revenueValues = monthlyRevenueGroups.Select(x => x.Total).ToList();

    // Order status doughnut
    int pendingSalesCount = ViewBag.PendingSales != null ? (int)ViewBag.PendingSales : 0;
    int processingSalesCount = ViewBag.ProcessingSales != null ? (int)ViewBag.ProcessingSales : 0;
    int dispatchedSalesCount = ViewBag.DispatchedSales != null ? (int)ViewBag.DispatchedSales : 0;
    int deliveredSalesCount = ViewBag.DeliveredSales != null ? (int)ViewBag.DeliveredSales : 0;
    int cancelledSalesCount = ViewBag.CancelledSales != null ? (int)ViewBag.CancelledSales : 0;

    // Top 5 products bar chart (reuses productQty computed above)
    var topProductsForChart = productQty.OrderByDescending(x => x.Value).Take(5).ToList();
    var topProductChartLabels = topProductsForChart.Select(x => x.Key).ToList();
    var topProductChartValues = topProductsForChart.Select(x => x.Value).ToList();

    // Payment split doughnut
    int cardPaymentsCount = ViewBag.CardPayments != null ? (int)ViewBag.CardPayments : 0;
    int codPaymentsCount = ViewBag.CODPayments != null ? (int)ViewBag.CODPayments : 0;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>

<style>
    html, body {
        overflow-x: hidden;
    }

    .seller-page {
        font-family: 'Inter', 'Segoe UI', Roboto, system-ui, sans-serif;
        padding: 1.5rem 0;
        overflow-x: hidden;
        background: radial-gradient(circle at 12% 0%, rgba(136, 210, 0, 0.06), transparent 45%), radial-gradient(circle at 100% 20%, rgba(136, 210, 0, 0.05), transparent 40%);
    }

        .seller-page *, .seller-page *::before, .seller-page *::after {
            box-sizing: border-box;
        }

        .seller-page .container-cust {
            max-width: 1200px;
            margin: 0 auto;
        }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(18px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes pulseRing {
        0% {
            box-shadow: 0 0 0 0 rgba(46,204,113,0.55);
        }

        70% {
            box-shadow: 0 0 0 8px rgba(46,204,113,0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(46,204,113,0);
        }
    }

    @@keyframes pulseSoft {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: 0.55;
        }
    }

    @@keyframes shineMove {
        0% {
            background-position: 0% 50%;
        }

        100% {
            background-position: 200% 50%;
        }
    }

    @@keyframes countBar {
        from {
            width: 0;
        }
    }

    @@keyframes floatSlow {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-4px);
        }
    }

    .seller-page .fade-in {
        animation: fadeInUp 0.55s ease both;
    }

    .seller-page .user-card {
        background: rgba(255,255,255,0.97);
        border-radius: 2rem;
        padding: 2rem 1.8rem 1.8rem;
        box-shadow: 0 20px 45px -16px rgba(111,168,0,0.22), 0 4px 18px rgba(136,210,0,0.06);
        border: 1px solid rgba(136,210,0,0.12);
        position: relative;
        overflow: hidden;
        margin-bottom: 1.4rem;
        transition: box-shadow 0.3s ease;
    }

        .seller-page .user-card:hover {
