            background: rgba(255,255,255,0.12);
            width: 42px;
            height: 42px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            border: none;
            transition: background 0.2s;
        }

            .bid-detail-page .lightbox-close:hover {
                background: rgba(255,255,255,0.25);
            }

    @@keyframes lbFadeInB {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@media (max-width: 900px) {
        .bid-detail-page .hero-grid, .bid-detail-page .cards-row {
            grid-template-columns: 1fr;
        }

        .bid-detail-page .info-grid, .bid-detail-page .quick-stats {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media (max-width: 576px) {
        .bid-detail-page .user-card {
            padding: 1.2rem;
        }

        .bid-detail-page .header-section {
            flex-direction: column;
            align-items: start;
        }

        .bid-detail-page .quick-stats, .bid-detail-page .info-grid {
            grid-template-columns: 1fr;
        }

        .bid-detail-page .position-rank {
            margin-left: 0;
        }
    }
</style>

<div class="bid-detail-page">
    <div class="container-cust">

        <div class="breadcrumb-strip">
            <a asp-action="Userallbids">My Bids</a>
            <i class="fas fa-chevron-right"></i>
            <span>Bid #@Model.Id</span>
        </div>

        <!-- header -->
        <div class="user-card">
            <div class="header-section">
                <div class="brand-head">
                    <div class="brand-icon"><i class="fas fa-gavel"></i></div>
                    <div>
                        <h1 class="heading-green">Bid Details</h1>
                        <div class="heading-sub">Bid #@Model.Id &middot; @Model.Product?.Name</div>
                    </div>
                </div>
                <a asp-action="MyBids" class="btn-action btn-back-a">
                    <i class="fas fa-arrow-left"></i> Back to My Bids
                </a>
            </div>

            <!-- position banner -->
            <div class="position-banner @(isHighest ? "leading" : "outbid")">
                <div class="position-icon">
                    <i class="fas @(isHighest ? "fa-crown" : "fa-arrow-trend-up")"></i>
                </div>
                <div>
                    <div class="position-title">@(isHighest ? "You're the Highest Bidder!" : "You've Been Outbid")</div>
                    <div class="position-desc">
                        @if (isHighest)
                        {
                            <span>You're currently leading this auction at Rs. @Model.bidamount</span>
                        }
                        else
                        {
                            <span>The current highest bid is Rs. @ViewBag.HighestBid — consider raising your bid</span>
                        }
                    </div>
                </div>
                <div class="position-rank">
                    <div class="pr-num">#@ViewBag.YourRank</div>
                    <div class="pr-label">Your Rank</div>
                </div>
            </div>

            <!-- hero -->
            <div class="hero-grid">
                <div>
                    <div class="gallery-main" id="galleryMain" onclick="openLightbox()">
                        @if (!string.IsNullOrEmpty(img1))
                        {
                            <img id="mainImg" src="~/images/products/@img1" alt="@Model.Product?.Name"
                                 onerror="handleImgError(this, 'no-img', 'fa-image', 'No image available')" />
                            @if (imageCount > 1)
                            {
                                <div class="img-count-badge"><i class="fas fa-images"></i> @imageCount</div>
                            }
                            <div class="zoom-hint"><i class="fas fa-search-plus"></i> Click to zoom</div>
                        }
                        else
                        {
                            <div class="no-img" id="mainImgFallback"><i class="fas fa-image"></i><span>No image available</span></div>
                        }
                    </div>
                    <div class="thumb-row">
                        @if (!string.IsNullOrEmpty(img1))
                        {
                            <div class="thumb-box active" onclick="event.stopPropagation(); switchMainImage('@Url.Content("~/images/products/" + img1)', this)">
                                <img src="~/images/products/@img1" />
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(img2))
                        {
                            <div class="thumb-box" onclick="event.stopPropagation(); switchMainImage('@Url.Content("~/images/products/" + img2)', this)">
                                <img src="~/images/products/@img2" />
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(img3))
                        {
                            <div class="thumb-box" onclick="event.stopPropagation(); switchMainImage('@Url.Content("~/images/products/" + img3)', this)">
                                <img src="~/images/products/@img3" />
                            </div>
                        }
                    </div>
                </div>

                <div class="summary-col">
                    <div>
                        <h2 class="product-title">@Model.Product?.Name</h2>
                    </div>

                    <div class="badge-row">
                        @{
                            var bidStatusClass = (Model.bidstatus ?? "").ToLower().Replace(" ", "-");
                        }
                        <span class="status-badge-row status-@bidStatusClass">
                            <i class="fas fa-circle" style="font-size:0.45rem;"></i> Status: @Model.bidstatus
                        </span>
                        <span class="status-badge-row status-@(isHighest ? "won" : "outbid")">
                            <i class="fas @(isHighest ? "fa-crown" : "fa-exclamation-triangle")" style="font-size:0.7rem;"></i>
                            @(isHighest ? "Highest Bidder" : "Outbid")
                        </span>
                    </div>

                    <div class="price-highlight">
                        <div class="price-box">
                            <div class="p-label">Your Bid</div>
                            <div class="p-value">Rs. @Model.bidamount</div>
                        </div>
                        <div class="price-box @(isHighest ? "" : "accent")">
                            <div class="p-label">Highest Bid</div>
                            <div class="p-value">Rs. @ViewBag.HighestBid</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- quick stats -->
        <div class="quick-stats">
            <div class="qs-item">
                <div class="qs-icon"><i class="fas fa-gavel"></i></div>
                <div>
                    <div class="qs-label">Total Bids</div>
                    <div class="qs-value">@ViewBag.TotalBids</div>
                </div>
            </div>
            <div class="qs-item">
                <div class="qs-icon"><i class="fas fa-ranking-star"></i></div>
                <div>
                    <div class="qs-label">Your Rank</div>
                    <div class="qs-value">#@ViewBag.YourRank</div>
                </div>
            </div>
            <div class="qs-item">
                <div class="qs-icon"><i class="fas fa-layer-group"></i></div>
                <div>
                    <div class="qs-label">Category</div>
                    <div class="qs-value">@(Model.Product?.SubCategory?.category?.Name ?? "—")</div>
                </div>
            </div>
        </div>

        <!-- product info + seller info -->
        <div class="cards-row">
            <div class="sub-card">
                <div class="section-title">
                    <div class="st-left"><i class="fas fa-box-open"></i> Product Information</div>
                </div>
                <div class="info-grid">
                    <div class="info-row" style="grid-column: 1 / -1;"><span class="k">Product</span><span class="v">@Model.Product?.Name</span></div>
                    <div class="info-row"><span class="k">Category</span><span class="v">@Model.Product?.SubCategory?.category?.Name</span></div>
                    <div class="info-row"><span class="k">Sub Category</span><span class="v">@Model.Product?.SubCategory?.Name</span></div>
                </div>
            </div>

            <div class="sub-card">
                <div class="section-title">
                    <div class="st-left"><i class="fas fa-store"></i> Seller Information</div>
                </div>
                <div class="seller-row">
                    <div class="seller-avatar">
                        @(string.IsNullOrEmpty(Model.Product?.User?.UserName) ? "?" : Model.Product.User.UserName.Substring(0, 1).ToUpper())
                    </div>
                    <div>
                        <div class="seller-name">@Model.Product?.User?.UserName</div>
                        <div class="seller-tag">Listed this item</div>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(Model.Product?.User?.Email))
                {
                    <a href="mailto:@Model.Product.User.Email" class="seller-contact-row"><i class="fas fa-envelope"></i> @Model.Product.User.Email</a>
                }
                @if (!string.IsNullOrEmpty(Model.Product?.User?.PhoneNumber))
                {
                    <a href="tel:@Model.Product.User.PhoneNumber" class="seller-contact-row"><i class="fas fa-phone"></i> @Model.Product.User.PhoneNumber</a>
                }
            </div>
        </div>

        <!-- previous bids timeline -->
        <div class="sub-card standalone-card" style="margin-top:1.4rem;">
            <div class="section-title">
                <div class="st-left"><i class="fas fa-history"></i> Previous Bids</div>
                <span class="timeline-caption">Ordered from lowest to highest</span>
            </div>
            @if (bidHistory.Any())
            {
                var maxBid = bidHistory.Max(b => b.bidamount);
                <div class="timeline">
                    @for (int i = 0; i < bidHistory.Count; i++)
                    {
                        var b = bidHistory[i];
                        bool isLeading = b.bidamount == maxBid;
                        bool isCurrent = b.Id == Model.Id;
                        <div class="timeline-item @(isCurrent ? "is-current" : "") @(isLeading ? "is-leading" : "")">
                            <div class="timeline-dot">@(i + 1)</div>
                            <div class="timeline-content">
                                <div class="timeline-amount">Rs. @b.bidamount</div>
                                <div class="timeline-user">@(b.User?.UserName ?? "Unknown bidder")</div>
                                <div class="timeline-badges">
                                    @if (isLeading)
                                    {
                                        <span class="tl-badge leading"><i class="fas fa-crown"></i> Leading</span>
                                    }
                                    @if (isCurrent)
                                    {
                                        <span class="tl-badge current">Your Bid</span>
                                    }
                                    <span class="tl-badge status">@b.bidstatus</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="timeline-empty"><i class="fas fa-info-circle"></i> No other bids have been placed yet.</div>
            }
        </div>

    </div>

    <div class="lightbox-overlay" id="lightboxOverlay" onclick="closeLightbox(event)">
        <button class="lightbox-close" onclick="closeLightbox(event)"><i class="fas fa-times"></i></button>
        <img id="lightboxImg" src="" alt="" />
    </div>
</div>

<script>
    function handleImgError(imgEl, fallbackClass, iconClass, extraText) {
        const div = document.createElement('div');
        div.className = fallbackClass;
        div.style.width = '100%'; div.style.height = '100%';
        div.style.display = 'flex'; div.style.flexDirection = extraText ? 'column' : 'row';
        div.style.alignItems = 'center'; div.style.justifyContent = 'center';
        div.innerHTML = '<i class="fas ' + iconClass + '"></i>' + (extraText ? '<span>' + extraText + '</span>' : '');
        imgEl.replaceWith(div);
    }

    function switchMainImage(url, thumbEl) {
        const main = document.getElementById('galleryMain');
        let img = document.getElementById('mainImg');
        if (!img) {
            main.innerHTML = '<img id="mainImg" src="" alt="" /><div class="zoom-hint"><i class="fas fa-search-plus"></i> Click to zoom</div>';
            img = document.getElementById('mainImg');
        }
        img.style.opacity = 0;
        setTimeout(() => { img.src = url; img.style.opacity = 1; }, 150);
        document.querySelectorAll('.thumb-box').forEach(t => t.classList.remove('active'));
        thumbEl.classList.add('active');
    }

    function openLightbox() {
        const mainImg = document.getElementById('mainImg');
        if (!mainImg || !mainImg.src) return;
        document.getElementById('lightboxImg').src = mainImg.src;
        document.getElementById('lightboxOverlay').classList.add('open');
    }
    function closeLightbox(e) {
        if (e) e.stopPropagation();
        document.getElementById('lightboxOverlay').classList.remove('open');
    }
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeLightbox(); });
</script>