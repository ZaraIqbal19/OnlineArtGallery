@model Art_Gallery.Models.AuctionDetails
@using System.Linq
@{
    ViewData["Title"] = "Bid Details";
    Layout = "~/Views/Shared/_UserLayout.cshtml";

    var bidHistory = (ViewBag.PreviousBids as IEnumerable<Art_Gallery.Models.AuctionDetails> ?? Enumerable.Empty<Art_Gallery.Models.AuctionDetails>())
        .OrderBy(b => b.bidamount)
        .ToList();

    string GetImgFileName(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return string.Empty;
        var normalized = raw.Replace('\\', '/');
        return normalized.Substring(normalized.LastIndexOf('/') + 1);
    }

    var img1 = GetImgFileName(Model.Product?.Image1);
    var img2 = GetImgFileName(Model.Product?.Image2);
    var img3 = GetImgFileName(Model.Product?.Image3);
    var imageCount = new[] { img1, img2, img3 }.Count(i => !string.IsNullOrEmpty(i));

    bool isHighest = ViewBag.IsHighestBidder != null && (bool)ViewBag.IsHighestBidder;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />

