<!-- ─── Success Modal Popup ─── -->
<div class="success-overlay" id="successOverlay">
    <div class="success-modal">
        <div class="modal-icon">
            <i class="fas fa-check"></i>
        </div>
        <h2>Success!</h2>
        <p id="successMessage">Your message has been sent successfully.</p>
        <button class="btn-close-modal" onclick="closeSuccessModal()">
            <i class="fas fa-arrow-right"></i> Continue
        </button>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/js/all.min.js"></script>
<script>
    (function () {
        const form = document.getElementById('contactForm');
        const input = document.getElementById('MessageInput');
        const wrapper = document.getElementById('messageWrapper');
        const valMsg = document.getElementById('validationMsg');
        const submitBtn = document.getElementById('submitBtn');
        const charCount = document.getElementById('charCount');
        const charCounter = document.getElementById('charCounter');
        const successOverlay = document.getElementById('successOverlay');
        const successMessage = document.getElementById('successMessage');

        function updateCharCounter() {
            const len = input.value.length;
            charCount.textContent = len;
            charCounter.classList.remove('warning', 'danger');
            if (len >= 180) charCounter.classList.add('warning');
            if (len >= 200) charCounter.classList.add('danger');
        }

        function validate() {
            const val = input.value;
            const len = val.length;
            let valid = true;
            let msg = '';
            let icon = 'fa-info-circle';

            if (len === 0) {
                valid = false;
                msg = 'Message is required';
                icon = 'fa-exclamation-circle';
            } else if (len < 3) {
                valid = false;
                msg = 'Minimum 3 characters';
                icon = 'fa-exclamation-circle';
            } else if (len > 200) {
                valid = false;
                msg = 'Maximum 200 characters';
                icon = 'fa-exclamation-triangle';
            } else {
                msg = 'Looks good!';
                icon = 'fa-check-circle';
            }

            wrapper.classList.remove('is-valid', 'is-invalid');
            valMsg.classList.remove('text-danger', 'text-success', 'text-muted');

            if (len === 0) {
                valMsg.classList.add('text-muted');
                valMsg.innerHTML = `<i class="fas fa-info-circle"></i> <span>Min 3 characters</span>`;
                return false;
            }

            if (valid) {
                wrapper.classList.add('is-valid');
                valMsg.classList.add('text-success');
            } else {
                wrapper.classList.add('is-invalid');
                valMsg.classList.add('text-danger');
            }

            valMsg.innerHTML = `<i class="fas ${icon}"></i> <span>${msg}</span>`;
            return valid;
        }

        function updateBtn() {
            const val = input.value;
            submitBtn.disabled = !(val.length >= 3 && val.length <= 200);
        }

        window.showSuccessModal = function (message) {
            if (message) {
                successMessage.textContent = message;
            }
            successOverlay.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        window.closeSuccessModal = function () {
            successOverlay.classList.remove('active');
            document.body.style.overflow = '';
            window.location.href = '@Url.Action("Index")';
        }

        input.addEventListener('input', function () {
            updateCharCounter();
            validate();
            updateBtn();
        });

        input.addEventListener('blur', function () {
            if (input.value.length === 0) {
                wrapper.classList.remove('is-valid', 'is-invalid');
                valMsg.classList.remove('text-danger', 'text-success');
                valMsg.classList.add('text-muted');
                valMsg.innerHTML = `<i class="fas fa-info-circle"></i> <span>Min 3 characters</span>`;
            } else {
                validate();
            }
            updateBtn();
        });

        updateCharCounter();
        submitBtn.disabled = true;
        valMsg.classList.add('text-muted');

        form.addEventListener('submit', function (e) {
            if (!validate()) {
                e.preventDefault();
                input.focus();
                return;
            }
            submitBtn.classList.add('loading');
            submitBtn.disabled = true;
        });

        @if (TempData["Message"] != null)
        {
                        <text>
                            setTimeout(function() {
                                showSuccessModal('@TempData["Message"]');
                            }, 500);
                        </text>
        }

        successOverlay.addEventListener('click', function (e) {
            if (e.target === this) {
                closeSuccessModal();
            }
        });

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape' && successOverlay.classList.contains('active')) {
                closeSuccessModal();
            }
        });

        // ─── FAQ accordion ───
        document.querySelectorAll('.faq-item').forEach(function (item) {
            const question = item.querySelector('.faq-question');
            const answer = item.querySelector('.faq-answer');

            question.addEventListener('click', function () {
                const isOpen = item.classList.contains('open');

                document.querySelectorAll('.faq-item.open').forEach(function (openItem) {
                    if (openItem !== item) {
                        openItem.classList.remove('open');
                        openItem.querySelector('.faq-answer').style.maxHeight = null;
                    }
                });

                if (isOpen) {
                    item.classList.remove('open');
                    answer.style.maxHeight = null;
                } else {
                    item.classList.add('open');
                    answer.style.maxHeight = answer.scrollHeight + 'px';
                }
            });
        });

        // ─── Scroll reveal for below-form sections ───
        if ('IntersectionObserver' in window) {
            const revealObserver = new IntersectionObserver(function (entries) {
                entries.forEach(function (entry) {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('revealed');
                        revealObserver.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.15 });

            document.querySelectorAll('.reveal').forEach(function (el) {
                revealObserver.observe(el);
            });
        } else {
            document.querySelectorAll('.reveal').forEach(function (el) {
                el.classList.add('revealed');
            });
        }

    })();
</script>
