@model Art_Gallery.Models.Contact

@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
    /* ─── Page Container ─── */
    .page-wrapper {
        max-width: 560px;
        margin: 2.5rem auto;
        padding: 0 1.25rem;
    }

    /* ─── Card ─── */
    .form-card {
        background: #ffffff;
        border-radius: 24px;
        padding: 2.5rem 2.8rem;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.03), 0 8px 32px rgba(104, 168, 0, 0.06);
        border: 1px solid rgba(136, 210, 0, 0.06);
        transition: box-shadow 0.3s ease;
    }

    .form-card:hover {
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.04), 0 12px 48px rgba(104, 168, 0, 0.08);
    }

    /* ─── Header ─── */
    .form-header {
        display: flex;
        align-items: center;
        gap: 0.875rem;
        margin-bottom: 0.25rem;
    }

    .form-header .icon-box {
        width: 52px;
        height: 52px;
        border-radius: 16px;
        background: #f0fae6;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        color: #6fa800;
        transition: all 0.3s ease;
    }

    .form-card:hover .icon-box {
        background: linear-gradient(135deg, #88d200, #6fa800);
        color: #ffffff;
        transform: scale(1.02);
    }

    .form-header h1 {
        font-size: 1.85rem;
        font-weight: 700;
        color: #1a2a08;
        letter-spacing: -0.02em;
        margin: 0;
    }

    .form-header h1 span {
        color: #6fa800;
    }

    .form-subtitle {
        display: flex;
        align-items: center;
        gap: 0.625rem;
        margin-bottom: 1.5rem;
        padding-left: 4px;
    }

    .form-subtitle .badge {
        font-size: 0.85rem;
        font-weight: 500;
        color: #4a6830;
        background: #f0fae6;
        padding: 0.2rem 1rem;
        border-radius: 20px;
    }

    .form-subtitle .badge i {
        color: #88d200;
        margin-right: 6px;
    }

    .form-subtitle .dot {
        width: 6px;
        height: 6px;
        background: #88d200;
        border-radius: 50%;
        display: inline-block;
        animation: pulse-dot 2s ease-in-out infinite;
    }

    @@keyframes pulse-dot {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.3; transform: scale(0.6); }
    }

    .divider {
        border: none;
        height: 2px;
        background: linear-gradient(90deg, #88d200, #d4f09b, #f0fae6);
        border-radius: 2px;
        margin: 0 0 1.75rem 0;
        opacity: 0.4;
    }

    /* ─── Success Modal / Popup ─── */
    .success-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.35);
        backdrop-filter: blur(4px);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        padding: 1.5rem;
        animation: fadeIn 0.3s ease;
    }

    .success-overlay.active {
        display: flex;
    }

    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    .success-modal {
        background: #ffffff;
        border-radius: 24px;
        padding: 2.5rem 3rem;
        max-width: 440px;
        width: 100%;
        text-align: center;
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.12);
        animation: popIn 0.5s cubic-bezier(0.22, 1, 0.36, 1);
        position: relative;
        overflow: hidden;
    }

    .success-modal::before {
        content: '';
        position: absolute;
        top: -60px;
        right: -60px;
        width: 200px;
        height: 200px;
        background: radial-gradient(circle, rgba(212, 240, 155, 0.15) 0%, transparent 70%);
        border-radius: 50%;
        pointer-events: none;
    }

    @@keyframes popIn {
        0% { opacity: 0; transform: scale(0.9) translateY(20px); }
        100% { opacity: 1; transform: scale(1) translateY(0); }
    }

    .success-modal .modal-icon {
        width: 72px;
        height: 72px;
        background: linear-gradient(135deg, #88d200, #6fa800);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
        font-size: 2.2rem;
        color: white;
        box-shadow: 0 8px 32px rgba(136, 210, 0, 0.2);
        animation: bounce 0.6s ease;
    }

    @@keyframes bounce {
        0% { transform: scale(0); }
        50% { transform: scale(1.2); }
        70% { transform: scale(0.9); }
        100% { transform: scale(1); }
    }

    .success-modal h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #1a2a08;
        margin-bottom: 0.5rem;
    }

    .success-modal p {
        color: #4a6830;
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: 1.5rem;
    }

    .success-modal .btn-close-modal {
        background: linear-gradient(135deg, #88d200, #6fa800);
        border: none;
        padding: 12px 32px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 0.95rem;
        color: #1a2a08;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 16px rgba(136, 210, 0, 0.15);
    }

    .success-modal .btn-close-modal:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 28px rgba(104, 168, 0, 0.2);
    }

    .success-modal .btn-close-modal i {
        margin-right: 8px;
    }

    /* ─── Form ─── */
    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-group label {
        display: block;
        font-weight: 600;
        font-size: 0.9rem;
        color: #2f421a;
        margin-bottom: 6px;
    }

    .form-group label i {
        color: #88d200;
        margin-right: 6px;
        width: 18px;
    }

    .input-group {
        position: relative;
        display: flex;
        align-items: center;
        background: #f8fdf3;
        border-radius: 12px;
        border: 2px solid #e4efd4;
        transition: all 0.25s ease;
        padding: 0 16px;
    }

    .input-group .input-icon {
        color: #8fae6a;
        font-size: 0.9rem;
        transition: 0.25s;
        margin-right: 10px;
        flex-shrink: 0;
    }

    .input-group input {
        width: 100%;
        border: none;
        background: transparent;
        padding: 13px 0;
        font-size: 0.95rem;
        font-weight: 500;
        color: #1a2a08;
        outline: none;
        font-family: inherit;
    }

    .input-group input::placeholder {
        color: #bccfa5;
        font-weight: 400;
    }

    .input-group:focus-within {
        border-color: #88d200;
        background: #ffffff;
        box-shadow: 0 0 0 4px rgba(136, 210, 0, 0.06);
    }

    .input-group:focus-within .input-icon {
        color: #88d200;
    }

    /* Validation */
    .input-group.is-valid {
        border-color: #88d200;
        background: #f4ffe6;
    }

    .input-group.is-valid .input-icon {
        color: #88d200;
    }

    .input-group.is-invalid {
        border-color: #e74c3c;
        background: #fef6f5;
    }

    .input-group.is-invalid .input-icon {
        color: #e74c3c;
    }

    .validation-msg {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.8rem;
        font-weight: 500;
        margin-top: 6px;
        padding-left: 6px;
        min-height: 1.4rem;
    }

    .validation-msg.text-danger {
        color: #c0392b;
    }

    .validation-msg.text-success {
        color: #6fa800;
    }

    .validation-msg.text-muted {
        color: #b0c79a;
    }

    .validation-msg i {
        font-size: 0.8rem;
    }

    .char-counter {
        text-align: right;
        font-size: 0.72rem;
        font-weight: 500;
        color: #b0c79a;
        margin-top: 4px;
        padding-right: 4px;
    }

    .char-counter.warning {
        color: #e67e22;
    }

    .char-counter.danger {
        color: #e74c3c;
    }

    /* ─── Button ─── */
    .btn-submit {
        width: 100%;
        padding: 15px 24px;
        border: none;
        border-radius: 12px;
        font-weight: 600;
        font-size: 0.98rem;
        color: #1a2a08;
        background: linear-gradient(135deg, #88d200, #6fa800);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 16px rgba(136, 210, 0, 0.15);
        font-family: inherit;
    }

    .btn-submit:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 8px 28px rgba(104, 168, 0, 0.2);
    }

    .btn-submit:active:not(:disabled) {
        transform: scale(0.97);
    }

    .btn-submit:disabled {
        background: #dce8cc;
        color: #7a9460;
        box-shadow: none;
        cursor: not-allowed;
        opacity: 0.6;
    }

    .btn-submit i {
        font-size: 0.9rem;
        transition: 0.2s;
    }

    .btn-submit:hover:not(:disabled) i {
        transform: translateX(2px);
    }

    .btn-submit .spinner {
        display: none;
    }

    .btn-submit.loading .btn-text {
        display: none;
    }

    .btn-submit.loading .spinner {
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    /* ─── Back Link ─── */
    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-top: 1.5rem;
        font-weight: 500;
        color: #4a6830;
        text-decoration: none;
        font-size: 0.9rem;
        transition: all 0.25s ease;
        border-bottom: 2px solid transparent;
        padding-bottom: 2px;
    }

    .back-link i {
        font-size: 0.8rem;
        transition: 0.25s;
    }

    .back-link:hover {
        color: #6fa800;
        border-bottom-color: #88d200;
        gap: 12px;
    }

    .back-link:hover i {
        transform: translateX(-4px);
    }

    /* ─── Responsive ─── */
    @@media (max-width: 540px) {
        .form-card {
            padding: 1.5rem;
            border-radius: 20px;
        }

        .form-header h1 {
            font-size: 1.5rem;
        }

        .form-header .icon-box {
            width: 44px;
            height: 44px;
            font-size: 1.2rem;
        }

        .btn-submit {
            font-size: 0.9rem;
            padding: 13px 18px;
        }

        .success-modal {
            padding: 1.8rem 1.5rem;
        }

        .success-modal .modal-icon {
            width: 60px;
            height: 60px;
            font-size: 1.8rem;
        }
    }

    @@media (max-width: 400px) {
        .form-card {
            padding: 1rem;
            border-radius: 16px;
        }
    }
</style>

<div class="page-wrapper">
    <div class="form-card">

        <!-- Header -->
        <div class="form-header">
            <div class="icon-box">
                <i class="fas fa-pen-fancy"></i>
            </div>
            <h1>Create <span>Contact</span></h1>
        </div>
        <div class="form-subtitle">
            <span class="badge">
                <i class="fas fa-address-card"></i> New Entry
            </span>
            <span class="dot"></span>
        </div>
        <hr class="divider" />

        <!-- Form -->
        <form asp-controller="user" asp-action="Addcontactlogic" method="post" id="contactForm" novalidate>
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger" style="display:none;"></div>

            <div class="form-group">
                <label for="MessageInput">
                    <i class="fas fa-comment-dots"></i> Message
                </label>
                <div class="input-group" id="messageWrapper">
                    <i class="fas fa-pencil-alt input-icon"></i>
                    <input id="MessageInput"
                           asp-for="Message"
                           placeholder="Type your message..."
                           required
                           minlength="3"
                           maxlength="200"
                           autocomplete="off" />
                </div>
                <div class="validation-msg text-muted" id="validationMsg">
                    <i class="fas fa-info-circle"></i>
                    <span>Minimum 3 characters</span>
                </div>
                <div class="char-counter" id="charCounter">
                    <span id="charCount">0</span> / 200
                </div>
            </div>

            <div class="form-group" style="margin-bottom:0;">
                <button type="submit" class="btn-submit" id="submitBtn" disabled>
                    <span class="btn-text">
                        <i class="fas fa-paper-plane"></i> Create
                    </span>
                    <span class="spinner">
                        <i class="fas fa-spinner fa-pulse"></i> Sending...
                    </span>
                </button>
            </div>
        </form>

        <!-- Back Link -->
        <a asp-action="Index" class="back-link">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>

    </div>
</div>

<!-- ─── Success Modal Popup ─── -->
<div class="success-overlay" id="successOverlay">
    <div class="success-modal">
        <div class="modal-icon">
            <i class="fas fa-check"></i>
        </div>
        <h2>Success!</h2>
        <p id="successMessage">Your contact has been created successfully.</p>
        <button class="btn-close-modal" onclick="closeSuccessModal()">
            <i class="fas fa-arrow-right"></i> Continue
        </button>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/js/all.min.js"></script>
<script>
    (function () {
        const form = document.getElementById('contactForm');
        const input = document.getElementById('MessageInput');
        const wrapper = document.getElementById('messageWrapper');
        const valMsg = document.getElementById('validationMsg');
        const submitBtn = document.getElementById('submitBtn');
        const charCount = document.getElementById('charCount');
        const charCounter = document.getElementById('charCounter');
        const successOverlay = document.getElementById('successOverlay');
        const successMessage = document.getElementById('successMessage');

        // ─── Character Counter ───
        function updateCharCounter() {
            const len = input.value.length;
            charCount.textContent = len;
            charCounter.classList.remove('warning', 'danger');
            if (len >= 180) charCounter.classList.add('warning');
            if (len >= 200) charCounter.classList.add('danger');
        }

        // ─── Validation ───
        function validate() {
            const val = input.value;
            const len = val.length;
            let valid = true;
            let msg = '';
            let icon = 'fa-info-circle';

            if (len === 0) {
                valid = false;
                msg = 'Message is required';
                icon = 'fa-exclamation-circle';
            } else if (len < 3) {
                valid = false;
                msg = 'Minimum 3 characters';
                icon = 'fa-exclamation-circle';
            } else if (len > 200) {
                valid = false;
                msg = 'Maximum 200 characters';
                icon = 'fa-exclamation-triangle';
            } else {
                msg = 'Looks good!';
                icon = 'fa-check-circle';
            }

            wrapper.classList.remove('is-valid', 'is-invalid');
            valMsg.classList.remove('text-danger', 'text-success', 'text-muted');

            if (len === 0) {
                valMsg.classList.add('text-muted');
                valMsg.innerHTML = `<i class="fas fa-info-circle"></i> <span>Min 3 characters</span>`;
                return false;
            }

            if (valid) {
                wrapper.classList.add('is-valid');
                valMsg.classList.add('text-success');
            } else {
                wrapper.classList.add('is-invalid');
                valMsg.classList.add('text-danger');
            }

            valMsg.innerHTML = `<i class="fas ${icon}"></i> <span>${msg}</span>`;
            return valid;
        }

        // ─── Update Button ───
        function updateBtn() {
            const val = input.value;
            submitBtn.disabled = !(val.length >= 3 && val.length <= 200);
        }

        // ─── Show Success Modal ───
        window.showSuccessModal = function (message) {
            if (message) {
                successMessage.textContent = message;
            }
            successOverlay.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        // ─── Close Success Modal ───
        window.closeSuccessModal = function () {
            successOverlay.classList.remove('active');
            document.body.style.overflow = '';
            // Redirect to Index after closing
            window.location.href = '@Url.Action("Index")';
        }

        // ─── Event Listeners ───
        input.addEventListener('input', function () {
            updateCharCounter();
            validate();
            updateBtn();
        });

        input.addEventListener('blur', function () {
            if (input.value.length === 0) {
                wrapper.classList.remove('is-valid', 'is-invalid');
                valMsg.classList.remove('text-danger', 'text-success');
                valMsg.classList.add('text-muted');
                valMsg.innerHTML = `<i class="fas fa-info-circle"></i> <span>Min 3 characters</span>`;
            } else {
                validate();
            }
            updateBtn();
        });

        // ─── Init ───
        updateCharCounter();
        submitBtn.disabled = true;
        valMsg.classList.add('text-muted');

        // ─── Form Submit ───
        form.addEventListener('submit', function (e) {
            if (!validate()) {
                e.preventDefault();
                input.focus();
                return;
            }

            // Show loading state
            submitBtn.classList.add('loading');
            submitBtn.disabled = true;
        });

        // ─── Check for TempData on page load ───
        @if (TempData["Message"] != null)
        {
            <text>
                // Show success modal with the message
                setTimeout(function() {
                    showSuccessModal('@TempData["Message"]');
                }, 500);
            </text>
        }

        // ─── Close modal on overlay click ───
        successOverlay.addEventListener('click', function (e) {
            if (e.target === this) {
                closeSuccessModal();
            }
        });

        // ─── Close modal on Escape key ───
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape' && successOverlay.classList.contains('active')) {
                closeSuccessModal();
            }
        });

    })();
</script>