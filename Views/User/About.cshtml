@{
    ViewData["Title"] = "About Us";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<!-- Banner Area -->
<section class="banner-area relative" id="home">
    <div class="overlay overlay-bg"></div>

    <div class="container">

        <div class="row d-flex align-items-center justify-content-center">

            <div class="about-content col-lg-12 text-center">

                <h1 class="text-white">
                    About Our Art Gallery
                </h1>

                <p class="text-white mt-3">
                    Discover, Buy, Sell, and Auction Beautiful Artwork from Talented Artists Around the World.
                </p>

            </div>

        </div>

    </div>

</section>
<!-- End Banner -->
<!-- Quote Section -->

<section class="quote-area pt-100">

    <div class="container">

        <div class="row">

            <div class="col-lg-6 quote-left">

                <h1>

                    <span>Art</span> inspires creativity,

                    <br>

                    connects <span>artists</span>

                    <br>

                    with passionate

                    <span>collectors.</span>

                </h1>

            </div>

            <div class="col-lg-6 quote-right">

                <p>

                    Our Art Gallery is a modern online marketplace designed for artists
                    and art lovers. Artists can upload their creations, manage sales,
                    and participate in online auctions while buyers can explore unique
                    paintings, digital artwork, sketches, photography, and handmade
                    masterpieces.

                </p>

                <br>

                <p>

                    We believe every artwork deserves an audience. Our platform connects
                    talented creators with collectors in a secure and transparent
                    environment.

                </p>

            </div>

        </div>

    </div>

</section>



<!-- Services -->

<section class="service-area section-gap">

    <div class="container">

        <div class="row">

            <div class="col-lg-4">

                <div class="single-service">

                    <span class="lnr lnr-cart"></span>

                    <h4>Buy Artwork</h4>

                    <p>

                        Browse thousands of beautiful paintings,
                        digital art, sketches and handmade
                        masterpieces uploaded by artists.

                    </p>

                    <div class="overlay">

                        <div class="text">

                            <p>

                                Purchase artwork securely using
                                Cash on Delivery or Card Payment.
                                Track every order directly from your account.

                            </p>

                        </div>

                    </div>

                </div>

            </div>



            <div class="col-lg-4">

                <div class="single-service">

                    <span class="lnr lnr-upload"></span>

                    <h4>Sell Artwork</h4>

                    <p>

                        Artists can upload unlimited artwork,
                        manage products and receive orders
                        from customers.

                    </p>

                    <div class="overlay">

                        <div class="text">

                            <p>

                                Grow your audience by showcasing
                                your artwork in an online gallery
                                visited by collectors every day.

                            </p>

                        </div>

                    </div>

                </div>

            </div>



            <div class="col-lg-4">

                <div class="single-service">

                    <span class="lnr lnr-diamond"></span>

                    <h4>Online Auctions</h4>

                    <p>

                        Participate in exciting auctions
                        and bid on exclusive artwork.

                    </p>

                    <div class="overlay">

                        <div class="text">

                            <p>

                                Our auction system automatically
                                selects the highest bidder after
                                the auction end date.

                            </p>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section><!-- ================= About Information ================= -->

<section class="section-gap info-area" id="about">

