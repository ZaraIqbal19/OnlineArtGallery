@model IEnumerable<Art_Gallery.Models.Category>

@{
    ViewData["Title"] = "Categories";
    Layout = "~/Views/Shared/_UserLayout.cshtml";

    // Retrieve the subcategories from ViewBag and cast them so we can use LINQ
    var subCategories = ViewBag.SubCategories as List<Art_Gallery.Models.SubCategory>;
    var maxSubCount = Model?.Max(c => subCategories?.Count(s => s.CategoryId == c.Id) ?? 0) ?? 0;
}

<style>
    /* Color Theme Variables */
    :root {
        --primary-green: #88d200;
        --dark-green: #6fa800;
        --light-green: #d4f09b;
        --ultra-light-green: #f0fae6;
    }

    /* Section Styling */
    .artify-categories-section {
        padding: 60px 0;
        background: #f8faf6;
    }

    .section-title {
        text-align: center;
        margin-bottom: 50px;
    }

    .artify-eyebrow {
        display: inline-block;
        background: var(--ultra-light-green);
        color: var(--dark-green);
        padding: 6px 20px;
        border-radius: 50px;
        font-size: 14px;
        font-weight: 600;
        letter-spacing: 1px;
        margin-bottom: 12px;
        border: 1px solid var(--light-green);
    }

        .artify-eyebrow i {
            margin-right: 8px;
            color: var(--primary-green);
        }

    .section-title .title {
        font-weight: 800;
        font-size: 38px;
        color: #2d2d2d;
        margin-bottom: 10px;
    }

        .section-title .title span {
            color: var(--primary-green);
        }

    .section-title .subtitle {
        color: #777;
        font-size: 17px;
        font-weight: 400;
    }

    /* Shop Card */
    .shop {
        position: relative;
        overflow: hidden;
        margin: 15px 0px;
        border-radius: 18px;
        transition: all 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        cursor: pointer;
        box-shadow: 0 4px 20px rgba(0,0,0,0.04);
        background: #fff;
        height: 100%;
    }

        /* Green Gradient Overlay */
        .shop:before {
            content: "";
            position: absolute;
            top: 0;
            bottom: 0;
            left: 0px;
            width: 65%;
            background: linear-gradient(135deg, var(--primary-green), var(--dark-green));
            opacity: 0.92;
            -webkit-transform: skewX(-45deg) scaleX(1.1);
            -ms-transform: skewX(-45deg) scaleX(1.1);
            transform: skewX(-45deg) scaleX(1.1);
            transition: all 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            transform-origin: left;
        }

        .shop:after {
            content: "";
            position: absolute;
            top: 0;
            bottom: 0;
            left: 1px;
            width: 100%;
            background: linear-gradient(135deg, var(--primary-green), var(--dark-green));
            opacity: 0.92;
            -webkit-transform: skewX(-45deg) translateX(-100%) scaleX(1.1);
            -ms-transform: skewX(-45deg) translateX(-100%) scaleX(1.1);
            transform: skewX(-45deg) translateX(-100%) scaleX(1.1);
            transition: all 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        .shop:hover:before {
            -webkit-transform: skewX(-30deg) scaleX(1.1);
            -ms-transform: skewX(-30deg) scaleX(1.1);
            transform: skewX(-30deg) scaleX(1.1);
            opacity: 1;
        }

        .shop:hover:after {
            -webkit-transform: skewX(-30deg) translateX(-100%) scaleX(1.1);
            -ms-transform: skewX(-30deg) translateX(-100%) scaleX(1.1);
            transform: skewX(-30deg) translateX(-100%) scaleX(1.1);
            opacity: 1;
        }

        /* Shop Image */
        .shop .shop-img {
            position: relative;
            background-color: var(--ultra-light-green);
            z-index: -1;
            overflow: hidden;
        }

            .shop .shop-img > img {
                width: 100%;
                height: 280px;
                object-fit: cover;
                -webkit-transition: 1s cubic-bezier(0.25, 0.46, 0.45, 0.94);
                transition: 1s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            }

        .shop:hover .shop-img > img {
            -webkit-transform: scale(1.2);
            -ms-transform: scale(1.2);
            transform: scale(1.2);
        }

    /* Badges */
    .shop-icon-badge {
        position: absolute;
        top: 18px;
        left: 18px;
        z-index: 5;
        background: rgba(255,255,255,0.95);
        color: var(--dark-green);
        width: 44px;
        height: 44px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        backdrop-filter: blur(5px);
        border: 1px solid rgba(255,255,255,0.3);
    }

    .shop-popular-badge {
        position: absolute;
        top: 18px;
        right: 18px;
        z-index: 5;
        background: linear-gradient(135deg, #FF6B6B, #ee5a24);
        color: #fff;
        padding: 6px 16px;
        border-radius: 50px;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.5px;
        box-shadow: 0 4px 15px rgba(238, 90, 36, 0.3);
        border: 1px solid rgba(255,255,255,0.2);
    }

        .shop-popular-badge i {
            margin-right: 6px;
        }

    .shop-count-badge {
        position: absolute;
        bottom: 18px;
        left: 18px;
        z-index: 5;
        background: rgba(0,0,0,0.7);
        backdrop-filter: blur(10px);
        color: #fff;
        padding: 6px 16px;
        border-radius: 50px;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.5px;
        border: 1px solid rgba(255,255,255,0.1);
    }

        .shop-count-badge i {
            margin-right: 6px;
        }

    .shop-explore-tag {
        position: absolute;
        bottom: 18px;
        right: 18px;
        z-index: 5;
        background: rgba(255,255,255,0.95);
        color: var(--dark-green);
        padding: 6px 16px;
        border-radius: 50px;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.5px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        border: 1px solid var(--light-green);
        opacity: 0;
        transform: translateY(10px);
        transition: all 0.4s ease;
    }

    .shop:hover .shop-explore-tag {
        opacity: 1;
        transform: translateY(0);
    }

    .shop-explore-tag i {
        margin-right: 6px;
    }

    /* Shop Body */
    .shop .shop-body {
        position: absolute;
        top: 0;
        width: 75%;
        padding: 40px 35px;
        z-index: 10;
        display: flex;
        flex-direction: column;
        justify-content: center;
        height: 100%;
        opacity: 0;
        transform: translateX(-40px) scale(0.95);
        transition: all 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .shop:hover .shop-body {
        opacity: 1;
        transform: translateX(0) scale(1);
    }

    .shop .shop-body h3 {
        color: #FFF;
        font-weight: 800;
        font-size: 28px;
        transform: translateY(20px);
        transition: all 0.6s ease 0.1s;
        text-shadow: 0 4px 20px rgba(0,0,0,0.15);
        letter-spacing: -0.5px;
        margin-bottom: 8px;
    }

        .shop .shop-body h3 small {
            display: block;
            font-size: 14px;
            font-weight: 400;
            opacity: 0.9;
            margin-top: 6px;
            letter-spacing: 1px;
        }

    .shop:hover .shop-body h3 {
        transform: translateY(0);
    }

    .shop .shop-body .cta-btn {
        color: #FFF;
        text-transform: uppercase;
        display: inline-flex;
        align-items: center;
        gap: 12px;
        transition: all 0.4s ease;
        font-weight: 700;
        padding: 10px 0;
        border-bottom: 2px solid rgba(255,255,255,0.25);
        width: fit-content;
        font-size: 14px;
        letter-spacing: 1.5px;
        opacity: 0;
        transform: translateY(15px);
        transition: all 0.6s ease 0.2s;
        text-decoration: none;
        background: transparent;
        border: none;
        border-bottom: 2px solid rgba(255,255,255,0.25);
    }

    .shop:hover .shop-body .cta-btn {
        opacity: 1;
        transform: translateY(0);
    }

    .shop .shop-body .cta-btn:hover {
        transform: translateX(12px);
        border-bottom-color: #fff;
        color: #fff;
        text-decoration: none;
    }

    .shop .shop-body .cta-btn i {
        transition: all 0.4s ease;
        font-size: 18px;
    }

    .shop .shop-body .cta-btn:hover i {
        transform: translateX(8px) scale(1.15);
    }

    /* Dummy Images - Different colors for variety */
    .dummy-img {
        width: 100%;
        height: 280px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 80px;
        color: white;
        font-weight: bold;
        position: relative;
        overflow: hidden;
    }

        .dummy-img .category-initial {
            font-size: 120px;
            font-weight: 800;
            opacity: 0.3;
            position: absolute;
            right: -20px;
            bottom: -40px;
            color: rgba(255,255,255,0.2);
        }

        .dummy-img .category-icon {
            font-size: 64px;
            margin-bottom: 10px;
            display: block;
        }

        .dummy-img .category-label {
            font-size: 16px;
            font-weight: 600;
            letter-spacing: 2px;
            text-transform: uppercase;
            opacity: 0.9;
        }

    /* Dummy image color variations */
    .dummy-1 {
        background: linear-gradient(135deg, #88d200, #6fa800);
    }

    .dummy-2 {
        background: linear-gradient(135deg, #f093fb, #f5576c);
    }

    .dummy-3 {
        background: linear-gradient(135deg, #4facfe, #00f2fe);
    }

    .dummy-4 {
        background: linear-gradient(135deg, #43e97b, #38f9d7);
    }

    .dummy-5 {
        background: linear-gradient(135deg, #fa709a, #fee140);
    }

    .dummy-6 {
        background: linear-gradient(135deg, #a18cd1, #fbc2eb);
    }

    .dummy-7 {
        background: linear-gradient(135deg, #fccb90, #d57eeb);
    }

    .dummy-8 {
        background: linear-gradient(135deg, #89f7fe, #66a6ff);
    }

    .dummy-9 {
        background: linear-gradient(135deg, #f6d365, #fda085);
    }

    .dummy-10 {
        background: linear-gradient(135deg, #84fab0, #8fd3f4);
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .section-title .title {
            font-size: 28px;
        }

        .shop .shop-body {
            padding: 30px 25px;
            width: 85%;
        }

            .shop .shop-body h3 {
                font-size: 22px;
            }

        .shop .shop-img > img,
        .dummy-img {
            height: 220px;
        }

        .shop-count-badge,
        .shop-explore-tag {
            font-size: 10px;
            padding: 4px 12px;
        }

        .dummy-img .category-icon {
            font-size: 48px;
        }

        .dummy-img .category-initial {
            font-size: 80px;
        }
    }

    @@media (max-width: 576px) {
        .shop .shop-body h3 {
            font-size: 18px;
        }

        .shop .shop-body .cta-btn {
            font-size: 12px;
        }

        .shop .shop-img > img,
        .dummy-img {
            height: 180px;
        }

            .dummy-img .category-icon {
                font-size: 36px;
            }

            .dummy-img .category-label {
                font-size: 12px;
            }

            .dummy-img .category-initial {
                font-size: 60px;
            }
    }
</style>

<div class="section artify-categories-section">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="section-title">
                    <span class="artify-eyebrow"><i class="fa fa-th-large"></i> Explore</span>
                    <h3 class="title">Browse <span>Categories</span></h3>
                    <p class="subtitle">Find exactly what you need, sorted by category.</p>
                </div>
            </div>

            @{
                int index = 0;
                string[] dummyColors = { "dummy-1", "dummy-2", "dummy-3", "dummy-4", "dummy-5", "dummy-6", "dummy-7", "dummy-8", "dummy-9", "dummy-10" };
                string[] icons = { "fa-paint-brush", "fa-camera", "fa-music", "fa-sculpture", "fa-pencil", "fa-palette", "fa-artstation", "fa-image", "fa-cubes", "fa-gem" };
            }

            @foreach (var category in Model)
            {
                var subCount = subCategories?.Count(s => s.CategoryId == category.Id) ?? 0;
                var isMostPopular = maxSubCount > 0 && subCount == maxSubCount;
                var colorClass = dummyColors[index % dummyColors.Length];
                var icon = icons[index % icons.Length];
                var firstLetter = category.Name?.FirstOrDefault().ToString().ToUpper() ?? "A";
                index++;

                <div class="col-md-4 col-6 mb-4">
                    <div class="shop">
                        <div class="shop-img">
                            <span class="shop-icon-badge"><i class="fa fa-tag"></i></span>

                            @if (isMostPopular)
                            {
                                <span class="shop-popular-badge"><i class="fa fa-fire"></i> Most Popular</span>
                            }

                            <span class="shop-count-badge"><i class="fa fa-cube"></i> @subCount items</span>
                            <span class="shop-explore-tag"><i class="fa fa-arrow-circle-right"></i> Tap to explore</span>

                            <!-- Dummy Image with Category Info -->
                            <div class="dummy-img @colorClass">
                                <div style="text-align: center; z-index: 2; position: relative;">
                                    <span class="category-icon">
                                        <i class="fa @icon"></i>
                                    </span>
                                    <div class="category-label">@category.Name</div>
                                </div>
                                <span class="category-initial">@firstLetter</span>
                            </div>
                        </div>
                        <div class="shop-body">
                            <h3>
                                @category.Name
                                <small>@subCount subcategories</small>
                            </h3>
                            <a href="#" class="cta-btn">
                                Explore <i class="fa fa-arrow-circle-right"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>