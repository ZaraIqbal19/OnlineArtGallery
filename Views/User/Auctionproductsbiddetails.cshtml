@model Art_Gallery.Models.AuctionDetails
@using System.Text.Json
@using System.Linq
@{
    ViewData["Title"] = "Auction Bid Details";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}
@functions {
    string JsStr(string? val) => JsonSerializer.Serialize(val ?? "");

    bool IsAvailableForBid(string? val)
    {
        if (string.IsNullOrWhiteSpace(val)) return false;
        var v = val.Trim();
        return v.Equals("yes", StringComparison.OrdinalIgnoreCase)
            || v.Equals("true", StringComparison.OrdinalIgnoreCase)
            || v.Equals("available", StringComparison.OrdinalIgnoreCase)
            || v.Equals("1", StringComparison.OrdinalIgnoreCase);
    }

    // The DB column sometimes holds just a filename ("abc.jpg") and sometimes
    // a full path ("/images/products/abc.jpg" or "images\products\abc.jpg")
    // depending on how the row was seeded/uploaded. This normalizes either
    // case down to a bare filename so it can be safely combined with
    // "~/images/products/" without doubling the folder.
    string GetImgFileName(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return string.Empty;
        var normalized = raw.Replace('\\', '/');
        return normalized.Substring(normalized.LastIndexOf('/') + 1);
    }
}

@{
    var bidHistory = (ViewBag.PreviousBids as IEnumerable<Art_Gallery.Models.AuctionDetails> ?? Enumerable.Empty<Art_Gallery.Models.AuctionDetails>())
        .OrderBy(b => b.bidamount)
        .ToList();

    var img1 = GetImgFileName(Model.Product?.Image1);
    var img2 = GetImgFileName(Model.Product?.Image2);
    var img3 = GetImgFileName(Model.Product?.Image3);
    var imageCount = new[] { img1, img2, img3 }.Count(i => !string.IsNullOrEmpty(i));
}

