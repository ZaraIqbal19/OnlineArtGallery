        border-radius: 40px;
    }

        .auction-user-page .tl-badge.leading {
            background: #eaf7d6;
            color: #4c7800;
        }

        .auction-user-page .tl-badge.current {
            background: #e6f1fc;
            color: #1a5fa5;
        }

        .auction-user-page .tl-badge.status {
            background: #f0fae6;
            color: #5c7a2e;
        }

    .auction-user-page .timeline-empty {
        color: #888;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 0;
    }

    /* lightbox */
    .auction-user-page .lightbox-overlay {
        position: fixed;
        inset: 0;
        background: rgba(10,10,10,0.88);
        z-index: 2000;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 30px;
        animation: lbFadeIn 0.2s ease;
    }

        .auction-user-page .lightbox-overlay.open {
            display: flex;
        }

        .auction-user-page .lightbox-overlay img {
            max-width: 90vw;
            max-height: 85vh;
            border-radius: 12px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.5);
        }

    .auction-user-page .lightbox-close {
        position: absolute;
        top: 24px;
        right: 32px;
        color: #fff;
        font-size: 1.6rem;
        background: rgba(255,255,255,0.12);
        width: 42px;
        height: 42px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        border: none;
        transition: background 0.2s;
    }

        .auction-user-page .lightbox-close:hover {
            background: rgba(255,255,255,0.25);
        }

    @@keyframes lbFadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@media (max-width: 900px) {
        .auction-user-page .hero-grid, .auction-user-page .cards-row {
            grid-template-columns: 1fr;
        }

        .auction-user-page .info-grid, .auction-user-page .quick-stats {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media (max-width: 576px) {
        .auction-user-page .user-card {
            padding: 1.2rem;
        }

        .auction-user-page .header-section {
            flex-direction: column;
            align-items: start;
        }

        .auction-user-page .quick-stats, .auction-user-page .info-grid {
            grid-template-columns: 1fr;
        }

        .auction-user-page .countdown-units {
            grid-template-columns: repeat(4, 1fr);
            gap: 6px;
        }

        .auction-user-page .countdown-unit .num {
            font-size: 1.15rem;
        }
    }
</style>

<div class="auction-user-page">
    <div class="container-cust">

        <div class="breadcrumb-strip">
            <a asp-action="Myauctionproductsbids">My Bids</a>
            <i class="fas fa-chevron-right"></i>
            <span>Bid #@Model.Id</span>
        </div>

        <!-- header -->
        <div class="user-card">
            <div class="header-section">
                <div class="brand-head">
                    <div class="brand-icon"><i class="fas fa-gavel"></i></div>
                    <div>
                        <h1 class="heading-green">Auction Bid Details</h1>
                        <div class="heading-sub">Bid #@Model.Id &middot; @Model.Product?.Name</div>
                    </div>
                </div>
                <a asp-action="Myauctionproductsbids" class="btn-action btn-back-a">
                    <i class="fas fa-arrow-left"></i> Back
                </a>
            </div>

            <!-- hero: gallery + summary/countdown -->
            <div class="hero-grid">
                <div>
                    <div class="gallery-main" id="galleryMain" onclick="openLightbox()">
                        @if (!string.IsNullOrEmpty(img1))
                        {
                            <img id="mainImg" src="~/images/products/@img1" alt="@Model.Product?.Name"
                                 onerror="handleImgError(this, 'no-img', 'fa-image', 'No image available')" />
                            @if (imageCount > 1)
                            {
                                <div class="img-count-badge"><i class="fas fa-images"></i> @imageCount</div>
                            }
                            <div class="zoom-hint"><i class="fas fa-search-plus"></i> Click to zoom</div>
                        }
                        else
                        {
                            <div class="no-img" id="mainImgFallback"><i class="fas fa-image"></i><span>No image available</span></div>
                        }
                    </div>
                    <div class="thumb-row">
                        @if (!string.IsNullOrEmpty(img1))
                        {
                            <div class="thumb-box active" onclick="event.stopPropagation(); switchMainImage('@Url.Content("~/images/products/" + img1)', this)">
                                <img src="~/images/products/@img1" onerror="handleImgError(this, 'thumb-fallback', 'fa-image')" />
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(img2))
                        {
                            <div class="thumb-box" onclick="event.stopPropagation(); switchMainImage('@Url.Content("~/images/products/" + img2)', this)">
                                <img src="~/images/products/@img2" onerror="handleImgError(this, 'thumb-fallback', 'fa-image')" />
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(img3))
                        {
                            <div class="thumb-box" onclick="event.stopPropagation(); switchMainImage('@Url.Content("~/images/products/" + img3)', this)">
                                <img src="~/images/products/@img3" onerror="handleImgError(this, 'thumb-fallback', 'fa-image')" />
                            </div>
                        }
                    </div>
                </div>

                <div class="summary-col">
                    <div>
                        <h2 class="product-title">@Model.Product?.Name</h2>
                        <p class="product-desc">@Model.Product?.Description</p>
                    </div>

                    <div class="badge-row">
                        @{
                            var bidStatusClass = (Model.bidstatus ?? "").ToLower().Replace(" ", "-");
                        }
                        <span class="status-badge-row status-@bidStatusClass">
                            <i class="fas fa-circle" style="font-size:0.45rem;"></i> Your Bid: @Model.bidstatus
                        </span>
                        <span class="status-badge-row status-@(IsAvailableForBid(Model.Product?.AvailableForBid) ? "yes" : "no")">
                            <i class="fas fa-gavel" style="font-size:0.7rem;"></i>
                            @(IsAvailableForBid(Model.Product?.AvailableForBid) ? "Auction Open" : "Not Available")
                        </span>
                    </div>

                    <div class="price-highlight">
                        <div class="price-box">
                            <div class="p-label">Your Bid</div>
                            <div class="p-value">Rs. @Model.bidamount</div>
                            @if (Model.Product != null)
                            {
                                <div class="p-diff">+Rs. @(Model.bidamount - Model.Product.BidPrice) above starting</div>
                            }
                        </div>
                        <div class="price-box">
                            <div class="p-label">Starting Price</div>
                            <div class="p-value">Rs. @Model.Product?.BidPrice</div>
                        </div>
                    </div>

                    <!-- countdown timer -->
                    <div class="countdown-card" id="countdownCard"
                         data-start="@Model.Product?.BidStartDate.ToString("yyyy-MM-dd")"
                         data-end="@Model.Product?.BidEndDate.ToString("yyyy-MM-dd")">
                        <div class="countdown-label">
                            <span class="lbl-text"><i class="fas fa-hourglass-half"></i> Auction Ends In</span>
                            <span class="countdown-duration" id="countdownDuration"></span>
                        </div>
                        <div class="countdown-units" id="countdownUnits">
                            <div class="countdown-unit"><div class="num" id="cd-days">--</div><div class="lbl">Days</div></div>
                            <div class="countdown-unit"><div class="num" id="cd-hours">--</div><div class="lbl">Hours</div></div>
                            <div class="countdown-unit"><div class="num" id="cd-mins">--</div><div class="lbl">Mins</div></div>
                            <div class="countdown-unit"><div class="num" id="cd-secs">--</div><div class="lbl">Secs</div></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- quick stats -->
        <div class="quick-stats">
            <div class="qs-item">
                <div class="qs-icon"><i class="fas fa-tag"></i></div>
                <div>
                    <div class="qs-label">List Price</div>
                    <div class="qs-value">Rs. @Model.Product?.price</div>
                </div>
            </div>
            <div class="qs-item">
                <div class="qs-icon"><i class="fas fa-layer-group"></i></div>
                <div>
                    <div class="qs-label">Category</div>
                    <div class="qs-value">@(Model.Product?.SubCategory?.category?.Name ?? "—")</div>
                </div>
            </div>
            <div class="qs-item">
                <div class="qs-icon"><i class="fas fa-tags"></i></div>
                <div>
                    <div class="qs-label">Sub Category</div>
                    <div class="qs-value">@(Model.Product?.SubCategory?.Name ?? "—")</div>
                </div>
            </div>
            <div class="qs-item">
                <div class="qs-icon"><i class="fas fa-gavel"></i></div>
                <div>
                    <div class="qs-label">Total Bids</div>
                    <div class="qs-value">@bidHistory.Count</div>
                </div>
            </div>
        </div>

        <!-- your bid + auction info -->
        <div class="cards-row">
            <div class="sub-card">
                <div class="section-title">
                    <div class="st-left"><i class="fas fa-receipt"></i> Your Bid</div>
                </div>
                <div class="info-grid">
                    <div class="info-row"><span class="k">Bidder Name</span><span class="v">@Model.User?.UserName</span></div>
                    <div class="info-row" style="grid-column: 1 / -1;"><span class="k">Bidder Email</span><span class="v">@Model.User?.Email</span></div>
                    <div class="info-row"><span class="k">Bid Amount</span><span class="v">Rs. @Model.bidamount</span></div>
                    <div class="info-row"><span class="k">Bid Status</span><span class="v">@Model.bidstatus</span></div>
                </div>
            </div>

            <div class="sub-card">
                <div class="section-title">
                    <div class="st-left"><i class="fas fa-clock"></i> Auction Period</div>
                </div>
                <div class="info-grid">
                    <div class="info-row" style="grid-column: 1 / -1;"><span class="k">Starting Price</span><span class="v">Rs. @Model.Product?.BidPrice</span></div>
                    <div class="info-row"><span class="k">Start Date</span><span class="v">@Model.Product?.BidStartDate</span></div>
                    <div class="info-row"><span class="k">End Date</span><span class="v">@Model.Product?.BidEndDate</span></div>
                </div>
            </div>
        </div>

        <!-- previous bids timeline -->
        <div class="sub-card standalone-card">
            <div class="section-title">
                <div class="st-left"><i class="fas fa-history"></i> Previous Bids</div>
                <span class="timeline-caption">Ordered from lowest to highest</span>
            </div>
            @if (bidHistory.Any())
            {
                var maxBid = bidHistory.Max(b => b.bidamount);
                <div class="timeline">
                    @for (int i = 0; i < bidHistory.Count; i++)
                    {
                        var b = bidHistory[i];
                        bool isLeading = b.bidamount == maxBid;
                        bool isCurrent = b.Id == Model.Id;
                        <div class="timeline-item @(isCurrent ? "is-current" : "") @(isLeading ? "is-leading" : "")">
                            <div class="timeline-dot">@(i + 1)</div>
                            <div class="timeline-content">
                                <div class="timeline-amount">Rs. @b.bidamount</div>
                                <div class="timeline-user">@(b.User?.UserName ?? "Unknown bidder")</div>
                                <div class="timeline-badges">
                                    @if (isLeading)
                                    {
                                        <span class="tl-badge leading"><i class="fas fa-crown"></i> Leading</span>
                                    }
                                    @if (isCurrent)
                                    {
                                        <span class="tl-badge current">Your Bid</span>
                                    }
                                    <span class="tl-badge status">@b.bidstatus</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="timeline-empty"><i class="fas fa-info-circle"></i> No other bids have been placed yet.</div>
            }
        </div>

    </div>

    <!-- lightbox -->
    <div class="lightbox-overlay" id="lightboxOverlay" onclick="closeLightbox(event)">
        <button class="lightbox-close" onclick="closeLightbox(event)"><i class="fas fa-times"></i></button>
        <img id="lightboxImg" src="" alt="" />
    </div>
</div>

<script>
    function handleImgError(imgEl, fallbackClass, iconClass, extraText) {
        const div = document.createElement('div');
        div.className = fallbackClass;
        div.style.width = '100%';
        div.style.height = '100%';
        div.style.display = 'flex';
        div.style.flexDirection = extraText ? 'column' : 'row';
        div.style.alignItems = 'center';
        div.style.justifyContent = 'center';
        div.innerHTML = '<i class="fas ' + iconClass + '"></i>' + (extraText ? '<span>' + extraText + '</span>' : '');
        imgEl.replaceWith(div);
    }

    function switchMainImage(url, thumbEl) {
        const main = document.getElementById('galleryMain');
        let img = document.getElementById('mainImg');
        if (!img) {
            main.innerHTML = '<img id="mainImg" src="" alt="" /><div class="zoom-hint"><i class="fas fa-search-plus"></i> Click to zoom</div>';
            img = document.getElementById('mainImg');
        }
        img.style.opacity = 0;
        setTimeout(() => {
            img.src = url;
            img.style.opacity = 1;
        }, 150);

        document.querySelectorAll('.thumb-box').forEach(t => t.classList.remove('active'));
        thumbEl.classList.add('active');
    }

    function openLightbox() {
        const mainImg = document.getElementById('mainImg');
        if (!mainImg || !mainImg.src) return;
        document.getElementById('lightboxImg').src = mainImg.src;
        document.getElementById('lightboxOverlay').classList.add('open');
    }

    function closeLightbox(e) {
        if (e) e.stopPropagation();
        document.getElementById('lightboxOverlay').classList.remove('open');
    }

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeLightbox();
    });

    (function () {
        const card = document.getElementById('countdownCard');
        if (!card) return;
        const startRaw = card.getAttribute('data-start');
        const endRaw = card.getAttribute('data-end');
        if (!endRaw) {
            card.querySelector('.lbl-text').innerHTML = '<i class="fas fa-question-circle"></i> No end date set';
            return;
        }
        const endTime = new Date(endRaw + 'T23:59:59').getTime();

        if (startRaw) {
            const startTime = new Date(startRaw + 'T00:00:00').getTime();
            const totalDays = Math.max(0, Math.round((endTime - startTime) / (1000 * 60 * 60 * 24)));
            document.getElementById('countdownDuration').textContent = totalDays + ' day listing';
        }

        const elDays = document.getElementById('cd-days');
        const elHours = document.getElementById('cd-hours');
        const elMins = document.getElementById('cd-mins');
        const elSecs = document.getElementById('cd-secs');

        let prev = { d: null, h: null, m: null, s: null };

        function pulse(el, newVal, prevVal) {
            el.textContent = String(newVal).padStart(2, '0');
            if (prevVal !== null && prevVal !== newVal) {
                el.classList.remove('tick');
                void el.offsetWidth;
                el.classList.add('tick');
            }
        }

        function tick() {
            const now = new Date().getTime();
            const diff = endTime - now;

            if (diff <= 0) {
                card.classList.add('ended');
                card.classList.remove('ending-soon');
                card.querySelector('.lbl-text').innerHTML = '<i class="fas fa-flag-checkered"></i> Auction Status';
                document.getElementById('countdownUnits').outerHTML = '<div class="ended-msg" id="countdownUnits"><i class="fas fa-times-circle"></i> This auction has ended</div>';
                clearInterval(timerHandle);
                return;
            }

            const d = Math.floor(diff / (1000 * 60 * 60 * 24));
            const h = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
            const s = Math.floor((diff % (1000 * 60)) / 1000);

            pulse(elDays, d, prev.d);
            pulse(elHours, h, prev.h);
            pulse(elMins, m, prev.m);
            pulse(elSecs, s, prev.s);
            prev = { d, h, m, s };

            if (diff < 1000 * 60 * 60 * 24) {
                card.classList.add('ending-soon');
            } else {
                card.classList.remove('ending-soon');
            }
        }

        tick();
        const timerHandle = setInterval(tick, 1000);
    })();
</script>