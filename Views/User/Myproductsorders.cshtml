@model IEnumerable<Art_Gallery.Models.Order>
@{
    ViewData["Title"] = "Orders Received";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}
@functions {
    // Image1 sometimes ends up saved as a full disk path (e.g. C:\Users\...\products\file.jpg)
    // instead of just the filename, which breaks the <img> src. This pulls out just the
    // filename regardless of how it was stored, so it always resolves under wwwroot/images/products.
    string GetProductImageFileName(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return string.Empty;
        var normalized = raw.Replace('\\', '/');
        var fileName = normalized.Substring(normalized.LastIndexOf('/') + 1);
        return fileName;
    }
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />

