        70% {
            transform: scale(0.9);
        }

        100% {
            transform: scale(1);
        }
    }

    .sales-page .toast-success .toast-content {
        flex: 1;
    }

    .sales-page .toast-success .toast-title {
        font-weight: 700;
        color: #1a1a2e;
        font-size: 1rem;
    }

    .sales-page .toast-success .toast-message {
        color: #6c757d;
        font-size: 0.9rem;
        margin-top: 2px;
    }

    .sales-page .toast-success.hide {
        animation: slideOutRightSales 0.5s cubic-bezier(0.2, 0.9, 0.4, 1) forwards;
    }

    @@keyframes slideOutRightSales {
        from {
            transform: translateX(0) scale(1);
            opacity: 1;
        }

        to {
            transform: translateX(120%) scale(0.9);
            opacity: 0;
        }
    }

    .sales-page .fade-out {
        animation: fadeOutSales 0.5s cubic-bezier(0.2, 0.9, 0.4, 1) forwards;
    }

    @@keyframes fadeOutSales {
        0% {
            opacity: 1;
            transform: scale(1) translateY(0);
        }

        100% {
            opacity: 0;
            transform: scale(0.8) translateY(-20px);
        }
    }

    /* responsive */
    @@media (max-width: 768px) {
        .sales-page .admin-card {
            padding: 1.2rem;
        }

        .sales-page .heading-green {
            font-size: 1.45rem;
        }

        .sales-page .brand-icon {
            width: 40px;
            height: 40px;
            font-size: 1.25rem;
        }

        .sales-page .table-green-white thead th,
        .sales-page .table-green-white tbody td {
            padding: 10px 10px;
            font-size: 0.84rem;
        }

        .sales-page .btn-action {
            padding: 6px 12px;
            font-size: 0.7rem;
        }

        .sales-page .actions-wrap {
            gap: 4px;
        }

        .sales-page .table-green-white tbody td:first-child {
            padding-left: 14px;
        }

        .sales-page .table-green-white tbody td:last-child {
            padding-right: 14px;
        }

        .sales-page .toast-container-custom {
            top: 20px;
            right: 20px;
            left: 20px;
            min-width: unset;
            max-width: unset;
        }

        .sales-page .delete-modal {
            padding: 2rem 1.5rem;
        }

            .sales-page .delete-modal .modal-actions {
                flex-direction: column;
            }

        .sales-page .stats-row {
            grid-template-columns: repeat(2, 1fr);
        }

        .sales-page .toolbar-row {
            flex-direction: column;
            align-items: stretch;
        }

        .sales-page .search-box {
            max-width: unset;
        }

        .sales-page .toolbar-right {
            justify-content: space-between;
        }
    }

    @@media (max-width: 576px) {
        .sales-page .header-section {
            flex-direction: column;
            align-items: start;
            gap: 0.8rem;
        }

        .sales-page .header-actions {
            width: 100%;
            justify-content: space-between;
        }

        .sales-page .stats-row {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="sales-page">
    <div class="container-cust">
        <div class="admin-card">

            <!-- header -->
            <div class="header-section">
                <div class="brand-head">
                    <div class="brand-icon">
                        <i class="fas fa-store"></i>
                    </div>
                    <h1 class="heading-green">
                        Orders Received
                        <span>@Model.Count()</span>
                    </h1>
                </div>
                <div class="header-actions">
                    <div class="status-badge">
                        <i class="fas fa-circle" style="font-size: 0.5rem;"></i> seller account
                    </div>
                </div>
            </div>

            @if (TempData["Message"] != null)
            {
                <div class="alert-success-cust">
                    <i class="fas fa-check-circle"></i> @TempData["Message"]
                </div>
            }

            @if (!Model.Any())
            {
                <div class="alert-info-cust">
                    <i class="fas fa-box-open"></i>
                    No orders have been placed for your products yet.
                </div>
            }
            else
            {
                <!-- stat cards -->
                <div class="stats-row">
                    <div class="stat-card">
                        <div class="stat-icon"><i class="fas fa-box"></i></div>
                        <div>
                            <div class="stat-value">@Model.Count()</div>
                            <div class="stat-label">Total Orders</div>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon"><i class="fas fa-hourglass-half"></i></div>
                        <div>
                            <div class="stat-value">@Model.Count(o => o.Status != null && o.Status.ToLower() == "pending")</div>
                            <div class="stat-label">Pending</div>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
                        <div>
                            <div class="stat-value">@Model.Count(o => o.Status != null && (o.Status.ToLower() == "delivered" || o.Status.ToLower() == "completed"))</div>
                            <div class="stat-label">Delivered</div>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon"><i class="fas fa-rupee-sign"></i></div>
                        <div>
                            <div class="stat-value">Rs. @Model.Sum(o => o.PricePaid)</div>
                            <div class="stat-label">Total Revenue</div>
                        </div>
                    </div>
                </div>

                <!-- search / toolbar -->
                <div class="toolbar-row">
                    <div class="search-box">
                        <i class="fas fa-search"></i>
                        <input type="text" id="orderSearch" placeholder="Search by product, buyer, email or status..." onkeyup="filterOrders()" />
                    </div>
                    <div class="toolbar-right">
                        <span class="result-count" id="resultCount">@Model.Count() of @Model.Count() shown</span>
                        <span class="scroll-hint">
                            <i class="fas fa-arrows-left-right"></i> click &amp; drag to scroll
                        </span>
                    </div>
                </div>

                <!-- table -->
                <div class="table-responsive-cust" id="orderTableScroll">
                    <table class="table table-green-white">
                        <thead>
                            <tr>
                                <th><span class="th-inner"><i class="fas fa-image fa-fw-lead"></i> Image</span></th>
                                <th class="sortable" onclick="sortTable(1, this)"><span class="th-inner"><i class="fas fa-box-open fa-fw-lead"></i> Product <i class="fas fa-sort sort-icon"></i></span></th>
                                <th class="sortable" onclick="sortTable(2, this)"><span class="th-inner"><i class="fas fa-user fa-fw-lead"></i> Buyer <i class="fas fa-sort sort-icon"></i></span></th>
                                <th><span class="th-inner"><i class="fas fa-hashtag fa-fw-lead"></i> Quantity</span></th>
                                <th class="sortable" onclick="sortTable(4, this)"><span class="th-inner"><i class="fas fa-rupee-sign fa-fw-lead"></i> Total Price <i class="fas fa-sort sort-icon"></i></span></th>
                                <th><span class="th-inner"><i class="fas fa-credit-card fa-fw-lead"></i> Payment</span></th>
                                <th class="sortable" onclick="sortTable(6, this)"><span class="th-inner"><i class="fas fa-calendar-alt fa-fw-lead"></i> Order Date <i class="fas fa-sort sort-icon"></i></span></th>
                                <th><span class="th-inner"><i class="fas fa-info-circle fa-fw-lead"></i> Status</span></th>
                                <th class="text-end"><span class="th-inner"><i class="fas fa-bolt fa-fw-lead"></i> Actions</span></th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int rowIndex = 0;
                            }
                            @foreach (var item in Model)
                            {
                                rowIndex++;
                                var statusClass = (item.Status ?? "").ToLower().Replace(" ", "-");
                                <tr style="--i: @rowIndex;" data-order-id="@item.Id">
                                    <td>
                                        @{
                                            var imgFile = GetProductImageFileName(item.Product?.Image1);
                                        }
                                        @if (!string.IsNullOrEmpty(imgFile))
                                        {
                                            <img src="~/images/products/@imgFile"
                                                 class="product-thumb"
                                                 onerror="this.onerror=null;this.replaceWith(Object.assign(document.createElement('div'),{className:'thumb-fallback',innerHTML:'<i class=\'fas fa-image\'></i>'}));" />
                                        }
                                        else
                                        {
                                            <div class="thumb-fallback"><i class="fas fa-image"></i></div>
                                        }
                                    </td>
                                    <td><span class="product-name-cell">@item.Product?.Name</span></td>
                                    <td>
                                        <div class="buyer-cell">
                                            <span class="buyer-name">@item.User?.UserName</span>
                                            <span class="buyer-email">@item.User?.Email</span>
                                        </div>
                                    </td>
                                    <td><span class="info-pill">@item.Quantity</span></td>
                                    <td><span class="price-cell">Rs. @item.PricePaid</span></td>
                                    <td><span class="info-pill">@(item.Payment?.ModeofPayment ?? "N/A")</span></td>
                                    <td><span class="info-pill">@item.OrderDate.ToString("dd-MMM-yyyy")</span></td>
                                    <td>
                                        <span class="status-badge-row status-@statusClass">
                                            <i class="fas fa-circle" style="font-size: 0.45rem;"></i> @item.Status
                                        </span>
                                    </td>
                                    <td style="text-align: right;">
                                        <div class="actions-wrap" style="justify-content: flex-end;">
                                            <a asp-action="Myproductsorderdetails" asp-route-id="@item.Id" class="btn btn-action btn-details">
                                                <i class="fas fa-eye"></i> Details
                                            </a>
                                            <button type="button" class="btn btn-action btn-delete"
                                                    onclick="openDeleteModal('@item.Id')">
                                                <i class="fas fa-trash-alt"></i> Delete
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                            <tr class="empty-state-row" id="noResultsRow" style="display: none;">
                                <td colspan="9">
                                    <i class="fas fa-inbox"></i>
                                    No matching orders found.
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- footer -->
                <div class="table-footer">
                    <span>
                        <i class="fas fa-arrow-right"></i> hover rows · click headers to sort · green theme
                    </span>
                    <span class="pill">
                        <i class="fas fa-box"></i> @Model.Count() orders
                    </span>
                </div>
            }

        </div> <!-- end admin-card -->
    </div> <!-- end container-cust -->
    <!-- ===== DELETE CONFIRMATION MODAL ===== -->
    <div id="deleteModal" class="delete-modal-overlay">
        <div class="delete-modal">
            <div class="modal-icon">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <h3>Delete This Order?</h3>
            <p>
                Are you sure you want to delete order
                <span class="order-id-highlight" id="modalOrderId">#0</span>?
                <br>
                <small style="color: #dc3545; font-weight: 500;">
                    <i class="fas fa-exclamation-circle"></i> This action cannot be undone.
                </small>
            </p>
            <div class="modal-actions">
                <button class="btn-cancel" onclick="closeDeleteModal()">
                    <i class="fas fa-times"></i> Cancel
                </button>
                <button class="btn-confirm-delete" id="confirmDeleteBtn">
                    <i class="fas fa-trash-alt"></i> Yes, Delete
                </button>
            </div>
        </div>
    </div>

    <!-- ===== SUCCESS TOAST ===== -->
    <div id="successToast" class="toast-container-custom">
        <div id="toastMessage" class="toast-success" style="display: none;">
            <i class="fas fa-check-circle"></i>
            <div class="toast-content">
                <div class="toast-title">Deleting...</div>
                <div class="toast-message" id="toastText">Redirecting to delete confirmation</div>
            </div>
        </div>
    </div>
</div> <!-- end sales-page -->

<script>
    let deleteOrderId = null;

    // Live search filter across product, buyer, email, payment and status columns
    function filterOrders() {
        const query = document.getElementById('orderSearch').value.trim().toLowerCase();
        const rows = document.querySelectorAll('.sales-page .table-green-white tbody tr:not(#noResultsRow)');
        let visibleCount = 0;

        rows.forEach(row => {
            const text = row.textContent.toLowerCase();
            const matches = text.includes(query);
            row.style.display = matches ? '' : 'none';
            if (matches) visibleCount++;
        });

        document.getElementById('noResultsRow').style.display = visibleCount === 0 ? '' : 'none';

        const totalRows = rows.length;
        const countEl = document.getElementById('resultCount');
        if (countEl) countEl.textContent = `${visibleCount} of ${totalRows} shown`;
    }

    // Click-to-sort table columns
    let sortDirections = {};
    function sortTable(colIndex, headerEl) {
        const table = headerEl.closest('table');
        const tbody = table.querySelector('tbody');
        const rows = Array.from(tbody.querySelectorAll('tr:not(#noResultsRow)'));

        const asc = !sortDirections[colIndex];
        sortDirections = {};
        sortDirections[colIndex] = asc;

        table.querySelectorAll('thead th').forEach(th => th.classList.remove('sort-asc', 'sort-desc'));
        headerEl.classList.add(asc ? 'sort-asc' : 'sort-desc');

        rows.sort((a, b) => {
            const cellA = a.children[colIndex].textContent.replace(/[^0-9.\-a-zA-Z]/g, '').trim().toLowerCase();
            const cellB = b.children[colIndex].textContent.replace(/[^0-9.\-a-zA-Z]/g, '').trim().toLowerCase();
            const numA = parseFloat(cellA), numB = parseFloat(cellB);
            const bothNumeric = !isNaN(numA) && !isNaN(numB);
            const cmp = bothNumeric ? (numA - numB) : cellA.localeCompare(cellB);
            return asc ? cmp : -cmp;
        });

        rows.forEach(row => tbody.insertBefore(row, document.getElementById('noResultsRow')));
    }

    function openDeleteModal(orderId) {
        deleteOrderId = orderId;
        document.getElementById('modalOrderId').textContent = '#' + orderId;

        const modal = document.getElementById('deleteModal');
        modal.style.display = 'flex';

        const modalContent = modal.querySelector('.delete-modal');
        modalContent.style.animation = 'none';
        setTimeout(() => {
            modalContent.style.animation = 'modalSlideUpSales 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275)';
        }, 10);
    }

    function closeDeleteModal() {
        document.getElementById('deleteModal').style.display = 'none';
        deleteOrderId = null;
    }

    document.getElementById('confirmDeleteBtn').addEventListener('click', function () {
        if (deleteOrderId) {
            const idToDelete = deleteOrderId; // capture before closeDeleteModal() clears it
            const row = document.querySelector(`tr[data-order-id="${idToDelete}"]`);
            closeDeleteModal();
            showSuccessToast('Deleted!', 'The order was removed successfully.');

            if (row) {
                row.classList.add('fade-out');
            }

            setTimeout(() => {
                window.location.href = '@Url.Action("Myproductsorderdeletelogic", "User")/' + idToDelete;
            }, 900);
        }
    });

    document.getElementById('deleteModal').addEventListener('click', function (e) {
        if (e.target === this) closeDeleteModal();
    });

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeDeleteModal();
    });

    function showSuccessToast(title, message) {
        const toast = document.getElementById('toastMessage');
        const textSpan = document.getElementById('toastText');
        const titleEl = toast.querySelector('.toast-title');

        if (titleEl) titleEl.innerText = title;
        if (textSpan) textSpan.innerText = message;

        toast.classList.remove('hide');
        toast.style.display = 'flex';

        toast.style.animation = 'none';
        setTimeout(() => {
            toast.style.animation = 'slideInRightSales 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275)';
        }, 10);

        clearTimeout(window.toastTimeout);
        window.toastTimeout = setTimeout(() => {
            toast.classList.add('hide');
            setTimeout(() => { toast.style.display = 'none'; }, 500);
        }, 4000);
    }

    // ===== Click & drag horizontal scrolling for the table =====
    (function () {
        const scroller = document.getElementById('orderTableScroll');
        if (!scroller) return;

        let isDown = false;
        let startX;
        let scrollLeftStart;

        scroller.addEventListener('mousedown', (e) => {
            isDown = true;
            scroller.classList.add('dragging');
            startX = e.pageX - scroller.offsetLeft;
            scrollLeftStart = scroller.scrollLeft;
        });

        window.addEventListener('mouseup', () => {
            isDown = false;
            scroller.classList.remove('dragging');
        });

        scroller.addEventListener('mouseleave', () => {
            isDown = false;
            scroller.classList.remove('dragging');
        });

        scroller.addEventListener('mousemove', (e) => {
            if (!isDown) return;
            e.preventDefault();
            const x = e.pageX - scroller.offsetLeft;
            const walk = (x - startX);
            scroller.scrollLeft = scrollLeftStart - walk;
        });

        // touch support
        let touchStartX = 0;
        let touchScrollStart = 0;
        scroller.addEventListener('touchstart', (e) => {
            touchStartX = e.touches[0].pageX;
            touchScrollStart = scroller.scrollLeft;
        }, { passive: true });

        scroller.addEventListener('touchmove', (e) => {
            const dx = e.touches[0].pageX - touchStartX;
            scroller.scrollLeft = touchScrollStart - dx;
        }, { passive: true });
    })();
</script>
