        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(8px);
        z-index: 10000;
        display: none;
        align-items: center;
        justify-content: center;
        animation: fadeInOverlaySales 0.3s ease;
    }

    @@keyframes fadeInOverlaySales {
        from {
            opacity: 0;
